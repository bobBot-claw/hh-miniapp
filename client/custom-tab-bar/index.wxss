/* custom-tab-bar/index.wxss - 悬浮毛玻璃胶囊 */
.float-tabbar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 48rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 999;
}
.float-tabbar-inner {
  display: flex; justify-content: space-around; align-items: center;
  background: rgba(30, 30, 50, 0.72);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-radius: 48rpx;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4);
}
.float-tabbar-item {
  display: flex; flex-direction: column; align-items: center; gap: 0;
  padding: 10rpx 28rpx; border-radius: 32rpx;
  transition: all 0.2s ease;
}
.float-tab-active {
  background: rgba(124, 111, 247, 0.18);
}
.float-tab-label {
  font-size: 24rpx; color: #555570; font-weight: 500;
  transition: color 0.2s ease;
}
.float-tab-active .float-tab-label {
  color: #9d93fa; font-weight: 700;
}
