/* custom-tab-bar/index.wxss - 悬浮毛玻璃胶囊 - 浅色 */
.float-tabbar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 48rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 999;
}
.float-tabbar-inner {
  display: flex; justify-content: space-around; align-items: center;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-radius: 48rpx;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}
.float-tabbar-item {
  display: flex; flex-direction: column; align-items: center; gap: 0;
  padding: 10rpx 28rpx; border-radius: 32rpx;
  transition: all 0.2s ease;
}
.float-tab-active {
  background: rgba(124, 111, 247, 0.1);
}
.float-tab-label {
  font-size: 24rpx; color: #a0a0b4; font-weight: 500;
  transition: color 0.2s ease;
}
.float-tab-active .float-tab-label {
  color: #7c6ff7; font-weight: 700;
}
