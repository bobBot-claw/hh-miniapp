/* custom-tab-bar/index.wxss - 深空悬浮 TabBar v2.0 */
.float-tabbar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 12rpx 40rpx calc(12rpx + env(safe-area-inset-bottom));
  z-index: 999;
}
/* 底部光晕 */
.tabbar-glow {
  position: absolute;
  bottom: 0; left: 50%; transform: translateX(-50%);
  width: 400rpx; height: 80rpx;
  background: radial-gradient(ellipse, rgba(124,111,247,0.15) 0%, transparent 70%);
  pointer-events: none;
}
.float-tabbar-inner {
  display: flex; justify-content: space-around; align-items: center;
  background: rgba(10,10,30,0.85);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-radius: 48rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  box-shadow: 0 4rpx 32rpx rgba(0,0,0,0.4), 0 0 60rpx rgba(124,111,247,0.06);
}
.float-tabbar-item {
  position: relative;
  display: flex; flex-direction: column; align-items: center;
  padding: 10rpx 28rpx; border-radius: 32rpx;
  transition: all 0.25s ease;
}
.float-tab-active {
  background: rgba(124,111,247,0.12);
}
/* 激活指示器 */
.tab-indicator {
  position: absolute; top: -2rpx; left: 50%; transform: translateX(-50%);
  width: 24rpx; height: 6rpx;
  background: linear-gradient(90deg, #7c6ff7, #4ecdc4);
  border-radius: 3rpx;
  box-shadow: 0 0 12rpx rgba(124,111,247,0.6);
}
.float-tab-label {
  font-size: 24rpx; color: rgba(255,255,255,0.35); font-weight: 500;
  transition: all 0.25s ease;
}
.float-tab-active .float-tab-label {
  color: #fff; font-weight: 700;
  text-shadow: 0 0 12rpx rgba(124,111,247,0.5);
}
