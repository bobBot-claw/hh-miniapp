/* app.wxss — 慢慢变好 v0.7 — 暖调极简·光遇感 */

page {
  /* 底色 */
  --neutral-0: #FFFFFF;
  --neutral-25: #FCFCFD;
  --neutral-100: #F8F4EE;
  --neutral-200: #EAE3D9;
  --neutral-900: #2A2820;

  /* 品牌色 — 墨绿 */
  --brand-50: #ECFDF3;
  --brand-100: #D1F7DE;
  --brand-600: #147D45;
  --brand-700: #106438;

  /* 暖金辅色 — 光遇烛光感 */
  --gold-300: #E5CC9A;
  --gold-400: #D4B779;
  --gold-500: #C9A66B;
  --gold-600: #A88950;

  /* 光晕 — 2 段暖调 */
  --halo-cream: rgba(248, 240, 220, 0.55);
  --halo-gold: rgba(212, 183, 121, 0.45);

  /* 文字 */
  --text-primary: rgba(0, 0, 0, 0.88);
  --text-secondary: rgba(60, 60, 67, 0.72);
  --text-tertiary: rgba(60, 60, 67, 0.48);
  --text-inverse: rgba(255, 255, 255, 0.95);

  /* 边框 / 阴影 */
  --border-subtle: rgba(10, 10, 15, 0.05);
  --border-glass: rgba(255, 255, 255, 0.6);
  --shadow-sm: 0 1px 2px rgba(10, 10, 25, 0.05);

  /* 全局 */
  background: var(--neutral-25);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  letter-spacing: 0.02em;
}

view, text, image, scroll-view { box-sizing: border-box; }

/* ═══ 共享类 ═══ */

/* 暖色光晕背景 */
.warm-bg {
  position: relative;
}
.warm-bg::before {
  content: '';
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 70% 60% at 30% 30%, var(--halo-cream) 0%, transparent 65%),
    radial-gradient(ellipse 55% 50% at 70% 70%, var(--halo-gold) 0%, transparent 65%);
  filter: blur(60px);
  z-index: -1;
  pointer-events: none;
}

/* 深色沉浸背景(行动中/情绪急救等) */
.dark-bg {
  position: relative;
  background: #1a1810;
}
.dark-bg::before {
  content: '';
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 50% 40% at 50% 40%, rgba(212, 183, 121, 0.12) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 毛玻璃 */
.glass {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border: 1rpx solid var(--border-glass);
}

/* CTA — 暖金色主按钮 */
.cta {
  display: flex; align-items: center; justify-content: center;
  padding: 28rpx 80rpx;
  border-radius: 100rpx;
  background: var(--gold-500);
  color: #fff;
  font-size: 28rpx; font-weight: 500;
  letter-spacing: 6rpx;
  box-shadow: 0 4rpx 24rpx rgba(201, 166, 107, 0.5);
  border: none;
}

/* CTA — 墨绿 */
.cta-green {
  background: var(--brand-600);
  box-shadow: 0 4rpx 24rpx rgba(20, 125, 69, 0.4);
}

/* 次要文字按钮 */
.btn-text {
  background: transparent;
  color: var(--text-tertiary);
  font-size: 24rpx; font-weight: 400;
  letter-spacing: 6rpx;
  padding: 20rpx 32rpx;
  border: none;
}

/* 深色上的文字按钮 */
.btn-text-inverse {
  background: transparent;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx; font-weight: 400;
  letter-spacing: 6rpx;
  padding: 20rpx 32rpx;
  border: none;
}

/* 卡片 */
.card {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border: 1rpx solid var(--border-glass);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

/* 插画 — 暗态(模糊) */
.illust-dim {
  filter: blur(12px) saturate(85%) brightness(0.65);
  opacity: 1;
  transition: filter 1.5s ease, opacity 1.5s ease;
}

/* 插画 — 亮态(清晰) */
.illust-lit {
  filter: blur(0) saturate(105%) brightness(1);
  opacity: 1;
}

/* ═══ 动画 ═══ */

/* 呼吸 — 光点 */
@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.1); opacity: 0.9; }
}

/* 光点漂浮 — 萤火虫 */
@keyframes float-particle {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  10% { opacity: 0.9; }
  50% { transform: translateY(-50%) translateX(15px); opacity: 0.7; }
  90% { opacity: 0.4; }
  100% { transform: translateY(-110%) translateX(25px); opacity: 0; }
}

/* 进度环旋转 */
@keyframes ring-pulse {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 1; }
}

/* ═══ 通用 ═══ */
.flex-row { display: flex; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }
.text-dim { color: var(--text-tertiary); }
.safe-bottom { padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); }
