/* app.wxss — 慢慢变好 · 七日微光计划 — 与 demo 完全一致 */

page {
  /* 配色 — 与 demo :root 一致 */
  --bg: #FCFCFD;
  --surface: #FFFFFF;
  --ink: #1F2937;
  --ink-mute: #6B7280;
  --ink-dim: #9CA3AF;
  --line: #EEF0F3;
  --line-soft: #F4F5F7;
  --gold: #147D45;
  --gold-soft: #E8F1EC;
  --warm: #FDF6EE;
  --warm-2: #FDF1DF;
  --halo-cream: #FDF6EC;
  --halo-gold: #F0E2C9;
  --done: #3C8F60;
  --dot: #DCE5DD;

  /* 全局排版 — demo: font-weight:300, line-height:1.7, letter-spacing:0.02em */
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-weight: 300;
  line-height: 1.7;
  letter-spacing: 0.02em;
  -webkit-font-smoothing: antialiased;
}

view, text, image, scroll-view, input { box-sizing: border-box; }

/* ═══ 共享组件 — 与 demo 完全一致 ═══ */

/* CTA 按钮 — demo: .cta */
.cta {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--gold);
  color: #fff;
  padding: 28rpx 64rpx;
  border-radius: 80rpx;
  font-size: 26rpx;
  letter-spacing: 0.2em;
  border: none;
  font-family: inherit;
}
.cta:active { transform: scale(0.97); }
.cta text { color: #fff; letter-spacing: 0.2em; }

/* 次要按钮 */
.cta-alt {
  display: inline-flex; align-items: center; justify-content: center;
  background: transparent;
  color: var(--ink-mute);
  padding: 28rpx 64rpx;
  border-radius: 80rpx;
  font-size: 26rpx;
  letter-spacing: 0.2em;
  border: 1rpx solid var(--line);
  font-family: inherit;
}
.cta-alt text { color: var(--ink-mute); letter-spacing: 0.2em; }

/* 推荐卡 — demo: .recommend */
.recommend {
  background: linear-gradient(150deg, var(--warm) 0%, var(--warm-2) 100%);
  border-radius: 48rpx;
  padding: 56rpx 48rpx;
  margin-bottom: 36rpx;
  position: relative;
}
.recommend .tag {
  font-size: 22rpx; letter-spacing: 0.3em; color: var(--gold);
  margin-bottom: 28rpx;
}

/* 周历条 — demo: .week-bar */
.week-bar {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 48rpx;
  padding: 36rpx 44rpx;
  margin-bottom: 36rpx;
}

/* 数据卡片 — demo: .data-card */
.data-card {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 36rpx;
}

/* 提示说明 — demo: .explain */
.explain {
  font-size: 26rpx;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
  line-height: 1.85;
  padding: 28rpx 36rpx;
  background: var(--warm);
  border-radius: 36rpx;
}

/* 隐私标记 */
.privacy-tag {
  font-size: 22rpx;
  color: var(--gold);
  letter-spacing: 0.24em;
  margin-bottom: 12rpx;
}

/* pill 标签 — demo: .mc-pill */
.pill {
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 1rpx solid var(--line);
  border-radius: 60rpx;
  font-size: 22rpx;
  letter-spacing: 0.2em;
  color: var(--ink-mute);
  margin-right: 12rpx;
  margin-bottom: 20rpx;
}
.pill.sel {
  background: var(--gold-soft);
  color: var(--gold);
  border-color: var(--gold-soft);
}
