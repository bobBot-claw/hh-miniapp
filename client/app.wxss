/* app.wxss - HH小程序全局样式 v2.0 - 质感升级 */

/* ===== 设计变量 ===== */
page {
  /* 背景层次：最深→卡片→浮起 */
  --color-bg: #0f0f1a;
  --color-bg-subtle: #161625;
  --color-bg-card: #1e1e32;
  --color-bg-elevated: #282845;
  --color-bg-glass: rgba(30, 30, 50, 0.75);

  /* 主题色 */
  --color-primary: #7c6ff7;
  --color-primary-light: #9d93fa;
  --color-primary-dark: #5b4fd4;
  --color-accent: #4ecdc4;
  --color-accent-warm: #ff6b6b;

  /* 文字层次 */
  --color-text: #eeeef5;
  --color-text-secondary: #8e8ea8;
  --color-text-muted: #555570;

  /* 边框与分割 */
  --color-border: rgba(255,255,255,0.06);
  --color-border-light: rgba(255,255,255,0.1);

  /* 语义色 */
  --color-success: #4ecdc4;
  --color-warning: #ffe66d;
  --color-danger: #ff6b6b;

  /* 字号 */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-md: 32rpx;
  --font-size-lg: 36rpx;
  --font-size-xl: 44rpx;
  --font-size-xxl: 56rpx;

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 全局 */
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: var(--font-size-base);
  line-height: 1.6;
}

/* ===== 全局重置 ===== */
view, text, image, scroll-view {
  box-sizing: border-box;
}

/* ===== 通用类 ===== */
.container {
  padding: var(--spacing-md);
  padding-bottom: calc(var(--spacing-xl) + env(safe-area-inset-bottom));
}

.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-accent { color: var(--color-accent); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-sm { font-size: var(--font-size-sm); }
.text-base { font-size: var(--font-size-base); }
.text-md { font-size: var(--font-size-md); }
.text-lg { font-size: var(--font-size-lg); }
.text-xl { font-size: var(--font-size-xl); }

/* ===== 卡片样式 - 质感升级 ===== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid var(--color-border);
}

.card-elevated {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid var(--color-border-light);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.2);
}

.card-glass {
  background: var(--color-bg-glass);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid var(--color-border-light);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* ===== 按钮样式 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: white;
  border-radius: var(--radius-xl);
  padding: 24rpx 48rpx;
  font-size: var(--font-size-md);
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(124, 111, 247, 0.35);
}
.btn-primary::after { border: none; }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-xl);
  padding: 22rpx 46rpx;
  font-size: var(--font-size-md);
  font-weight: 600;
  text-align: center;
}
.btn-outline::after { border: none; }

.btn-ghost {
  background: rgba(255,255,255,0.06);
  color: var(--color-text);
  border-radius: var(--radius-xl);
  padding: 22rpx 46rpx;
  font-size: var(--font-size-md);
  font-weight: 500;
  text-align: center;
  border: 1rpx solid var(--color-border);
}
.btn-ghost::after { border: none; }

/* ===== 标签样式 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  background: var(--color-bg-elevated);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}
.tag-active {
  background: var(--color-primary);
  color: white;
  border-color: var(--color-primary);
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--spacing-md) 0;
}

/* ===== 滚动区域 ===== */
.scroll-h { white-space: nowrap; }

/* ===== 加载状态 ===== */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}
.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-md);
}
.empty-state .empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

/* ===== 安全区域底部 ===== */
.safe-bottom {
  padding-bottom: calc(var(--spacing-lg) + env(safe-area-inset-bottom));
}
