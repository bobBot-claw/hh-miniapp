/* app.wxss - HH小程序全局样式 v5.0 — 极简沉浸·行动驱动 */

page {
  /* 深色基底 */
  --bg: #06060f;
  --bg-soft: #0c0c1a;
  --surface: rgba(255,255,255,0.05);
  --surface-hover: rgba(255,255,255,0.08);

  /* 主色 — 一紫一青，只做强调 */
  --primary: #7c6ff7;
  --primary-soft: rgba(124,111,247,0.12);
  --accent: #4ecdc4;

  /* 文字 — 只两层 */
  --text: rgba(255,255,255,0.88);
  --text-dim: rgba(255,255,255,0.4);

  /* 线 */
  --line: rgba(255,255,255,0.06);

  /* 语义 */
  --success: #4ecdc4;
  --danger: #ff6b6b;

  /* 全局 */
  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view, text, image, scroll-view { box-sizing: border-box; }

/* ═══ 共享类 — 极简 ═══ */

/* 全局安静背景 — 一层渐变 */
.deep-bg {
  position: relative;
}
.deep-bg::before {
  content: '';
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 50% 30%, rgba(124,111,247,0.06) 0%, transparent 60%),
              var(--bg);
  z-index: -1;
}

/* 卡片 — 最低存在感 */
.card {
  background: var(--surface);
  border-radius: 20rpx;
  padding: 28rpx;
}

/* CTA — 唯一需要突出的元素 */
.cta {
  display: flex; align-items: center; justify-content: center;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  background: var(--primary);
  color: #fff;
  font-size: 30rpx; font-weight: 700;
  letter-spacing: 2rpx;
}
.cta-sm {
  padding: 14rpx 32rpx;
  font-size: 24rpx;
  border-radius: 32rpx;
}

/* 标签 — 几乎隐形 */
.tag {
  font-size: 22rpx;
  color: var(--text-dim);
  background: var(--surface);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

/* 呼吸动画 */
@keyframes breathe {
  0%, 100% { opacity: 0.3; transform: scale(0.95); }
  50%      { opacity: 0.8; transform: scale(1.1); }
}

/* 浮动 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-8rpx); }
}

/* ═══ 通用 ═══ */
.flex-row { display: flex; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }

.text-dim { color: var(--text-dim); }

.safe-bottom { padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); }
