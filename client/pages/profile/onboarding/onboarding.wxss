/* pages/profile/onboarding/onboarding.wxss - 极简版 */
.page { min-height: 100vh; display: flex; flex-direction: column; padding: 80rpx 36rpx 36rpx; }
.dots { margin-bottom: 48rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: rgba(255,255,255,0.1); }
.dot-on { background: var(--primary); }

.step { flex: 1; }
.step-title { font-size: 40rpx; font-weight: 800; color: var(--text); display: block; margin-bottom: 12rpx; }
.step-sub { font-size: 28rpx; color: var(--text-dim); display: block; margin-bottom: 40rpx; }

.options { display: flex; flex-direction: column; gap: 12rpx; }
.opt {
  padding: 24rpx 28rpx; border-radius: 12rpx;
  background: var(--surface); border: 2rpx solid transparent;
}
.opt-on { border-color: var(--primary); background: var(--primary-soft); }
.opt-label { font-size: 28rpx; color: var(--text); font-weight: 500; }

.bottom { display: flex; gap: 16rpx; padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); }
.ctrl { padding: 14rpx 32rpx; border-radius: 32rpx; background: var(--surface); font-size: 24rpx; color: var(--text-dim); }
