/* pages/profile/onboarding/onboarding.wxss — 深空沉浸版 */

.page-onboarding {
  min-height: 100vh;
  display: flex; flex-direction: column;
  padding: 80rpx 32rpx 32rpx;
}

/* 进度点 */
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: rgba(255,255,255,0.1); }
.dot-active { background: var(--color-primary); box-shadow: 0 0 10rpx rgba(124,111,247,0.5); }

/* 步骤内容 */
.step-content { flex: 1; padding-top: 60rpx; }
.step-title { font-size: var(--font-size-xl); font-weight: 700; display: block; margin-bottom: 12rpx; color: var(--color-text); }
.step-subtitle { font-size: var(--font-size-base); display: block; margin-bottom: 48rpx; color: var(--color-text-secondary); }

/* 选项 */
.options-list { display: flex; flex-direction: column; gap: 16rpx; }
.option-card { padding: 32rpx 28rpx; border: 2rpx solid transparent; display: flex; flex-direction: column; gap: 4rpx; }
.option-selected { border-color: var(--color-primary) !important; background: rgba(124,111,247,0.08) !important; box-shadow: 0 0 20rpx rgba(124,111,247,0.1); }
.option-label { font-size: var(--font-size-md); font-weight: 500; color: var(--color-text); }
.option-desc { font-size: var(--font-size-sm); color: var(--color-text-secondary); padding-left: 4rpx; }

/* 底部按钮 */
.bottom-bar { display: flex; gap: 16rpx; padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); }
