<!--pages/profile/onboarding/onboarding.wxml - 极简版-->
<view class="page deep-bg">
  <view class="dots flex-center" style="gap:12rpx;">
    <view wx:for="{{steps}}" wx:key="index" class="dot {{step >= index ? 'dot-on' : ''}}"></view>
  </view>

  <view class="step">
    <text class="step-title">{{steps[step].title}}</text>
    <text class="step-sub">{{steps[step].subtitle}}</text>
    <view class="options">
      <view wx:for="{{steps[step].options}}" wx:key="key" class="opt {{item.selected ? 'opt-on' : ''}}" data-index="{{index}}" bindtap="onOptionTap">
        <text class="opt-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="bottom">
    <view wx:if="{{step > 0}}" class="ctrl" bindtap="onBack"><text>上一步</text></view>
    <view class="cta" style="flex:1;" bindtap="onNext"><text>{{step === steps.length - 1 ? '完成' : '下一步'}}</text></view>
  </view>
</view>
