<!--pages/profile/onboarding/onboarding.wxml - 深空沉浸版-->
<view class="page-onboarding deep-bg">
  <!-- 进度指示器 -->
  <view class="progress-dots flex-center" style="gap:12rpx;">
    <view
      wx:for="{{steps}}" wx:key="index"
      class="dot {{step >= index ? 'dot-active' : ''}}"
    ></view>
  </view>

  <!-- 当前步骤 -->
  <view class="step-content">
    <text class="step-title">{{steps[step].title}}</text>
    <text class="step-subtitle">{{steps[step].subtitle}}</text>

    <view class="options-list">
      <view
        wx:for="{{steps[step].options}}" wx:key="key"
        class="option-card glow-card {{item.selected ? 'option-selected' : ''}}"
        data-index="{{index}}" bindtap="onOptionTap"
      >
        <text class="option-label">{{item.label}}</text>
        <text wx:if="{{item.desc}}" class="option-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view wx:if="{{step > 0}}" class="btn-outline" bindtap="onBack">
      <text>上一步</text>
    </view>
    <view class="cta-holo" style="flex:1;" bindtap="onNext">
      <text class="cta-holo-text">{{step === steps.length - 1 ? '完成设置' : '下一步'}}</text>
    </view>
  </view>
</view>
