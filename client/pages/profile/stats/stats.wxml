<!--pages/profile/stats/stats.wxml - 能力值 v4.0 — 极简-->
<view class="page deep-bg">
  <view wx:if="{{loading}}" class="empty"><text class="text-dim">加载中</text></view>

  <scroll-view wx:else scroll-y class="scroll">
    <view class="header">
      <text class="title">能力值</text>
    </view>

    <!-- 能力条 -->
    <view class="abilities">
      <view wx:for="{{abilities}}" wx:key="key" class="ab-row">
        <view class="ab-left">
          <text class="ab-emoji">{{item.emoji}}</text>
          <text class="ab-name">{{item.name}}</text>
        </view>
        <text class="ab-val" style="color:{{item.color}};">{{item.value}}</text>
        <view class="ab-bar-bg">
          <view class="ab-bar" style="width:{{item.value}}%; background:{{item.color}};"></view>
        </view>
      </view>
    </view>

    <!-- 总体 -->
    <view class="summary" wx:if="{{stats}}">
      <view class="sum-row">
        <view class="sum-item"><text class="sum-val">{{stats.total_exercises || 0}}</text><text class="sum-label">运动</text></view>
        <view class="sum-item"><text class="sum-val">{{stats.total_minutes || 0}}</text><text class="sum-label">分钟</text></view>
        <view class="sum-item"><text class="sum-val">{{stats.streak || 0}}</text><text class="sum-label">连续天</text></view>
      </view>
    </view>

    <view style="height:40rpx;"></view>
  </scroll-view>
</view>
