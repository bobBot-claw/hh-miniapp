/* pages/profile/stats/stats.wxss - 能力值 v4.0 */
.page { min-height: 100vh; }
.scroll { height: 100vh; }

.header { padding: 40rpx 36rpx 20rpx; }
.title { font-size: 40rpx; font-weight: 800; color: var(--text); }

.abilities { padding: 0 36rpx; }
.ab-row {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 0;
}
.ab-left { display: flex; align-items: center; gap: 8rpx; width: 140rpx; }
.ab-emoji { font-size: 24rpx; }
.ab-name { font-size: 24rpx; color: var(--text-dim); }
.ab-val { font-size: 28rpx; font-weight: 800; width: 60rpx; }
.ab-bar-bg { flex: 1; height: 4rpx; background: rgba(255,255,255,0.06); border-radius: 2rpx; overflow: hidden; }
.ab-bar { height: 100%; border-radius: 2rpx; transition: width 0.4s ease; }

.summary { padding: 28rpx 36rpx; margin-top: 20rpx; }
.sum-row { display: flex; justify-content: space-around; }
.sum-item { text-align: center; }
.sum-val { display: block; font-size: 36rpx; font-weight: 800; color: var(--primary); }
.sum-label { display: block; font-size: 22rpx; color: var(--text-dim); }

.empty { display: flex; justify-content: center; padding: 120rpx 0; }
