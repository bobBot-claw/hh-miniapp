<!--pages/profile/index/index.wxml - 我的 v4.0 — 极简-->
<view class="page deep-bg">
  <view wx:if="{{loading}}" class="empty"><text class="text-dim">加载中</text></view>

  <scroll-view wx:else scroll-y class="scroll">
    <!-- 引导 -->
    <view wx:if="{{showOnboarding}}" class="onboard">
      <text class="emoji-xl">🚀</text>
      <text class="title-lg">开始评估</text>
      <text class="sub">获取个性化训练计划</text>
      <view class="cta" bindtap="onStartOnboarding"><text>开始</text></view>
    </view>

    <!-- 用户 -->
    <view class="user" wx:if="{{profile}}">
      <text class="user-emoji">🏃</text>
      <view class="user-info">
        <text class="user-name">{{profile.nickname || '探索者'}}</text>
        <text class="user-stat">Lv.{{stats.level || 1}} · {{stats.total_exercises || 0}}次</text>
      </view>
    </view>

    <!-- 能力值 — 横向点 -->
    <view class="ability-bar" wx:if="{{stats}}" bindtap="onViewStats">
      <view wx:for="{{stats.abilities}}" wx:key="key" class="ab-item">
        <view class="ab-dot" style="background: {{item.color}}; opacity: {{0.3 + item.value / 150}};"></view>
        <text class="ab-val" style="color: {{item.color}};">{{item.value}}</text>
      </view>
      <text class="ab-more">›</text>
    </view>

    <!-- 菜单 -->
    <view class="menu">
      <view class="menu-item" bindtap="onViewWeeklyReport">
        <text>每周报告</text><text class="go">›</text>
      </view>
      <view class="menu-item" bindtap="onStartOnboarding">
        <text>重新评估</text><text class="go">›</text>
      </view>
      <view class="menu-item" bindtap="onSettings">
        <text>设置</text><text class="go">›</text>
      </view>
    </view>

    <view style="height:160rpx;"></view>
  </scroll-view>
</view>
