/* pages/profile/index/index.wxss - 我的页面样式 */
.page-profile {
  min-height: 100vh;
  background: #f5f5f7;
}

.profile-scroll {
  height: 100vh;
}

/* 新用户引导 */
.onboarding-banner {
  margin: 32rpx;
  background: linear-gradient(135deg, #7c6ff7, #9d93fa);
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  color: #fff;
}

.onboarding-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.onboarding-desc {
  font-size: 26rpx;
  opacity: 0.85;
  display: block;
  margin-bottom: 32rpx;
}

.onboarding-content .btn-primary {
  display: inline-block;
  background: #fff;
  color: #7c6ff7;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 用户信息 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 24rpx;
}

.avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 44rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.user-level {
  display: block;
  margin-top: 6rpx;
}

/* 能力值面板 */
.stats-panel {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stats-header {
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.stats-more {
  padding: 4rpx 8rpx;
}

.stat-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.stat-row:last-child {
  margin-bottom: 0;
}

.stat-emoji {
  font-size: 28rpx;
  width: 36rpx;
  text-align: center;
}

.stat-name {
  font-size: 24rpx;
  color: #333;
  width: 100rpx;
}

.stat-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.stat-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.stat-value {
  font-size: 24rpx;
  color: #666;
  width: 50rpx;
  text-align: right;
}

/* 成就 */
.achievements-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.achievement-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
}

.achievement-list {
  display: inline-flex;
  gap: 24rpx;
}

.achievement-badge {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.achievement-emoji {
  font-size: 44rpx;
  margin-bottom: 6rpx;
}

.achievement-name {
  color: #666;
  text-align: center;
  white-space: nowrap;
}

/* 菜单 */
.menu-section {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-emoji {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 通用 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-header {
  margin-bottom: 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.text-secondary { color: #666; }
.text-muted { color: #999; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}
