/* pages/profile/index/index.wxss - 我的页面 - 暗色质感版 */
.page-profile {
  min-height: 100vh;
  background: var(--color-bg);
}

.profile-scroll { height: 100vh; }

/* 新用户引导 */
.onboarding-banner {
  margin: 32rpx 36rpx;
  background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary), var(--color-accent));
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(124, 111, 247, 0.3);
  border: 1rpx solid rgba(255,255,255,0.1);
}
.onboarding-title {
  font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 12rpx;
}
.onboarding-desc {
  font-size: 26rpx; opacity: 0.85; display: block; margin-bottom: 32rpx;
}
.onboarding-content .btn-primary {
  display: inline-block; background: #fff; color: var(--color-primary-dark);
  padding: 18rpx 48rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

/* 用户信息 */
.profile-header {
  display: flex; align-items: center; padding: 40rpx 36rpx; gap: 24rpx;
}
.avatar-wrap {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(124, 111, 247, 0.3);
}
.avatar-emoji { font-size: 44rpx; }
.user-info { flex: 1; }
.user-name { font-size: 36rpx; font-weight: 700; color: var(--color-text); display: block; }
.user-level { display: block; margin-top: 6rpx; }

/* 能力值面板 */
.stats-panel {
  margin: 0 36rpx 24rpx; background: var(--color-bg-card);
  border-radius: 24rpx; padding: 28rpx 32rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}
.stats-header { margin-bottom: 20rpx; }
.stats-title { font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.stats-more { padding: 4rpx 8rpx; }

.stat-row {
  display: flex; align-items: center; margin-bottom: 16rpx; gap: 12rpx;
}
.stat-row:last-child { margin-bottom: 0; }
.stat-emoji { font-size: 28rpx; width: 36rpx; text-align: center; }
.stat-name { font-size: 24rpx; color: var(--color-text-secondary); width: 100rpx; }
.stat-bar-bg {
  flex: 1; height: 14rpx; background: rgba(255,255,255,0.05);
  border-radius: 7rpx; overflow: hidden;
}
.stat-bar-fill {
  height: 100%; border-radius: 7rpx;
  box-shadow: 0 0 8rpx rgba(124, 111, 247, 0.3);
  transition: width 0.3s ease;
}
.stat-value { font-size: 24rpx; color: var(--color-text-secondary); width: 50rpx; text-align: right; }

/* 成就 */
.achievements-section {
  margin: 0 36rpx 24rpx; background: var(--color-bg-card);
  border-radius: 24rpx; padding: 28rpx 32rpx;
  border: 1rpx solid var(--color-border);
}
.achievement-scroll { white-space: nowrap; margin-top: 16rpx; }
.achievement-list { display: inline-flex; gap: 28rpx; }
.achievement-badge {
  display: inline-flex; flex-direction: column; align-items: center; width: 100rpx;
}
.achievement-emoji { font-size: 44rpx; margin-bottom: 6rpx; }
.achievement-name { color: var(--color-text-secondary); text-align: center; white-space: nowrap; }

/* 菜单 */
.menu-section {
  margin: 0 36rpx; background: var(--color-bg-card);
  border-radius: 24rpx; overflow: hidden;
  border: 1rpx solid var(--color-border);
}
.menu-item {
  display: flex; align-items: center; padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.menu-item:last-child { border-bottom: none; }
.menu-emoji { font-size: 32rpx; margin-right: 20rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: var(--color-text); }
.menu-arrow { color: var(--color-text-muted); font-size: 28rpx; }

/* 通用 */
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.section-header { margin-bottom: 4rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }
.loading-container { display: flex; justify-content: center; align-items: center; height: 60vh; }
