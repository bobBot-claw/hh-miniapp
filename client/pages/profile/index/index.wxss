/* pages/profile/index/index.wxss - 我的页面 v3.0 — 深空沉浸 */
.page-profile { min-height: 100vh; }
.profile-scroll { height: 100vh; }

/* 引导卡 */
.onboarding-card {
  position: relative; overflow: hidden;
  margin: 32rpx 36rpx; padding: 48rpx 36rpx;
  text-align: center;
}
.onboard-glow {
  position: absolute; top: -30%; right: -20%;
  width: 300rpx; height: 300rpx;
  background: radial-gradient(circle, rgba(124,111,247,0.1) 0%, transparent 70%);
  pointer-events: none;
}
.onboard-emoji { font-size: 72rpx; display: block; margin-bottom: 16rpx; }
.onboard-title { font-size: 36rpx; font-weight: 700; color: var(--color-text); display: block; margin-bottom: 12rpx; }
.onboard-desc { font-size: 26rpx; color: var(--color-text-secondary); display: block; margin-bottom: 32rpx; }

/* 用户信息 */
.profile-header { display: flex; align-items: center; padding: 40rpx 36rpx; gap: 24rpx; }
.avatar-orb {
  position: relative; width: 96rpx; height: 96rpx;
  display: flex; align-items: center; justify-content: center;
}
.avatar-halo {
  position: absolute; inset: -12rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(124,111,247,0.2) 0%, transparent 70%);
  animation: glow-pulse 3s ease-in-out infinite;
}
.avatar-emoji { font-size: 44rpx; z-index: 1; }
.user-info { flex: 1; }
.user-name { font-size: 36rpx; font-weight: 700; color: var(--color-text); display: block; }
.user-level { display: block; margin-top: 6rpx; color: var(--color-text-secondary); font-size: 24rpx; }

/* 能力值面板 — 迷你能量球 */
.stats-panel { margin: 0 36rpx 24rpx; padding: 28rpx 32rpx; }
.stats-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.stats-title { font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.stats-link { font-size: 22rpx; color: var(--color-text-secondary); }

.mini-orbs { display: flex; justify-content: space-around; }
.mini-orb { display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.mini-orb-sphere {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  animation: gentle-float 4s ease-in-out infinite;
}
.mini-orb-val { font-size: 24rpx; font-weight: 800; }
.mini-orb-name { font-size: 22rpx; }

/* 成就 */
.ach-section { margin: 0 36rpx 24rpx; padding: 28rpx 32rpx; }
.ach-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.ach-title { font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.ach-count { font-size: 22rpx; color: var(--color-text-secondary); }
.ach-scroll { white-space: nowrap; }
.ach-list { display: inline-flex; gap: 24rpx; }
.ach-badge {
  display: inline-flex; flex-direction: column; align-items: center;
  width: 96rpx; position: relative;
}
.ach-badge-glow {
  position: absolute; top: -10rpx; left: 50%; transform: translateX(-50%);
  width: 60rpx; height: 60rpx;
  background: radial-gradient(circle, rgba(255,215,0,0.1) 0%, transparent 70%);
  pointer-events: none;
}
.ach-badge-emoji { font-size: 40rpx; margin-bottom: 6rpx; z-index: 1; }
.ach-badge-name { font-size: 20rpx; color: var(--color-text-secondary); text-align: center; white-space: nowrap; }

/* 菜单 */
.menu-section { margin: 0 36rpx; padding: 8rpx 0; overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 24rpx 32rpx; }
.menu-icon { font-size: 32rpx; margin-right: 16rpx; width: 44rpx; text-align: center; }
.menu-label { flex: 1; font-size: 28rpx; color: var(--color-text); }
.menu-arrow { color: var(--color-text-muted); font-size: 28rpx; }
.menu-divider { height: 1rpx; background: var(--color-border); margin: 0 32rpx; }

.text-secondary { color: var(--color-text-secondary); }
.loading-container { display: flex; justify-content: center; align-items: center; height: 60vh; }
