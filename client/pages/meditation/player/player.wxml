<!--pages/meditation/player/player.wxml - 冥想播放器 v4.0 — 极简·呼吸-->
<view class="page">
  <!-- 播放 -->
  <view wx:if="{{!completed}}" class="play-view">
    <view class="back" bindtap="wx.navigateBack"><text>←</text></view>

    <view class="info">
      <text class="emoji">{{meditation.emoji || '🧘'}}</text>
      <text class="title">{{meditation.title}}</text>
    </view>

    <!-- 呼吸环 -->
    <view class="ring-wrap">
      <view class="ring {{isPlaying ? 'breathing' : ''}}">
        <view class="ring-bg"></view>
        <view class="ring-progress" style="background: conic-gradient(var(--primary) {{progress}}%, transparent {{progress}}%);"></view>
        <view class="ring-inner">
          <text class="time-current">{{formatTime(currentTime)}}</text>
          <text class="time-total">{{formatTime(totalTime)}}</text>
        </view>
      </view>
    </view>

    <view class="play-btn {{isPlaying ? 'playing' : ''}}" bindtap="onTogglePlay">
      <text>{{isPlaying ? '⏸' : '▶'}}</text>
    </view>
  </view>

  <!-- 完成 -->
  <view wx:if="{{completed && feedback}}" class="done-view">
    <text class="done-icon">🎉</text>
    <text class="done-text">{{feedback.encouragement}}</text>
    <view class="cta" bindtap="onCloseFeedback"><text>好的</text></view>
  </view>
</view>
