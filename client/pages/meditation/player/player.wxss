/* pages/meditation/player/player.wxss - 冥想播放器样式 */
.page-meditation-player {
  min-height: 100vh;
  background: #1a1a2e;
}

.player-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
  position: relative;
}

.back-btn {
  position: absolute;
  top: 80rpx;
  left: 32rpx;
  padding: 16rpx;
}

.back-icon {
  color: #fff;
  font-size: 40rpx;
}

.meditation-info {
  text-align: center;
  margin-top: 140rpx;
}

.meditation-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.meditation-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.meditation-subtitle {
  font-size: 26rpx;
  display: block;
}

/* 进度环 */
.progress-ring-container {
  margin: 80rpx 0;
}

.progress-ring {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  position: relative;
}

.progress-ring-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 8rpx solid rgba(255,255,255,0.1);
}

.progress-ring-fill {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}

.progress-ring-inner {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.progress-time {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.progress-total {
  font-size: 24rpx;
  margin-top: 4rpx;
}

/* 播放控制 */
.controls {
  margin-bottom: 60rpx;
}

.play-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.play-icon {
  font-size: 48rpx;
  color: #fff;
  margin-left: 6rpx;
}

.hint-text {
  font-size: 24rpx;
  margin-top: 20rpx;
}

/* 完成反馈 */
.feedback-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: linear-gradient(180deg, #2d1b69, #1a1a2e);
}

.feedback-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  text-align: center;
  width: 100%;
}

.feedback-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.feedback-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 16rpx;
}

.feedback-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.stat-gains {
  margin-bottom: 40rpx;
}

.stat-gain-item {
  margin-bottom: 12rpx;
}

.stat-gain-text {
  font-size: 28rpx;
  color: #7c6ff7;
  font-weight: 600;
}

.btn-primary {
  display: inline-block;
  background: linear-gradient(135deg, #7c6ff7, #9d93fa);
  color: #fff;
  padding: 20rpx 64rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 通用 */
.text-white-70 { color: rgba(255,255,255,0.7); }
.text-white-50 { color: rgba(255,255,255,0.5); }
