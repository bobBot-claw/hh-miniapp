/* pages/meditation/player/player.wxss - 冥想播放器 v4.0 */
.page { min-height: 100vh; background: var(--bg); }

.play-view {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center;
  padding: 0 36rpx; position: relative;
}

.back { position: absolute; top: 80rpx; left: 36rpx; padding: 16rpx; z-index: 10; }
.back text { color: var(--text-dim); font-size: 36rpx; }

.info { text-align: center; margin-top: 160rpx; }
.emoji { font-size: 72rpx; display: block; margin-bottom: 20rpx; animation: float 5s ease-in-out infinite; }
.title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }

/* 呼吸环 */
.ring-wrap { margin: 80rpx 0; }
.ring {
  width: 280rpx; height: 280rpx; border-radius: 50%; position: relative;
}
.ring.breathing { animation: breathe-ring 6s ease-in-out infinite; }
@keyframes breathe-ring { 0%,100%{transform:scale(0.92)}50%{transform:scale(1.06)} }

.ring-bg {
  position: absolute; inset: 0; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.06);
}
.ring-progress {
  position: absolute; inset: 0; border-radius: 50%;
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}
.ring-inner {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.time-current { font-size: 40rpx; font-weight: 700; color: #fff; }
.time-total { font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; }

.play-btn {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: var(--surface); display: flex; align-items: center; justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.1);
  font-size: 40rpx; color: #fff;
}
.play-btn.playing { border-color: var(--primary); }

/* 完成 */
.done-view {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 48rpx;
}
.done-icon { font-size: 72rpx; margin-bottom: 24rpx; }
.done-text { font-size: 32rpx; font-weight: 600; margin-bottom: 48rpx; text-align: center; color: var(--text); }
