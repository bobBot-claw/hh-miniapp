/* pages/meditation/list/list.wxss - 静养模块样式 v2.0 */

.page-meditation-list {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 页面头部 */
.page-header {
  padding: 48rpx 32rpx 12rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: var(--font-size-base);
  display: block;
}

/* 标签筛选 */
.tag-scroll {
  white-space: nowrap;
  padding: 16rpx 32rpx 20rpx;
}

.tag-list {
  display: inline-flex;
  gap: 16rpx;
}

.tag-item {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-xl);
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  font-weight: 500;
}

.tag-item.tag-active {
  background: var(--color-primary);
  color: white;
}

/* 冥想列表 */
.meditation-scroll {
  height: calc(100vh - 240rpx);
  padding: 0 32rpx;
}

.meditation-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.meditation-card {
  display: flex;
  flex-direction: row;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.meditation-cover {
  width: 180rpx;
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  position: relative;
}

.meditation-cover-emoji {
  font-size: 52rpx;
  margin-bottom: 8rpx;
}

.meditation-duration-badge {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  background: rgba(0,0,0,0.2);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.meditation-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}

.meditation-title {
  font-size: var(--font-size-base);
  font-weight: 600;
}

.meditation-subtitle {
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

.meditation-meta {
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

/* 通用 */
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-xs { font-size: var(--font-size-xs); }
.text-sm { font-size: var(--font-size-sm); }

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 40vh;
}
