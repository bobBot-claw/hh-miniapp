/* pages/meditation/list/list.wxss - 静养模块 v3.0 — 深空沉浸 */
.page-meditation-list { min-height: 100vh; }

.page-header {
  position: relative; padding: 48rpx 36rpx 12rpx; overflow: hidden;
}
.header-glow {
  position: absolute; top: -20%; left: 30%;
  width: 300rpx; height: 300rpx;
  background: radial-gradient(circle, rgba(9,132,227,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.page-title {
  font-size: 44rpx; font-weight: 800; display: block; margin-bottom: 8rpx;
  color: var(--color-text);
  text-shadow: 0 0 30rpx rgba(124,111,247,0.3);
}
.page-subtitle {
  font-size: var(--font-size-base); display: block;
  color: var(--color-text-secondary);
}

.tag-scroll { white-space: nowrap; padding: 16rpx 36rpx 20rpx; }
.tag-list { display: inline-flex; gap: 12rpx; }

.meditation-scroll { height: calc(100vh - 240rpx); padding: 0 36rpx; }
.meditation-list { display: flex; flex-direction: column; gap: 16rpx; }

/* 冥想卡片 — 水平布局 */
.med-card {
  display: flex; flex-direction: row; overflow: hidden;
}
.med-card-cover {
  width: 140rpx; min-height: 140rpx;
  display: flex; justify-content: center; align-items: center;
  flex-shrink: 0; position: relative;
}
.med-card-badge {
  font-size: 20rpx; color: rgba(255,255,255,0.8);
  background: rgba(0,0,0,0.25); padding: 2rpx 12rpx; border-radius: 12rpx;
}
.med-card-ripple {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.08) 0%, transparent 70%);
  animation: glow-pulse 4s ease-in-out infinite;
  pointer-events: none;
}
.med-card-info {
  flex: 1; padding: 20rpx 24rpx;
  display: flex; flex-direction: column; justify-content: center;
}
.med-card-title { font-size: var(--font-size-base); font-weight: 700; color: var(--color-text); }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 60rpx; }
.empty-state .empty-text { font-size: var(--font-size-base); color: var(--color-text-muted); }

.text-secondary { color: var(--color-text-secondary); }
.loading-container { display: flex; justify-content: center; align-items: center; height: 40vh; }
