<!--pages/meditation/list/list.wxml - 静养模块 v2.1-->
<view class="page-meditation-list">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">静养</text>
    <text class="page-subtitle text-secondary">让身心安静下来</text>
  </view>

  <!-- 标签筛选 -->
  <scroll-view scroll-x class="tag-scroll">
    <view class="tag-list">
      <view
        wx:for="{{tags}}"
        wx:key="key"
        class="tag-item {{activeTag === item.key ? 'tag-active' : ''}}"
        data-tag="{{item.key}}"
        bindtap="onTagTap"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 冥想列表 -->
  <scroll-view scroll-y class="meditation-scroll">
    <view wx:if="{{loading}}" class="loading-container">
      <text class="text-secondary">加载中...</text>
    </view>

    <block wx:else>
      <view wx:if="{{filteredList.length === 0}}" class="empty-state">
        <text class="empty-text">暂无内容</text>
      </view>

      <view wx:else class="meditation-grid">
        <view
          wx:for="{{filteredList}}"
          wx:key="id"
          class="meditation-card"
          data-id="{{item.id}}"
          bindtap="onMeditationTap"
        >
          <view class="meditation-cover" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
            <text class="meditation-duration-badge">{{item.duration_text || '3min'}}</text>
          </view>
          <view class="meditation-info">
            <text class="meditation-title">{{item.title}}</text>
            <text class="meditation-subtitle text-secondary">{{item.subtitle}}</text>
            <view class="meditation-meta">
              <text class="text-xs text-muted">{{item.category_label || ''}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <view style="height: 160rpx;"></view>
  </scroll-view>
</view>
