<!--pages/meditation/list/list.wxml - 静养模块 v3.0 — 深空沉浸-->
<view class="page-meditation-list deep-bg">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-glow"></view>
    <text class="page-title">静养</text>
    <text class="page-subtitle">让身心安静下来</text>
  </view>

  <!-- 标签筛选 — 全息标签 -->
  <scroll-view scroll-x class="tag-scroll">
    <view class="tag-list">
      <view
        wx:for="{{tags}}" wx:key="key"
        class="holo-tag {{activeTag === item.key ? 'holo-tag-active' : ''}}"
        data-tag="{{item.key}}" bindtap="onTagTap"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 冥想列表 -->
  <scroll-view scroll-y class="meditation-scroll">
    <view wx:if="{{loading}}" class="loading-container">
      <text class="text-secondary">加载中...</text>
    </view>

    <block wx:else>
      <view wx:if="{{filteredList.length === 0}}" class="empty-state">
        <text class="empty-text">暂无内容</text>
      </view>

      <view wx:else class="meditation-list">
        <view
          wx:for="{{filteredList}}" wx:key="id"
          class="med-card glow-card"
          data-id="{{item.id}}" bindtap="onMeditationTap"
        >
          <view class="med-card-cover" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
            <text class="med-card-badge">{{item.duration_text || '3min'}}</text>
            <view class="med-card-ripple"></view>
          </view>
          <view class="med-card-info">
            <text class="med-card-title">{{item.title}}</text>
          </view>
        </view>
      </view>
    </block>

    <view style="height: 160rpx;"></view>
  </scroll-view>
</view>
