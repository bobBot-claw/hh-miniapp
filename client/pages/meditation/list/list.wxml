<!--pages/meditation/list/list.wxml - 静养 v4.0 — 极简·安静-->
<view class="page deep-bg">
  <view class="header">
    <text class="page-title">静养</text>
  </view>

  <!-- 标签 -->
  <scroll-view scroll-x class="tags">
    <view class="tag-row">
      <text wx:for="{{tags}}" wx:key="key" class="tag {{activeTag === item.key ? 'tag-on' : ''}}" data-tag="{{item.key}}" bindtap="onTagTap">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 列表 -->
  <view wx:if="{{loading}}" class="empty"><text class="text-dim">加载中</text></view>
  <scroll-view wx:else scroll-y class="list-scroll">
    <view wx:if="{{filteredList.length === 0}}" class="empty"><text class="text-dim">暂无内容</text></view>
    <view wx:else class="list">
      <view wx:for="{{filteredList}}" wx:key="id" class="item" data-id="{{item.id}}" bindtap="onMeditationTap">
        <view class="item-cover" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}"></view>
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <text class="item-dur">{{item.duration_text || '3min'}}</text>
        </view>
        <text class="item-go">›</text>
      </view>
    </view>
    <view style="height:160rpx;"></view>
  </scroll-view>
</view>
