/* pages/mood/mood.wxss — 情绪天气：5天气+1词 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  padding: 0 48rpx;
}

/* 顶部 */
.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 100rpx 0 48rpx;
}
.back-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex; align-items: center; justify-content: center;
}
.back-arrow {
  width: 16rpx; height: 16rpx;
  border-left: 3rpx solid rgba(42, 40, 32, 0.6);
  border-bottom: 3rpx solid rgba(42, 40, 32, 0.6);
  transform: rotate(45deg);
  margin-left: 6rpx;
}
.header-title {
  font-size: 32rpx; font-weight: 500;
  color: var(--neutral-900);
  letter-spacing: 4rpx;
}

/* 天气选择 */
.weather-row {
  display: flex; justify-content: space-between;
  padding: 32rpx 0 64rpx;
}
.weather-item {
  display: flex; flex-direction: column;
  align-items: center; gap: 12rpx;
  opacity: 0.35;
  transition: opacity 0.3s;
}
.weather-on {
  opacity: 1;
}

/* 天气线条图标 — 用 CSS 画 */
.weather-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  position: relative;
  display: flex; align-items: center; justify-content: center;
}

/* 晴：圆+放射线 */
.icon-weather-sunny {
  background: transparent;
  border: 4rpx solid var(--gold-500);
}
.icon-weather-sunny::before {
  content: '';
  width: 24rpx; height: 24rpx;
  border-radius: 50%;
  background: var(--gold-500);
}

/* 多云：圆+偏移小圆 */
.icon-weather-cloudy {
  background: transparent;
}
.icon-weather-cloudy::before {
  content: '';
  width: 50rpx; height: 30rpx;
  border-radius: 30rpx;
  background: var(--neutral-300);
  margin-top: 10rpx;
}
.icon-weather-cloudy::after {
  content: '';
  position: absolute; top: 12rpx; right: 8rpx;
  width: 30rpx; height: 18rpx;
  border-radius: 18rpx;
  background: var(--neutral-200);
}

/* 小雨：圆+竖线 */
.icon-weather-rainy {
  background: transparent;
  border: 4rpx solid #7B9EC6;
}
.icon-weather-rainy::before {
  content: '';
  position: absolute; bottom: -16rpx; left: 50%;
  width: 3rpx; height: 16rpx;
  background: #7B9EC6;
  transform: translateX(-50%);
}

/* 雷阵雨：圆+闪电 */
.icon-weather-stormy {
  background: transparent;
  border: 4rpx solid #5B5B7B;
}
.icon-weather-stormy::before {
  content: '';
  position: absolute; bottom: -8rpx; left: 50%;
  width: 16rpx; height: 20rpx;
  background: #5B5B7B;
  clip-path: polygon(60% 0%, 100% 40%, 60% 40%, 80% 100%, 0% 50%, 40% 50%, 0% 0%);
  transform: translateX(-50%);
}

/* 雨后：圆+弧线 */
.icon-weather-after {
  background: transparent;
  border: 4rpx solid var(--brand-600);
  position: relative;
}
.icon-weather-after::before {
  content: '';
  position: absolute;
  top: -14rpx; left: 50%;
  width: 40rpx; height: 40rpx;
  border: 4rpx solid var(--gold-400);
  border-radius: 50%;
  border-bottom-color: transparent;
  border-left-color: transparent;
  transform: translateX(-50%) rotate(-45deg);
}

.weather-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 3rpx;
}
.weather-on .weather-label {
  color: var(--neutral-900);
  font-weight: 500;
}

/* 一句话 */
.word-section {
  padding: 0 32rpx;
  margin-bottom: 64rpx;
}
.word-input {
  width: 100%;
  text-align: center;
  font-size: 40rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 8rpx;
  border: none;
  background: transparent;
  border-bottom: 2rpx solid var(--neutral-200);
  padding: 24rpx 0;
}

/* 保存按钮 */
.cta-disabled {
  opacity: 0.4;
}

/* 提示 */
.hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
  margin-top: 32rpx;
}
