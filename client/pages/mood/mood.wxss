/* pages/mood/mood.wxss — 微光契约：与 demo 屏2 完全一致 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  background: rgba(20, 30, 60, 0.32);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

/* 暖色光晕 */
.halo {
  position: fixed; pointer-events: none; z-index: 0;
  border-radius: 50%; filter: blur(140px); opacity: 0.3;
}
.halo-1 { width: 680px; height: 680px; background: var(--halo-cream); top: -200px; right: -200px; }
.halo-2 { width: 480px; height: 480px; background: var(--halo-gold); bottom: -200px; left: -200px; opacity: 0.2; }

/* 弹层容器 */
.modal-bg {
  position: relative; z-index: 1;
  width: 100%; min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx;
}

/* 弹层卡片 — demo: .modal-card */
.modal-card {
  background: var(--surface);
  border-radius: 64rpx;
  padding: 72rpx 56rpx;
  width: 100%;
  max-width: 760rpx;
  position: relative;
  animation: rise 0.4s ease;
}
@keyframes rise {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 关闭按钮 */
.mc-close {
  position: absolute; top: 36rpx; right: 40rpx;
  background: none; border: none;
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
}
.close-x {
  font-size: 36rpx; color: var(--ink-dim);
}

/* 内容 — demo 原版 */
.mc-t {
  font-size: 22rpx; letter-spacing: 0.32em; color: var(--gold);
  margin-bottom: 28rpx; display: block;
}
.mc-h {
  font-size: 44rpx; font-weight: 300; letter-spacing: 0.04em;
  margin-bottom: 36rpx; display: block; color: var(--ink);
  white-space: pre-line;
}
.mc-b {
  font-size: 26rpx; color: var(--ink-mute); line-height: 1.85;
  margin-bottom: 44rpx; display: block; letter-spacing: 0.03em;
  white-space: pre-line;
}

/* 输入框 — demo: .modal-card input */
.reward-input {
  width: 100%;
  padding: 28rpx 32rpx;
  background: var(--warm);
  border: none;
  border-radius: 28rpx;
  font-size: 28rpx; color: var(--ink);
  font-family: inherit;
  letter-spacing: 0.04em;
  margin-bottom: 28rpx;
  outline: none;
}

/* pill 标签行 */
.pill-label {
  font-size: 22rpx; letter-spacing: 0.18em; color: var(--ink-dim);
  display: block; margin-bottom: 12rpx;
}
.pill-row {
  display: flex; flex-wrap: wrap; gap: 0;
  margin-bottom: 44rpx;
}
.pill {
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 1rpx solid var(--line);
  border-radius: 60rpx;
  font-size: 22rpx; letter-spacing: 0.2em;
  color: var(--ink-mute);
  margin-right: 12rpx;
  margin-bottom: 20rpx;
}
.pill.sel {
  background: var(--gold-soft);
  color: var(--gold);
  border-color: var(--gold-soft);
}
.pill text { color: inherit; letter-spacing: 0.2em; }

/* 双按钮行 — demo: .cta-row */
.cta-row {
  display: flex; gap: 24rpx;
}
.cta-row .cta,
.cta-row .cta-alt {
  flex: 1;
  text-align: center;
  justify-content: center;
}

/* 底部提示 */
.mc-foot {
  font-size: 24rpx; color: var(--ink-dim); letter-spacing: 0.06em;
  text-align: center; margin-top: 36rpx; display: block;
}
