/* pages/discover/index/index.wxss - 发现页样式 */
.page-discover {
  min-height: 100vh;
  background: #f5f5f7;
}

.discover-scroll {
  height: 100vh;
}

.section {
  padding: 32rpx 32rpx 0;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.section-more {
  padding: 8rpx 16rpx;
}

/* 知识卡片 */
.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.knowledge-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.knowledge-tag-wrap {
  margin-bottom: 12rpx;
}

.knowledge-category-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #7c6ff7;
  background: rgba(124,111,247,0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.knowledge-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.knowledge-content {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.knowledge-read {
  color: #999;
}

/* 冥想横滑 */
.meditation-scroll {
  white-space: nowrap;
}

.meditation-list {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 32rpx;
}

.meditation-card {
  display: inline-flex;
  flex-direction: column;
  width: 280rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.meditation-cover {
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.meditation-emoji {
  font-size: 64rpx;
}

.meditation-info {
  padding: 20rpx;
}

.meditation-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meditation-sub {
  display: block;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 通用 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-secondary { color: #666; }
.text-muted { color: #999; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}
