/* pages/discover/index/index.wxss - 发现 v4.0 */
.page { min-height: 100vh; }
.scroll { height: 100vh; }
.section { padding: 32rpx 36rpx 0; }
.sec-title { font-size: 32rpx; font-weight: 700; color: var(--text); display: block; margin-bottom: 16rpx; }
.list { }
.item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 18rpx 0; border-bottom: 1rpx solid var(--line);
}
.item-title { flex: 1; font-size: 28rpx; color: var(--text); font-weight: 500; }
.item-dur { font-size: 22rpx; color: var(--text-dim); }
.item-go { font-size: 26rpx; color: var(--text-dim); }
