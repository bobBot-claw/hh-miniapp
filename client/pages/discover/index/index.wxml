<!--pages/discover/index/index.wxml - 发现 v4.0 — 极简-->
<view class="page deep-bg">
  <scroll-view scroll-y class="scroll">
    <view class="section">
      <text class="sec-title">💡 知识</text>
      <view class="list">
        <view wx:for="{{knowledge}}" wx:key="id" class="item" data-id="{{item.id}}" bindtap="onKnowledgeTap">
          <text class="item-title">{{item.title}}</text>
          <text class="item-go">›</text>
        </view>
      </view>
    </view>

    <view class="section">
      <text class="sec-title">🧘 冥想</text>
      <view class="list">
        <view wx:for="{{meditations}}" wx:key="id" class="item" data-id="{{item.id}}" bindtap="onMeditationTap">
          <text class="item-title">{{item.title}}</text>
          <text class="item-dur">{{item.duration_text}}</text>
          <text class="item-go">›</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
