/* pages/done/done.wxss — 完成后：揭示彩蛋 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
}

.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: space-between;
  padding: 0 64rpx;
}

/* 顶部 */
.done-top {
  padding-top: 200rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.done-msg {
  font-size: 44rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 6rpx;
  display: block;
  margin-bottom: 24rpx;
}
.done-feeling {
  font-size: 28rpx;
  color: var(--brand-600, #147D45);
  line-height: 1.6;
  max-width: 480rpx;
  margin-bottom: 16rpx;
  animation: breathe 3s ease-in-out infinite;
}
.done-benefit {
  font-size: 24rpx;
  color: rgba(42, 40, 32, 0.45);
  line-height: 1.6;
  max-width: 480rpx;
  border-left: 3rpx solid var(--gold-500, #C9A66B);
  padding-left: 20rpx;
  text-align: left;
}

/* 底部 */
.done-bottom {
  padding-bottom: 180rpx;
  display: flex; flex-direction: column;
  align-items: center;
  text-align: center;
}
.egg-credit {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}
