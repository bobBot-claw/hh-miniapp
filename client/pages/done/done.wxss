/* pages/done/done.wxss — 完成后：揭示彩蛋 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
}

.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: space-between;
  padding: 0 64rpx;
}

/* 顶部 */
.done-top {
  padding-top: 200rpx;
  text-align: center;
}
.done-msg {
  font-size: 44rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 6rpx;
  display: block;
  margin-bottom: 12rpx;
}
.done-sub {
  font-size: 24rpx;
  color: rgba(42, 40, 32, 0.5);
  letter-spacing: 6rpx;
  display: block;
}

/* 底部 */
.done-bottom {
  padding-bottom: 180rpx;
  display: flex; flex-direction: column;
  align-items: center;
  text-align: center;
}
.egg-credit {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}
