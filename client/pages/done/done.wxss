/* pages/done/done.wxss — 完成：认知卡片确认页 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  background: var(--bg);
}
.halo {
  position: fixed; pointer-events: none; z-index: 0;
  border-radius: 50%; filter: blur(140px); opacity: 0.5;
}
.halo-1 { width: 680px; height: 680px; background: var(--halo-cream); top: -200px; right: -200px; }
.halo-2 { width: 480px; height: 480px; background: var(--halo-gold); bottom: -200px; left: -200px; opacity: 0.3; }

.center {
  position: relative; z-index: 1;
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx;
}

/* 认知卡片 — 与 action 页一致 */
.cognize {
  background: linear-gradient(150deg, var(--warm) 0%, var(--warm-2) 100%);
  border-radius: 64rpx;
  padding: 72rpx 56rpx;
  width: 100%;
  max-width: 760rpx;
  animation: rise 0.4s ease;
}
@keyframes rise {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.ci-tag { font-size: 22rpx; letter-spacing: 0.32em; color: var(--gold); margin-bottom: 28rpx; display: block; }
.ci-h { font-size: 44rpx; font-weight: 300; letter-spacing: 0.04em; margin-bottom: 36rpx; display: block; color: var(--ink); }
.ci-t { font-size: 28rpx; color: var(--ink); line-height: 1.95; margin-bottom: 36rpx; display: block; letter-spacing: 0.03em; }
.ci-em { font-size: 28rpx; color: var(--gold); letter-spacing: 0.04em; line-height: 1.85; padding: 28rpx 0; border-top: 1rpx solid var(--warm-2); margin-bottom: 36rpx; display: block; }
.ci-foot { font-size: 22rpx; letter-spacing: 0.18em; color: var(--ink-dim); margin-bottom: 36rpx; display: block; text-align: center; }
