/* pages/done/done.wxss — 完成后：v0.7 demo 风格 — 极简揭示 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
  background: #FCFCFD;
}

/* 背景插画 — 全屏 */
.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

/* 内容层 */
.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: space-between;
  padding: 0 64rpx;
}

/* 顶部 — 极简 */
.done-top {
  padding-top: 160rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.done-msg {
  font-size: 40rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 0.2em;
  display: block;
  margin-bottom: 16rpx;
}
.done-sub {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.5);
  letter-spacing: 0.3em;
}

/* 底部 */
.done-bottom {
  padding-bottom: 160rpx;
  display: flex; flex-direction: column;
  align-items: center;
  text-align: center;
}
.egg-credit {
  font-size: 20rpx;
  color: rgba(42, 40, 32, 0.4);
  letter-spacing: 0.2em;
  margin-bottom: 32rpx;
}

/* 共练分享 */
.done-together {
  margin-top: 24rpx;
}
.together-share-btn {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 36rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
  color: var(--neutral-900);
  letter-spacing: 0.2em;
  line-height: 1.5;
}
.together-share-btn::after { border: none; }

/* 文字按钮 — demo 风格 */
.btn-text {
  background: transparent;
  border: none;
  padding: 16rpx 32rpx;
  margin-top: 4rpx;
}
.btn-text text {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.7);
  letter-spacing: 0.3em;
}
