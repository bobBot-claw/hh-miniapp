/* pages/done/done.wxss — 完成后：揭示彩蛋 v0.8 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
}

.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

/* 轻叠加层 */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, rgba(252,252,253,0.6) 0%, rgba(252,252,253,0.3) 40%, rgba(252,252,253,0.7) 100%);
  z-index: 1;
  pointer-events: none;
}

.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: space-between;
  padding: 0 64rpx;
}

/* 顶部 */
.done-top {
  padding-top: 180rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.done-msg {
  font-size: 48rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 48rpx;
}

/* 体感 */
.done-feeling-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}
.feeling-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}
.done-feeling {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--brand-600, #147D45);
  line-height: 1.7;
  max-width: 520rpx;
  animation: breathe 3s ease-in-out infinite;
}

/* 收益 */
.done-benefit-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 520rpx;
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(201, 166, 107, 0.15);
}
.benefit-label {
  font-size: 22rpx;
  color: var(--gold-500, #C9A66B);
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}
.done-benefit {
  font-size: 26rpx;
  color: rgba(42, 40, 32, 0.6);
  line-height: 1.7;
  text-align: left;
}

/* 底部 */
.done-bottom {
  padding-bottom: 180rpx;
  display: flex; flex-direction: column;
  align-items: center;
  text-align: center;
}
.egg-credit {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}
