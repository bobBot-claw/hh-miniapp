<!--pages/done/done.wxml — 完成后 v0.8-->

<view class="page warm-bg">
  <image class="illust-bg {{revealed?'illust-lit':'illust-dim'}}" src="{{eggClearUrl}}" mode="aspectFill" />
  <view class="overlay"></view>

  <view class="content">
    <view class="done-top">
      <text class="done-msg">{{together?'一起做到了':'做到了'}}</text>

      <view wx:if="{{together}}" class="done-together">
        <button class="together-share-btn" open-type="share"><text>告诉好友</text></button>
      </view>

      <view wx:if="{{feeling}}" class="done-feeling-wrap">
        <text class="feeling-label">身体在说</text>
        <text class="done-feeling">{{feeling}}</text>
      </view>

      <view wx:if="{{benefit}}" class="done-benefit-wrap">
        <text class="benefit-label">会变好</text>
        <text class="done-benefit">{{benefit}}</text>
      </view>
    </view>

    <view class="done-bottom">
      <text class="egg-credit">{{worldName}} · 第{{eggIndex}}张</text>
      <view class="cta" bindtap="goWorld"><text>收入世界</text></view>
      <view class="btn-text" bindtap="goHome"><text>回主页</text></view>
    </view>
  </view>
</view>
