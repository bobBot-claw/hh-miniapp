<!--pages/done/done.wxml — 完成后 v0.7 demo 风格-->

<view class="page">
  <image class="illust-bg {{revealed?'illust-lit':'illust-dim'}}" src="{{eggClearUrl}}" mode="aspectFill" />

  <view class="content">
    <!-- 顶部文案 -->
    <view class="done-top">
      <text class="done-msg">{{together?'一起做到了':'做到了'}}</text>
      <text class="done-sub">明 天 继 续</text>
    </view>

    <!-- 底部操作 -->
    <view class="done-bottom">
      <text class="egg-credit">{{worldName}} · 第{{eggIndex}}张</text>
      <view class="cta" bindtap="goWorld"><text>收入世界</text></view>
      <view class="btn-text" bindtap="goHome"><text>回到主页</text></view>

      <view wx:if="{{together}}" class="done-together">
        <button class="together-share-btn" open-type="share"><text>告诉好友</text></button>
      </view>
    </view>
  </view>
</view>
