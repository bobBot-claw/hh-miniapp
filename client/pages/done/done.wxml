<!--pages/done/done.wxml — 完成后：揭示彩蛋 v0.8-->

<view class="page warm-bg">

  <!-- 背景插画 — 暗态开始，1.5s后变亮 -->
  <image
    class="illust-bg {{revealed ? 'illust-lit' : 'illust-dim'}}"
    src="{{eggClearUrl}}"
    mode="aspectFill"
  />

  <!-- 暖白叠加层（轻微，让文字可读） -->
  <view class="overlay"></view>

  <!-- 内容 -->
  <view class="content">

    <!-- 顶部消息 -->
    <view class="done-top">
      <text class="done-msg">做到了</text>

      <!-- 当下体感 -->
      <view wx:if="{{feeling}}" class="done-feeling-wrap">
        <text class="feeling-label">你的身体在说</text>
        <text class="done-feeling">{{feeling}}</text>
      </view>

      <!-- 长期收益 -->
      <view wx:if="{{benefit}}" class="done-benefit-wrap">
        <text class="benefit-label">为什么会变好</text>
        <text class="done-benefit">{{benefit}}</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="done-bottom">
      <text class="egg-credit">{{worldName}} · 第 {{eggIndex}} 张</text>
      <view class="cta" bindtap="goWorld">
        <text>收入世界</text>
      </view>
      <view class="btn-text" bindtap="goHome">
        <text>回到主页</text>
      </view>
    </view>

  </view>
</view>
