/* pages/together/together.wxss — 全周计划：与 demo 屏5 完全一致 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  background: var(--bg);
}

/* 暖色光晕 */
.halo {
  position: fixed; pointer-events: none; z-index: 0;
  border-radius: 50%; filter: blur(140px); opacity: 0.5;
}
.halo-1 { width: 680px; height: 680px; background: var(--halo-cream); top: -200px; right: -200px; }
.halo-2 { width: 480px; height: 480px; background: var(--halo-gold); bottom: -200px; left: -200px; opacity: 0.3; }

.scroll {
  position: relative; z-index: 1;
  height: 100vh;
  padding: 72rpx 44rpx 0;
}

/* 顶部行 */
.top-row {
  display: flex; align-items: center; gap: 24rpx;
  margin-bottom: 44rpx;
}
.back-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--surface);
  border: 1rpx solid var(--line);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.back-arrow {
  width: 16rpx; height: 16rpx;
  border-left: 3rpx solid var(--ink-mute);
  border-bottom: 3rpx solid var(--ink-mute);
  transform: rotate(45deg);
  margin-left: 6rpx;
}
.brand-l { font-size: 22rpx; letter-spacing: 0.3em; color: var(--ink-mute); }
.day-l { font-size: 22rpx; letter-spacing: 0.2em; color: var(--ink-dim); }

/* 7天列表 — demo: 每行一个 day-row */
.day-list {
  display: flex; flex-direction: column; gap: 28rpx;
}

.day-row {
  display: flex; gap: 28rpx; align-items: center;
  padding: 28rpx 36rpx;
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
}

/* 今天高亮 — demo: 暖色底+金边 */
.day-row-today {
  background: var(--warm);
  border: 3rpx solid var(--gold);
}

.day-idx {
  width: 64rpx;
  font-size: 28rpx; color: var(--ink);
  letter-spacing: 0.1em;
  flex-shrink: 0;
}
.day-row-today .day-idx {
  color: var(--gold);
}

.day-content {
  flex: 1;
}
.day-title {
  font-size: 28rpx; color: var(--ink);
  display: block;
}
.day-sub {
  font-size: 22rpx; color: var(--ink-mute);
  letter-spacing: 0.16em; margin-top: 6rpx;
  display: block;
}
