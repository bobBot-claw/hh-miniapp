<!--pages/together/together.wxml — 全周计划：与 demo 屏5 完全一致-->

<view class="page">

  <!-- 暖色光晕 -->
  <view class="halo halo-1"></view>
  <view class="halo halo-2"></view>

  <scroll-view scroll-y class="scroll">

    <!-- 顶部行 -->
    <view class="top-row">
      <view class="back-btn" bindtap="goBack">
        <view class="back-arrow"></view>
      </view>
      <text class="brand-l">慢 慢 变 好</text>
      <text class="day-l">本 周 · 一 览</text>
    </view>

    <!-- 7 天计划列表 -->
    <view class="day-list">
      <view
        wx:for="{{weekDays}}" wx:key="idx"
        class="day-row {{item.isToday ? 'day-row-today' : ''}}"
      >
        <text class="day-idx">{{item.dayLabel}}</text>
        <view class="day-content">
          <text class="day-title">{{item.title}}</text>
          <text class="day-sub">{{item.scene}} · {{item.cost}}</text>
        </view>
      </view>
    </view>

    <view style="height: 80rpx;"></view>
  </scroll-view>

</view>
