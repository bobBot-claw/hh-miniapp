<!--pages/together/together.wxml — 共练：选行动+邀请好友-->

<view class="page warm-bg">

  <!-- 背景光点 -->
  <view class="particles">
    <view class="particle p1"></view>
    <view class="particle p2"></view>
    <view class="particle p3"></view>
  </view>

  <!-- 返回 -->
  <view class="top-left" style="top: {{topBarTop}}px; left: {{topBarLeft}}px;" bindtap="goBack">
    <view class="back-icon"></view>
  </view>

  <view class="content">

    <!-- 标题区 -->
    <view class="header">
      <text class="title">一起练</text>
      <text class="subtitle">选一个行动，邀请好友同时开始</text>
    </view>

    <!-- 时段选择 -->
    <view class="scene-tabs">
      <view class="scene-tab {{scene === 'morning' ? 'tab-on' : ''}}" bindtap="switchScene" data-scene="morning">
        <text>晨间</text>
      </view>
      <view class="scene-tab {{scene === 'work' ? 'tab-on' : ''}}" bindtap="switchScene" data-scene="work">
        <text>工间</text>
      </view>
      <view class="scene-tab {{scene === 'night' ? 'tab-on' : ''}}" bindtap="switchScene" data-scene="night">
        <text>夜间</text>
      </view>
      <view class="scene-tab {{scene === 'problem' ? 'tab-on' : ''}}" bindtap="switchScene" data-scene="problem">
        <text>按需</text>
      </view>
    </view>

    <!-- 行动卡片列表 -->
    <view class="action-list">
      <view wx:for="{{actionList}}" wx:key="id" class="action-card" bindtap="selectAction" data-id="{{item.id}}">
        <!-- 选中态 -->
        <view class="card-radio {{selectedId === item.id ? 'radio-on' : ''}}">
          <view wx:if="{{selectedId === item.id}}" class="radio-dot"></view>
        </view>
        <view class="card-body">
          <text class="card-title">{{item.title}}</text>
          <text class="card-sub">{{item.subtitle}}</text>
        </view>
        <view class="card-meta">
          <text class="card-duration">{{item.durationText}}</text>
          <view class="card-depth depth-{{item.depth}}">
            <text>{{item.depthLabel}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部 CTA -->
    <view class="bottom-bar">
      <view class="cta {{selectedId ? '' : 'cta-disabled'}}" bindtap="shareAction">
        <text>{{selectedId ? '邀请好友一起练' : '先选一个行动'}}</text>
      </view>
    </view>

  </view>
</view>
