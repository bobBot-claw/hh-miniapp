/* pages/exercise/player/player.wxss - 跟练播放器 v4.0 */
.page { min-height: 100vh; background: var(--bg); color: #fff; }

.header { padding: 24rpx 36rpx; text-align: center; }
.title { font-size: 32rpx; font-weight: 700; }

.video-wrap { margin: 0 36rpx; border-radius: 16rpx; overflow: hidden; }
.video { width: 100%; height: 420rpx; }

/* Mock */
.mock { min-height: 60vh; display: flex; align-items: center; justify-content: center; }
.mock-center { display: flex; flex-direction: column; align-items: center; width: 100%; }
.mock-emoji { font-size: 72rpx; margin-bottom: 24rpx; }
.mock-dur { font-size: 26rpx; color: var(--text-dim); margin-bottom: 40rpx; }

.countdown-num {
  font-size: 140rpx; font-weight: 900;
  color: var(--primary);
}

.play-emoji { font-size: 72rpx; margin-bottom: 40rpx; }
.progress-track { width: 70%; height: 6rpx; background: rgba(255,255,255,0.08); border-radius: 3rpx; overflow: hidden; margin-bottom: 16rpx; }
.progress-fill { height: 100%; background: var(--primary); border-radius: 3rpx; transition: width 1s linear; }
.play-time { font-size: 24rpx; color: var(--text-dim); margin-bottom: 32rpx; }

.ctrl-row { display: flex; gap: 24rpx; }
.ctrl {
  padding: 14rpx 36rpx; border-radius: 28rpx; font-size: 26rpx;
  background: var(--surface); color: var(--text-dim);
}
.ctrl-on { background: var(--primary-soft); color: var(--primary); }

.end-row { padding: 24rpx 36rpx; display: flex; justify-content: center; }

/* 反馈 */
.fb {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 48rpx 36rpx;
}
.fb-icon { font-size: 64rpx; margin-bottom: 24rpx; }
.fb-text { font-size: 36rpx; font-weight: 700; margin-bottom: 32rpx; text-align: center; }
.fb-gains { margin-bottom: 40rpx; }
.fb-gain { font-size: 26rpx; color: var(--accent); margin-bottom: 8rpx; text-align: center; }

.empty { display: flex; justify-content: center; padding: 120rpx 0; }
