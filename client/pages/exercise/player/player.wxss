/* pages/exercise/player/player.wxss - 跟练播放器样式 v2.0 */
.page-exercise-player {
  min-height: 100vh;
  background: #1a1a2e;
  color: #fff;
}

.player-header {
  padding: 24rpx 32rpx;
  text-align: center;
}

.player-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 6rpx;
}

.player-category {
  display: block;
  opacity: 0.6;
}

/* 真实视频 */
.video-container {
  margin: 0 32rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.exercise-video {
  width: 100%;
  height: 420rpx;
}

/* Mock 模式播放器 */
.mock-player-container {
  margin: 20rpx 32rpx;
  min-height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mock-ready {
  text-align: center;
  width: 100%;
}

.mock-exercise-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.mock-exercise-name {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.mock-duration {
  font-size: 28rpx;
  opacity: 0.6;
  display: block;
  margin-bottom: 48rpx;
}

.btn-start-mock {
  display: inline-block;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
}

/* 倒计时 */
.mock-countdown {
  text-align: center;
}

.countdown-number {
  font-size: 160rpx;
  font-weight: 900;
  color: #4facfe;
  display: block;
  animation: countPulse 1s infinite;
}

@keyframes countPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.countdown-text {
  font-size: 28rpx;
  opacity: 0.6;
  display: block;
  margin-top: 20rpx;
}

/* 播放中 */
.mock-playing {
  text-align: center;
  width: 100%;
}

.mock-animation-area {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pulse-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid rgba(79, 172, 254, 0.3);
}

.pulse-ring.pulsing {
  animation: pulse 2s infinite;
}

.pulse-ring.delay.pulsing {
  animation: pulse 2s infinite 0.5s;
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(1.4); opacity: 0; }
}

.mock-playing-emoji {
  font-size: 80rpx;
  z-index: 1;
}

.mock-progress-bar {
  width: 80%;
  margin: 0 auto 16rpx;
  height: 12rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.mock-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4facfe, #00f2fe);
  border-radius: 6rpx;
  transition: width 1s linear;
}

.mock-time {
  font-size: 26rpx;
  opacity: 0.5;
  display: block;
  margin-bottom: 40rpx;
}

.mock-controls {
  display: flex;
  justify-content: center;
}

.btn-mock-pause, .btn-mock-resume {
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.1);
  color: #fff;
}

/* 动作提示 */
.player-hint {
  padding: 20rpx 32rpx;
  text-align: center;
}

.hint-text {
  font-size: 26rpx;
  opacity: 0.5;
}

/* 完成按钮 */
.player-footer {
  padding: 24rpx 32rpx;
  text-align: center;
}

.btn-done {
  display: inline-block;
  padding: 20rpx 64rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

/* 完成反馈 */
.feedback-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(180deg, #1a1a2e, #2d1b69);
}

.feedback-celebration {
  font-size: 60rpx;
  display: block;
  margin-bottom: 32rpx;
  animation: celebration 0.8s ease;
}

@keyframes celebration {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}

.feedback-encouragement {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  display: block;
  margin-bottom: 16rpx;
}

.feedback-body-hint {
  font-size: 28rpx;
  opacity: 0.6;
  text-align: center;
  display: block;
  margin-bottom: 40rpx;
}

.stat-gains {
  width: 100%;
  margin-bottom: 40rpx;
}

.stat-gain-item {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
}

.stat-gain-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.stat-gain-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #4facfe;
}

.achievement-unlock {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,215,0,0.3);
}

.achievement-emoji {
  font-size: 48rpx;
  display: block;
  margin-bottom: 8rpx;
}

.achievement-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffd700;
  display: block;
  margin-bottom: 4rpx;
}

.achievement-desc {
  opacity: 0.6;
}

.feedback-actions {
  display: flex;
  gap: 24rpx;
}

.btn-another {
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.1);
  border: 2rpx solid rgba(255,255,255,0.3);
  color: #fff;
  font-size: 28rpx;
}

.btn-done-feedback {
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* 通用 */
.text-secondary { color: rgba(255,255,255,0.6); }
.text-sm { font-size: 24rpx; }

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}
