<!--pages/exercise/player/player.wxml - 跟练播放器 v4.0 — 极简·专注-->
<view class="page">
  <view wx:if="{{loading}}" class="empty"><text class="text-dim">加载中</text></view>

  <!-- 跟练中 -->
  <block wx:if="{{exercise && !feedback}}">
    <view class="header">
      <text class="title">{{exercise.title}}</text>
    </view>

    <!-- 有视频 -->
    <view wx:if="{{hasVideo}}" class="video-wrap">
      <video id="exerciseVideo" src="{{exercise.video_url}}" class="video"
        controls show-center-play-btn enable-progress-gesture object-fit="contain"
        bindplay="onVideoPlay" bindpause="onVideoPause" bindended="onVideoEnded" bindtimeupdate="onVideoTimeUpdate"
      />
    </view>

    <!-- Mock模式 -->
    <view wx:else class="mock">
      <!-- 准备 -->
      <view wx:if="{{timerPhase === 'ready'}}" class="mock-center">
        <text class="mock-emoji">{{exercise.emoji || '🏋️'}}</text>
        <text class="mock-dur">预计 {{duration}}s</text>
        <view class="cta" bindtap="onStartMock"><text>开始</text></view>
      </view>
      <!-- 倒计时 -->
      <view wx:elif="{{timerPhase === 'countdown'}}" class="mock-center">
        <text class="countdown-num">{{countDown}}</text>
      </view>
      <!-- 播放 -->
      <view wx:elif="{{timerPhase === 'playing'}}" class="mock-center">
        <text class="play-emoji">{{exercise.emoji || '🏋️'}}</text>
        <view class="progress-track">
          <view class="progress-fill" style="width: {{mockProgress}}%"></view>
        </view>
        <text class="play-time">{{formatTime(currentTime)}} / {{formatTime(duration)}}</text>
        <view class="ctrl-row">
          <view wx:if="{{mockPlaying}}" class="ctrl" bindtap="onPauseMock"><text>暂停</text></view>
          <view wx:else class="ctrl ctrl-on" bindtap="onResumeMock"><text>继续</text></view>
        </view>
      </view>
    </view>

    <!-- 完成 -->
    <view class="end-row" wx:if="{{hasVideo || timerPhase === 'playing'}}">
      <view class="ctrl" bindtap="onDoneTap"><text>{{completed ? '完成了' : '结束跟练'}}</text></view>
    </view>
  </block>

  <!-- 反馈 -->
  <block wx:if="{{feedback}}">
    <view class="fb">
      <text class="fb-icon">✨</text>
      <text class="fb-text">{{feedback.encouragement}}</text>
      <view wx:if="{{feedback.stat_gains}}" class="fb-gains">
        <view wx:for="{{feedback.stat_gains}}" wx:key="stat" class="fb-gain">
          <text>{{item.label}} +{{item.gain}}</text>
        </view>
      </view>
      <view class="cta" bindtap="onDoneTap"><text>完成</text></view>
      <view class="ctrl" style="margin-top:16rpx;" bindtap="onDoAnotherTap"><text>再来一个</text></view>
    </view>
  </block>
</view>
