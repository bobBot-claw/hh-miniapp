<!--pages/exercise/player/player.wxml - 跟练播放器 v3.0 — 深空沉浸+全息反馈-->
<view class="page-exercise-player deep-bg">
  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-secondary">加载中...</text>
  </view>

  <!-- 跟练中 -->
  <block wx:if="{{exercise && !feedback}}">
    <view class="player-header">
      <text class="player-title">{{exercise.title}}</text>
      <text class="player-category">{{exercise.category_label || ''}}</text>
    </view>

    <!-- 有真实视频 -->
    <view wx:if="{{hasVideo}}" class="video-container">
      <video
        id="exerciseVideo"
        src="{{exercise.video_url}}"
        class="exercise-video"
        controls="{{true}}"
        show-center-play-btn="{{true}}"
        enable-progress-gesture="{{true}}"
        object-fit="contain"
        bindplay="onVideoPlay"
        bindpause="onVideoPause"
        bindended="onVideoEnded"
        bindtimeupdate="onVideoTimeUpdate"
        poster="{{exercise.thumbnail_url || ''}}"
      />
    </view>

    <!-- Mock 模式：全息能量环 -->
    <view wx:else class="mock-player">
      <!-- 准备态 -->
      <view wx:if="{{timerPhase === 'ready'}}" class="mock-ready">
        <view class="energy-orb-lg">
          <view class="energy-orb-halo"></view>
          <text class="energy-orb-emoji">{{exercise.emoji || '🏋️'}}</text>
        </view>
        <text class="mock-ex-name">{{exercise.title}}</text>
        <text class="mock-ex-dur">预计 {{duration}}s</text>
        <view class="cta-holo" bindtap="onStartMock">
          <text class="cta-holo-text">开始跟练</text>
        </view>
      </view>

      <!-- 倒计时 -->
      <view wx:elif="{{timerPhase === 'countdown'}}" class="mock-countdown">
        <text class="countdown-num">{{countDown}}</text>
        <text class="countdown-label">准备开始</text>
        <view class="countdown-ring"></view>
      </view>

      <!-- 播放中 -->
      <view wx:elif="{{timerPhase === 'playing'}}" class="mock-playing">
        <view class="play-energy-ring">
          <view class="ring-pulse r1 {{mockPlaying ? 'ring-active' : ''}}"></view>
          <view class="ring-pulse r2 {{mockPlaying ? 'ring-active' : ''}}"></view>
          <text class="play-emoji">{{exercise.emoji || '🏋️'}}</text>
        </view>
        <view class="play-progress-track">
          <view class="play-progress-fill" style="width: {{mockProgress}}%"></view>
        </view>
        <text class="play-time">{{formatTime(currentTime)}} / {{formatTime(duration)}}</text>
        <view class="play-ctrl">
          <view wx:if="{{mockPlaying}}" class="ctrl-btn" bindtap="onPauseMock">
            <text>⏸ 暂停</text>
          </view>
          <view wx:else class="ctrl-btn ctrl-primary" bindtap="onResumeMock">
            <text>▶ 继续</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 动作提示 -->
    <view class="player-hint" wx:if="{{hasVideo}}">
      <text>💡 跟着视频做，动作缓慢，不要用力</text>
    </view>

    <!-- 完成按钮 -->
    <view class="player-footer" wx:if="{{hasVideo || timerPhase === 'playing'}}">
      <view class="ctrl-btn ctrl-end" bindtap="onDoneTap">
        <text>{{completed ? '完成了' : '结束跟练'}}</text>
      </view>
    </view>
  </block>

  <!-- 完成反馈 — 全息解锁 -->
  <block wx:if="{{feedback}}">
    <view class="feedback-view">
      <view class="fb-glow"></view>
      <text class="fb-celebrate">✨ 🎉 ✨</text>
      <text class="fb-encourage">{{feedback.encouragement}}</text>
      <text class="fb-hint" wx:if="{{feedback.body_hint}}">{{feedback.body_hint}}</text>

      <!-- 能力值增长 — 能量注入动画 -->
      <view class="fb-gains" wx:if="{{feedback.stat_gains}}">
        <view wx:for="{{feedback.stat_gains}}" wx:key="stat" class="fb-gain-item">
          <text class="fb-gain-label">{{item.label}}</text>
          <text class="fb-gain-value">+{{item.gain}}</text>
          <view class="fb-gain-bar" style="width: {{item.gain * 20}}%; background: {{item.color || '#7c6ff7'}};"></view>
        </view>
      </view>

      <!-- 成就 -->
      <view wx:if="{{feedback.achievement}}" class="fb-achievement">
        <view class="ach-glow"></view>
        <text class="ach-emoji">🏆</text>
        <text class="ach-title">{{feedback.achievement.title}}</text>
        <text class="ach-desc">{{feedback.achievement.description}}</text>
      </view>

      <!-- 操作 -->
      <view class="fb-actions">
        <view class="ctrl-btn" bindtap="onDoAnotherTap"><text>再来一个</text></view>
        <view class="cta-holo" bindtap="onDoneTap">
          <text class="cta-holo-text">完成</text>
        </view>
      </view>
    </view>
  </block>
</view>
