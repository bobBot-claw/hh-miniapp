<!--pages/exercise/detail/detail.wxml - 运动详情 v4.0 — 极简·行动-->
<view class="page deep-bg">
  <view wx:if="{{loading}}" class="empty"><text class="text-dim">加载中</text></view>

  <block wx:if="{{exercise}}">
    <!-- 沉浸封面 -->
    <view class="hero" style="background: {{exercise.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
      <view class="hero-fade"></view>
      <text class="hero-emoji">{{exercise.emoji || '💪'}}</text>
      <text class="hero-title">{{exercise.title}}</text>
      <text class="hero-sub">{{exercise.subtitle}}</text>
    </view>

    <!-- CTA — 直接行动 -->
    <view class="cta-wrap">
      <view class="cta" bindtap="onStartTap"><text>开始跟练</text></view>
    </view>

    <!-- 极简信息 -->
    <view class="info">
      <view class="info-row" wx:if="{{exercise.target_body && exercise.target_body.length}}">
        <text class="info-label">目标</text>
        <text class="info-val">{{exercise.target_body.join(' · ')}}</text>
      </view>
      <view class="info-row" wx:if="{{exercise.duration_text}}">
        <text class="info-label">时长</text>
        <text class="info-val">{{exercise.duration_text}}</text>
      </view>
      <view class="info-row" wx:if="{{exercise.difficulty}}">
        <text class="info-label">难度</text>
        <text class="info-val">{{exercise.difficulty}}</text>
      </view>
    </view>

    <view style="height:60rpx;"></view>
  </block>
</view>
