/* pages/exercise/detail/detail.wxss - 运动详情 v3.0 — 深空沉浸 */
.page-exercise-detail { min-height: 100vh; padding-bottom: 120rpx; }

/* 全屏沉浸封面 */
.detail-hero {
  position: relative;
  min-height: 420rpx;
  display: flex; align-items: flex-end;
  overflow: hidden;
}
.hero-vignette {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 200rpx;
  background: linear-gradient(to top, #050510, transparent);
  z-index: 1;
}
.hero-content {
  position: relative; z-index: 2;
  padding: 0 36rpx 36rpx;
  width: 100%;
}
.detail-emoji {
  font-size: 72rpx; display: block; margin-bottom: 16rpx;
  filter: drop-shadow(0 0 16rpx rgba(124,111,247,0.4));
}
.detail-title {
  font-size: 44rpx; font-weight: 900; color: #fff; display: block;
  line-height: 1.2; margin-bottom: 8rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}
.detail-subtitle {
  font-size: var(--font-size-base); color: rgba(255,255,255,0.6); display: block;
  line-height: 1.5;
}
/* 浮动光点 */
.hero-glow-1 {
  position: absolute; top: 10%; right: -10%;
  width: 200rpx; height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: gentle-float 6s ease-in-out infinite;
  pointer-events: none;
}
.hero-glow-2 {
  position: absolute; top: 40%; left: -5%;
  width: 160rpx; height: 160rpx;
  background: radial-gradient(circle, rgba(124,111,247,0.1) 0%, transparent 70%);
  animation: gentle-float 7s ease-in-out infinite 2s;
  pointer-events: none;
}

/* 信息条 */
.detail-meta { padding: 24rpx 36rpx 0; }
.meta-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }

/* 开始按钮 */
.detail-action { padding: 32rpx 36rpx; }

/* 段落 */
.detail-section { padding: 20rpx 36rpx; }
.section-title-cyber {
  font-size: var(--font-size-base); font-weight: 700;
  margin-bottom: 16rpx; display: block;
  color: var(--color-text);
}
.target-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.detail-desc {
  font-size: var(--font-size-sm); line-height: 1.8;
  color: var(--color-text-secondary);
}

.text-secondary { color: var(--color-text-secondary); }
.loading-container { display: flex; justify-content: center; align-items: center; height: 60vh; }
