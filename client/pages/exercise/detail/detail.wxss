/* pages/exercise/detail/detail.wxss - 运动详情 - 质感升级 */
.page-exercise-detail { min-height: 100vh; background: var(--color-bg); padding-bottom: 120rpx; }

.detail-cover {
  height: 360rpx; display: flex; justify-content: center; align-items: center;
  position: relative;
}
.detail-cover::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0;
  height: 80rpx; background: linear-gradient(to top, var(--color-bg), transparent);
}
.detail-cover-emoji { font-size: 96rpx; }

.detail-info { padding: 32rpx 36rpx; display: flex; flex-direction: column; gap: 12rpx; }
.detail-title { font-size: 42rpx; font-weight: 800; line-height: 1.3; color: var(--color-text); }
.detail-subtitle { font-size: var(--font-size-base); line-height: 1.5; color: var(--color-text-secondary); }
.detail-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }

.detail-action { padding: 0 36rpx; margin: 16rpx 0; }
.btn-start {
  display: flex; justify-content: center; align-items: center;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: white; padding: 28rpx; border-radius: var(--radius-xl);
  font-size: var(--font-size-lg); font-weight: 700;
  box-shadow: 0 8rpx 32rpx rgba(124, 111, 247, 0.35);
  border: 1rpx solid rgba(255,255,255,0.1);
}

.detail-section { padding: 20rpx 36rpx; }
.section-label { font-size: var(--font-size-base); font-weight: 700; margin-bottom: 16rpx; display: block; color: var(--color-text); }
.target-body-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.target-tag {
  background: var(--color-bg-card); color: var(--color-primary-light);
  padding: 8rpx 20rpx; border-radius: var(--radius-lg); font-size: var(--font-size-sm);
  border: 1rpx solid rgba(124, 111, 247, 0.2);
}
.detail-desc { font-size: var(--font-size-sm); line-height: 1.8; color: var(--color-text-secondary); }
