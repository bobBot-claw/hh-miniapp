/* pages/exercise/detail/detail.wxss - 运动详情 v4.0 */
.page { min-height: 100vh; }

.hero {
  position: relative; min-height: 400rpx;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 0 36rpx 48rpx; overflow: hidden;
}
.hero-fade {
  position: absolute; bottom: 0; left: 0; right: 0; height: 180rpx;
  background: linear-gradient(to top, var(--bg), transparent);
}
.hero-emoji { font-size: 64rpx; margin-bottom: 16rpx; position: relative; z-index: 1; }
.hero-title { font-size: 44rpx; font-weight: 800; color: #fff; display: block; margin-bottom: 8rpx; position: relative; z-index: 1; }
.hero-sub { font-size: 26rpx; color: rgba(255,255,255,0.6); display: block; position: relative; z-index: 1; }

.cta-wrap { padding: 36rpx 36rpx 0; display: flex; justify-content: center; }

.info { padding: 36rpx; }
.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.info-label { font-size: 26rpx; color: var(--text-dim); }
.info-val { font-size: 26rpx; color: var(--text); font-weight: 500; }

.empty { display: flex; justify-content: center; padding: 120rpx 0; }
