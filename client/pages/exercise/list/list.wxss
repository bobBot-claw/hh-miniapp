/* pages/exercise/list/list.wxss - 运动列表 v2.2 - 加入计划入口 */
.page-exercise-list { min-height: 100vh; background: var(--color-bg); }

/* 训练计划入口 */
.plan-entry {
  display: flex; align-items: center; justify-content: space-between;
  margin: 20rpx 36rpx 8rpx; padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(124, 111, 247, 0.08), rgba(78, 205, 196, 0.06));
  border-radius: 20rpx; border: 1rpx solid rgba(124, 111, 247, 0.12);
}
.plan-entry-left { display: flex; align-items: center; gap: 20rpx; }
.plan-entry-icon {
  width: 64rpx; height: 64rpx; border-radius: 16rpx;
  background: var(--color-primary);
  display: flex; align-items: center; justify-content: center;
}
.plan-entry-icon-text { font-size: 22rpx; font-weight: 700; color: #fff; }
.plan-entry-text { display: flex; flex-direction: column; gap: 4rpx; }
.plan-entry-title { font-size: 28rpx; font-weight: 700; color: var(--color-text); }
.plan-entry-sub { font-size: 22rpx; color: var(--color-text-secondary); }
.plan-entry-go {
  width: 16rpx; height: 16rpx;
  border-right: 3rpx solid var(--color-text-tertiary);
  border-top: 3rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
}

.category-scroll { white-space: nowrap; padding: 20rpx 36rpx; }
.category-list { display: inline-flex; gap: 12rpx; }
.category-tag {
  display: inline-block; padding: 14rpx 28rpx; border-radius: 24rpx;
  background: var(--color-bg-card); font-size: var(--font-size-sm);
  color: var(--color-text-secondary); font-weight: 500;
  border: 1rpx solid var(--color-border);
}
.category-active {
  background: var(--color-primary); color: white;
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(124, 111, 247, 0.2);
}

.exercise-scroll { height: calc(100vh - 200rpx); }
.exercise-grid { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 0 36rpx 40rpx; }
.exercise-card {
  width: calc(50% - 8rpx); background: var(--color-bg-card);
  border-radius: 24rpx; overflow: hidden;
  border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.exercise-cover {
  height: 160rpx; display: flex; justify-content: center; align-items: center;
  position: relative;
}
.exercise-duration-badge {
  position: absolute; top: 12rpx; right: 12rpx; font-size: 20rpx;
  background: rgba(0,0,0,0.35); color: rgba(255,255,255,0.85);
  padding: 4rpx 14rpx; border-radius: 10rpx;
}
.exercise-info { padding: 18rpx; display: flex; flex-direction: column; gap: 6rpx; }
.exercise-title { font-size: var(--font-size-sm); font-weight: 700; color: var(--color-text); line-height: 1.4; }
.exercise-sub { line-height: 1.4; color: var(--color-text-secondary); }
.exercise-meta { display: flex; gap: 8rpx; align-items: center; margin-top: 4rpx; }
