/* pages/exercise/list/list.wxss - 运动列表 v4.0 */
.page { min-height: 100vh; }

.link-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 36rpx; font-size: 28rpx; color: var(--text);
}
.link-row .go { color: var(--text-dim); }

.tags { white-space: nowrap; padding: 0 36rpx 16rpx; }
.tag-row { display: inline-flex; gap: 16rpx; }
.tag { font-size: 24rpx; color: var(--text-dim); padding: 6rpx 0; }
.tag-on { color: #fff; font-weight: 700; }

.list-scroll { height: calc(100vh - 180rpx); }
.list { padding: 0 36rpx; }

.item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.item-cover {
  width: 56rpx; height: 56rpx; border-radius: 12rpx; flex-shrink: 0;
}
.item-info { flex: 1; min-width: 0; }
.item-title { font-size: 28rpx; font-weight: 600; color: var(--text); display: block; }
.item-dur { font-size: 22rpx; color: var(--text-dim); }
.item-go { font-size: 28rpx; color: var(--text-dim); flex-shrink: 0; }

.empty { display: flex; justify-content: center; padding: 120rpx 0; }
