<!--pages/exercise/list/list.wxml - 运动分类列表 v2.3 - 卡片精简-->
<view class="page-exercise-list">
  <!-- 训练计划入口 -->
  <view class="plan-entry" bindtap="onViewPlans">
    <view class="plan-entry-left">
      <view class="plan-entry-icon">
        <text class="plan-entry-icon-text">计划</text>
      </view>
      <view class="plan-entry-text">
        <text class="plan-entry-title">系统训练计划</text>
        <text class="plan-entry-sub">一个计划解决一个问题</text>
      </view>
    </view>
    <view class="plan-entry-go"></view>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="category-scroll">
    <view class="category-list">
      <view
        class="category-tag {{activeCategory === '' ? 'category-active' : ''}}"
        bindtap="onCategoryTap"
        data-key=""
      >
        <text>全部</text>
      </view>
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-tag {{activeCategory === item.key ? 'category-active' : ''}}"
        bindtap="onCategoryTap"
        data-key="{{item.key}}"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 运动列表 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-secondary">加载中...</text>
  </view>

  <scroll-view wx:else scroll-y class="exercise-scroll">
    <view class="exercise-grid">
      <view
        wx:for="{{exercises}}"
        wx:key="id"
        class="exercise-card"
        data-id="{{item.id}}"
        bindtap="onExerciseTap"
      >
        <view class="exercise-cover" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
          <text class="exercise-duration-badge">{{item.duration_text || '5min'}}</text>
        </view>
        <view class="exercise-info">
          <text class="exercise-title">{{item.title}}</text>
        </view>
      </view>
    </view>
    <view style="height: 160rpx;"></view>
  </scroll-view>
</view>
