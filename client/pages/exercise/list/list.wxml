<!--pages/exercise/list/list.wxml - 运动列表 v4.0 — 极简·行动-->
<view class="page deep-bg">
  <!-- 计划入口 -->
  <view class="link-row" bindtap="onViewPlans">
    <text>训练计划</text>
    <text class="go">›</text>
  </view>

  <!-- 标签 — 一行文字 -->
  <scroll-view scroll-x class="tags">
    <view class="tag-row">
      <text class="tag {{activeCategory === '' ? 'tag-on' : ''}}" data-key="" bindtap="onCategoryTap">全部</text>
      <text wx:for="{{categories}}" wx:key="key" class="tag {{activeCategory === item.key ? 'tag-on' : ''}}" data-key="{{item.key}}" bindtap="onCategoryTap">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 列表 -->
  <view wx:if="{{loading}}" class="empty"><text class="text-dim">加载中</text></view>
  <scroll-view wx:else scroll-y class="list-scroll">
    <view class="list">
      <view wx:for="{{exercises}}" wx:key="id" class="item" data-id="{{item.id}}" bindtap="onExerciseTap">
        <view class="item-cover" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}"></view>
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <text class="item-dur">{{item.duration_text || '5min'}}</text>
        </view>
        <text class="item-go">›</text>
      </view>
    </view>
    <view style="height:160rpx;"></view>
  </scroll-view>
</view>
