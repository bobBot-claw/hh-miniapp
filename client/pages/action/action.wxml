<!--pages/action/action.wxml — 行动+认知卡片：与 demo 屏3 完全一致-->

<view class="page">

  <!-- 暖色光晕 -->
  <view class="halo halo-1"></view>
  <view class="halo halo-2"></view>

  <!-- 行动中状态 — 简化倒计时 -->
  <view class="action-view" wx:if="{{!showCognize}}">
    <view class="top-row">
      <text class="brand-l">慢 慢 变 好</text>
      <text class="day-l">第 {{weekNum}} 周 · {{dayLabel}}</text>
    </view>

    <view class="recommend">
      <text class="tag">今 日 微 动 作</text>
      <text class="rec-scene">{{sceneLabel}}</text>
      <text class="act-name">{{actionTitle}}</text>
      <text class="act-sub">{{actionSub}}</text>
    </view>

    <view class="timer-section">
      <text class="timer-label">行 动 中</text>
      <view class="cta" bindtap="completeAction"><text>完 成 了</text></view>
      <view class="cta-alt" bindtap="goBack"><text>提 前 结 束</text></view>
    </view>
  </view>

  <!-- 认知卡片弹层 — demo: .cognize -->
  <view class="overlay" wx:if="{{showCognize}}">
    <view class="cognize">
      <text class="ci-tag">你 今 天 的 发 现</text>
      <text class="ci-h">{{cognizeTitle}}</text>
      <text class="ci-t">{{cognizeText}}</text>
      <text class="ci-em">{{cognizeEm}}</text>
      <text class="ci-foot">科 学 小 知 识 · 不 是 点 评</text>
      <view class="cta" style="width:100%;text-align:center;" bindtap="goHome"><text>收 到</text></view>
    </view>
  </view>

</view>
