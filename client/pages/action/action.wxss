/* pages/action/action.wxss — 行动页：暖白浅色 */

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: #FCFCFD;
}

/* 背景插画 — 柔和暗态 */
.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}
.illust-soft {
  filter: blur(16px) saturate(60%) brightness(1.1) opacity(0.3);
}

/* 暖白叠加层 */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 60% 50% at 40% 30%, rgba(212, 183, 121, 0.1) 0%, transparent 60%),
    linear-gradient(180deg, rgba(252, 252, 253, 0.85) 0%, rgba(248, 244, 238, 0.92) 100%);
  z-index: 1;
  pointer-events: none;
}

/* 内容 */
.content {
  position: relative;
  z-index: 5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 64rpx;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

/* 返回 */
.top-left {
  position: fixed; top: 100rpx; left: 48rpx;
  z-index: 10;
}
.back-icon {
  width: 60rpx; height: 60rpx;
  position: relative;
}
.back-icon::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 2rpx;
  background: rgba(42, 40, 32, 0.4);
  transform: translate(-50%, -50%) rotate(45deg);
  transform-origin: right center;
}
.back-icon::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 2rpx;
  background: rgba(42, 40, 32, 0.4);
  transform: translate(-50%, -50%) rotate(-45deg);
  transform-origin: right center;
}

/* 进度环 */
.ring-wrap {
  width: 260rpx; height: 260rpx;
  position: relative;
  margin-bottom: 40rpx;
}
.ring-bg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(0, 0, 0, 0.06);
}
.ring-fg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  border: 6rpx solid transparent;
  border-top-color: var(--brand-600, #147D45);
  animation: ring-pulse 3s ease-in-out infinite;
}
.ring-center {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201, 166, 107, 0.15) 0%, transparent 70%);
  display: flex; align-items: center; justify-content: center;
}
.flame-svg {
  width: 40rpx; height: 40rpx;
  background: radial-gradient(circle, var(--gold-500, #C9A66B) 0%, rgba(201, 166, 107, 0.2) 60%, transparent 100%);
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
}

/* 标题 */
.action-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--neutral-900);
  margin-bottom: 12rpx;
}
.action-sub {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* 深度标签 */
.depth-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 32rpx;
}
.depth-light {
  background: rgba(20, 125, 69, 0.08);
  color: var(--brand-600, #147D45);
  border: 1rpx solid rgba(20, 125, 69, 0.2);
}
.depth-medium {
  background: rgba(201, 166, 107, 0.1);
  color: var(--gold-600, #A88950);
  border: 1rpx solid rgba(201, 166, 107, 0.25);
}
.depth-deep {
  background: rgba(106, 90, 205, 0.08);
  color: rgba(106, 90, 205, 0.8);
  border: 1rpx solid rgba(106, 90, 205, 0.2);
}

/* 步骤 */
.steps {
  width: 100%;
  margin-top: 8rpx;
}
.step {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  opacity: 0.35;
  transition: opacity 0.5s ease;
}
.step-on {
  opacity: 1;
}
.step-num {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
  margin-right: 20rpx;
  transition: all 0.5s ease;
  background: #fff;
}
.step-on .step-num {
  border-color: var(--brand-600, #147D45);
  color: var(--brand-600, #147D45);
  background: rgba(20, 125, 69, 0.06);
}
.step-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.step-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}
.step-hint {
  font-size: 24rpx;
  color: var(--brand-600, #147D45);
  opacity: 0.7;
  margin-top: 6rpx;
  line-height: 1.5;
  animation: breathe 3s ease-in-out infinite;
}

/* 提前结束 */
.btn-text {
  margin-top: 40rpx;
  padding: 16rpx 40rpx;
  background: transparent;
  border: none;
}
.btn-text text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
}
