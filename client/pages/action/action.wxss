/* pages/action/action.wxss — 行动页：暖白浅色 v0.8 三段式 */

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: #FCFCFD;
}

/* 背景插画 — 柔和暗态 */
.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}
.illust-soft {
  filter: blur(16px) saturate(60%) brightness(1.1) opacity(0.3);
}

/* 暖白叠加层 */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 60% 50% at 40% 30%, rgba(212, 183, 121, 0.1) 0%, transparent 60%),
    linear-gradient(180deg, rgba(252, 252, 253, 0.85) 0%, rgba(248, 244, 238, 0.92) 100%);
  z-index: 1;
  pointer-events: none;
}

/* 内容 */
.content {
  position: relative;
  z-index: 5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 64rpx;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

/* 返回按钮 — 动态定位 */
.top-left {
  position: fixed;
  z-index: 10;
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex; align-items: center; justify-content: center;
}
.back-icon {
  width: 60rpx; height: 60rpx;
  position: relative;
}
.back-icon::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 2rpx;
  background: rgba(42, 40, 32, 0.4);
  transform: translate(-50%, -50%) rotate(45deg);
  transform-origin: right center;
}
.back-icon::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 2rpx;
  background: rgba(42, 40, 32, 0.4);
  transform: translate(-50%, -50%) rotate(-45deg);
  transform-origin: right center;
}

/* 进度环 */
.ring-wrap {
  width: 260rpx; height: 260rpx;
  position: relative;
  margin-bottom: 32rpx;
}
.ring-bg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(0, 0, 0, 0.06);
}
.ring-fg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  border: 6rpx solid transparent;
  border-top-color: var(--brand-600, #147D45);
  animation: ring-pulse 3s ease-in-out infinite;
}
.ring-center {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}

/* 阶段标识 */
.phase-label {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}
.phase-warmup {
  color: var(--gold-500, #C9A66B);
}
.phase-work {
  color: var(--brand-600, #147D45);
}
.phase-rest {
  color: var(--text-tertiary, #9CA3AF);
}
.phase-cooldown {
  color: rgba(106, 90, 205, 0.7);
}

/* 标题 */
.action-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--neutral-900);
  margin-bottom: 12rpx;
}
.action-sub {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* 深度标签 */
.depth-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 28rpx;
}
.depth-light {
  background: rgba(20, 125, 69, 0.08);
  color: var(--brand-600, #147D45);
  border: 1rpx solid rgba(20, 125, 69, 0.2);
}
.depth-medium {
  background: rgba(201, 166, 107, 0.1);
  color: var(--gold-600, #A88950);
  border: 1rpx solid rgba(201, 166, 107, 0.25);
}
.depth-deep {
  background: rgba(106, 90, 205, 0.08);
  color: rgba(106, 90, 205, 0.8);
  border: 1rpx solid rgba(106, 90, 205, 0.2);
}

/* 当前步骤大字 */
.current-step {
  width: 100%;
  text-align: center;
  margin-bottom: 32rpx;
}
.current-step-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--neutral-900);
  line-height: 1.6;
}
.current-step-hint {
  display: block;
  font-size: 26rpx;
  color: var(--brand-600, #147D45);
  opacity: 0.8;
  margin-top: 12rpx;
  line-height: 1.5;
  animation: breathe 3s ease-in-out infinite;
}

/* 步骤进度条 — 阶段色彩 */
.step-track {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
  flex-wrap: wrap;
}
.step-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  transition: all 0.4s ease;
}
/* 按 phase 着色 */
.step-dot-warmup {
  background: rgba(201, 166, 107, 0.3);
}
.step-dot-work {
  background: rgba(20, 125, 69, 0.3);
}
.step-dot-rest {
  background: rgba(156, 163, 175, 0.25);
}
.step-dot-cooldown {
  background: rgba(106, 90, 205, 0.25);
}
/* 激活态 */
.step-dot-active {
  width: 22rpx; height: 22rpx;
  transform: scale(1.2);
}
.step-dot-active.step-dot-warmup { background: var(--gold-500, #C9A66B); }
.step-dot-active.step-dot-work { background: var(--brand-600, #147D45); }
.step-dot-active.step-dot-rest { background: rgba(156, 163, 175, 0.5); }
.step-dot-active.step-dot-cooldown { background: rgba(106, 90, 205, 0.6); }
/* 已完成 */
.step-dot-done.step-dot-warmup { background: rgba(201, 166, 107, 0.15); }
.step-dot-done.step-dot-work { background: rgba(20, 125, 69, 0.15); }
.step-dot-done.step-dot-rest { background: rgba(156, 163, 175, 0.1); }
.step-dot-done.step-dot-cooldown { background: rgba(106, 90, 205, 0.1); }

/* 步骤列表 */
.steps {
  width: 100%;
  margin-top: 4rpx;
}
.step {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  opacity: 0.3;
  max-height: 120rpx;
  transition: opacity 0.5s ease, max-height 0.4s ease;
  overflow: hidden;
}
.step-on {
  opacity: 1;
  max-height: 300rpx;
}
.step-done {
  opacity: 0.5;
  max-height: 120rpx;
}
.step-fold {
  max-height: 0;
  padding: 0;
  opacity: 0;
}
.step-indicator {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-top: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.step-ind-warmup { background: var(--gold-500, #C9A66B); }
.step-ind-work { background: var(--brand-600, #147D45); }
.step-ind-rest { background: rgba(156, 163, 175, 0.5); }
.step-ind-cooldown { background: rgba(106, 90, 205, 0.5); }

.step-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.step-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
}
.step-hint {
  font-size: 24rpx;
  color: var(--brand-600, #147D45);
  opacity: 0.7;
  margin-top: 4rpx;
  line-height: 1.5;
  animation: breathe 3s ease-in-out infinite;
}

/* 提前结束 */
.btn-text {
  margin-top: 32rpx;
  padding: 16rpx 40rpx;
  background: transparent;
  border: none;
}
.btn-text text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
}
