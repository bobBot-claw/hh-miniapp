/* pages/action/action.wxss — 行动中：倒计时+步骤引导 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
  background: #1a1810;
}

.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

.particles {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1; pointer-events: none; overflow: hidden;
}
.particle {
  position: absolute; bottom: 0;
  width: 10rpx; height: 10rpx;
  background: radial-gradient(circle, var(--gold-400) 0%, transparent 70%);
  border-radius: 50%;
  animation: float-particle 9s ease-in-out infinite;
  opacity: 0;
}
.p1 { left: 25%; animation-delay: 0s; }
.p2 { left: 55%; animation-delay: 2.5s; }
.p3 { left: 80%; animation-delay: 5s; }

.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 160rpx 64rpx 80rpx;
}

/* 返回按钮 */
.top-left {
  position: fixed; top: 100rpx; left: 48rpx;
  z-index: 10;
}
.back-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  position: relative;
}
.back-icon::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 3rpx;
  background: rgba(255, 255, 255, 0.7);
  transform: translate(-50%, -50%) rotate(45deg);
}
.back-icon::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 3rpx;
  background: rgba(255, 255, 255, 0.7);
  transform: translate(-50%, -50%) rotate(-45deg);
  transform-origin: right center;
  transform: translate(-35%, -50%) rotate(-45deg);
}

/* 进度环 */
.ring-wrap {
  position: relative;
  width: 440rpx; height: 440rpx;
  margin-bottom: 64rpx;
}
.ring-bg {
  position: absolute; inset: 0;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.15);
}
.ring-fg {
  position: absolute; inset: 0;
  border-radius: 50%;
  transition: conic-gradient 1s linear;
}
/* 用 mask 做圆环效果 */
.ring-fg::before {
  content: '';
  position: absolute; inset: 6rpx;
  border-radius: 50%;
  background: #1a1810;
}

/* 中心火焰 */
.ring-center {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx; height: 160rpx;
  background: radial-gradient(circle, var(--gold-400) 0%, var(--gold-600) 60%, transparent 80%);
  border-radius: 50%;
  box-shadow: 0 0 80rpx var(--gold-400);
  display: flex; align-items: center; justify-content: center;
  animation: ring-pulse 2s ease-in-out infinite;
}

/* 简化火焰 SVG — 线条火苗 */
.flame-svg {
  width: 60rpx; height: 80rpx;
  background: linear-gradient(to top, transparent 0%, rgba(255,255,255,0.9) 100%);
  clip-path: polygon(50% 0%, 20% 60%, 30% 90%, 50% 100%, 70% 90%, 80% 60%);
}

/* 标题 */
.action-title {
  font-size: 40rpx; font-weight: 300;
  color: var(--text-inverse);
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  display: block;
  text-align: center;
}
.action-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
  margin-bottom: 64rpx;
  text-align: center;
  display: block;
}

/* 步骤 */
.steps {
  width: 100%;
  max-width: 560rpx;
  margin-bottom: 64rpx;
}
.step {
  display: flex; align-items: flex-start; gap: 20rpx;
  padding: 20rpx 0;
  opacity: 0.3;
  transition: opacity 0.3s;
}
.step-on {
  opacity: 1;
}
.step-num {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.step-on .step-num {
  background: var(--gold-500);
  color: #fff;
}
.step-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.7;
  letter-spacing: 2rpx;
}
