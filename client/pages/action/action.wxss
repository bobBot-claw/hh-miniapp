/* pages/action/action.wxss — 行动页：v0.7 demo 风格 */

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: #FCFCFD;
}

/* 背景插画 — 暗态模糊 */
.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}
.illust-soft {
  filter: blur(12px) saturate(85%) brightness(0.65);
  opacity: 1;
}

/* 半透明叠加层 — demo 风格 */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.15);
  z-index: 1;
  pointer-events: none;
}

/* ═══ 共练 3-2-1 倒计时 ═══ */
.countdown-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 20;
  background: rgba(252, 252, 253, 0.85);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.countdown-num {
  font-size: 160rpx;
  font-weight: 200;
  color: var(--brand-600, #147D45);
  letter-spacing: 8rpx;
  animation: breathe 1s ease-in-out infinite;
}

/* ═══ 共练标识条 ═══ */
.together-badge {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 15;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 0;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(20, 125, 69, 0.08);
}
.together-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--brand-600, #147D45);
  animation: breathe 2s ease-in-out infinite;
}
.together-text {
  font-size: 24rpx;
  color: var(--brand-600, #147D45);
  letter-spacing: 3rpx;
  font-weight: 500;
}
.together-share {
  margin-left: 16rpx;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(20, 125, 69, 0.06);
  border: 1rpx solid rgba(20, 125, 69, 0.15);
  font-size: 22rpx;
  color: var(--brand-600, #147D45);
  line-height: 1.4;
}
.together-share::after { border: none; }

/* 内容 */
.content {
  position: relative;
  z-index: 5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
  text-align: center;
}

/* 返回按钮 */
.top-left {
  position: fixed;
  z-index: 10;
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex; align-items: center; justify-content: center;
}
.back-icon {
  width: 60rpx; height: 60rpx;
  position: relative;
}
.back-icon::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 2rpx;
  background: rgba(42, 40, 32, 0.6);
  transform: translate(-50%, -50%) rotate(45deg);
  transform-origin: right center;
}
.back-icon::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 20rpx; height: 2rpx;
  background: rgba(42, 40, 32, 0.6);
  transform: translate(-50%, -50%) rotate(-45deg);
  transform-origin: right center;
}

/* ═══ 进度环 + 火焰中心 (demo 风格) ═══ */
.progress-ring {
  position: relative;
  width: 440rpx; height: 440rpx;
  margin-bottom: 80rpx;
}
.ring-svg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
}
.ring-bg-circle {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.25);
}
.ring-fg-circle {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  border: 8rpx solid transparent;
  border-top-color: var(--gold-400);
  animation: ring-pulse 3s ease-in-out infinite;
}

/* 火焰中心 — demo 风格 */
.flame-center {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx; height: 160rpx;
  background: radial-gradient(circle, var(--gold-400) 0%, var(--gold-600) 60%, transparent 80%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 80rpx var(--gold-400);
  transition: all 2s ease;
}
.flame-center-icon {
  font-size: 56rpx;
  color: white;
  filter: drop-shadow(0 0 8rpx rgba(255, 255, 255, 0.8));
}

/* 标题 — demo: 白色 + text-shadow + font-weight:300 */
.action-title {
  font-size: 36rpx; font-weight: 300;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 0.2em;
  margin-bottom: 24rpx;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}
.action-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.2em;
  max-width: 560rpx;
  line-height: 1.8;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  margin-bottom: 48rpx;
}

/* 步骤进度条 — 阶段色彩 */
.step-track {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 48rpx;
  flex-wrap: wrap;
}
.step-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.4s ease;
}
.step-dot-warmup { background: rgba(229, 204, 154, 0.4); }
.step-dot-work { background: rgba(20, 125, 69, 0.4); }
.step-dot-rest { background: rgba(156, 163, 175, 0.3); }
.step-dot-cooldown { background: rgba(106, 90, 205, 0.3); }
.step-dot-active { width: 22rpx; height: 22rpx; transform: scale(1.2); }
.step-dot-active.step-dot-warmup { background: var(--gold-400); }
.step-dot-active.step-dot-work { background: var(--brand-600); }
.step-dot-active.step-dot-rest { background: rgba(156, 163, 175, 0.6); }
.step-dot-active.step-dot-cooldown { background: rgba(106, 90, 205, 0.7); }
.step-dot-done { opacity: 0.3; }

/* 提前结束 */
.btn-text {
  background: transparent;
  border: none;
  padding: 24rpx 48rpx;
}
.btn-text text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.3em;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
}
