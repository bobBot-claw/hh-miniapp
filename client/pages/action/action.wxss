/* pages/action/action.wxss — 行动+认知卡片：与 demo 完全一致 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  background: var(--bg);
}

/* 暖色光晕 */
.halo {
  position: fixed; pointer-events: none; z-index: 0;
  border-radius: 50%; filter: blur(140px); opacity: 0.5;
}
.halo-1 { width: 680px; height: 680px; background: var(--halo-cream); top: -200px; right: -200px; }
.halo-2 { width: 480px; height: 480px; background: var(--halo-gold); bottom: -200px; left: -200px; opacity: 0.3; }

/* 行动视图 */
.action-view {
  position: relative; z-index: 1;
  padding: 72rpx 44rpx;
}

/* 顶部行 */
.top-row {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 44rpx;
}
.brand-l { font-size: 22rpx; letter-spacing: 0.3em; color: var(--ink-mute); }
.day-l { font-size: 22rpx; letter-spacing: 0.2em; color: var(--ink-dim); }

/* 推荐卡 */
.recommend {
  background: linear-gradient(150deg, var(--warm) 0%, var(--warm-2) 100%);
  border-radius: 48rpx;
  padding: 56rpx 48rpx;
  margin-bottom: 36rpx;
}
.recommend .tag {
  font-size: 22rpx; letter-spacing: 0.3em; color: var(--gold);
  margin-bottom: 16rpx; display: block;
}
.rec-scene {
  font-size: 24rpx; color: var(--ink-mute);
  letter-spacing: 0.18em; margin-bottom: 16rpx; display: block;
}
.act-name {
  font-size: 64rpx; font-weight: 300; letter-spacing: 0.04em;
  margin-bottom: 12rpx; display: block; color: var(--ink);
}
.act-sub {
  font-size: 26rpx; color: var(--ink-mute);
  letter-spacing: 0.06em; display: block;
}

/* 计时区域 */
.timer-section {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 0;
}
.timer-label {
  font-size: 24rpx; letter-spacing: 0.3em; color: var(--ink-dim);
  margin-bottom: 40rpx;
}

/* 认知卡片弹层 — demo: overlay + cognize */
.overlay {
  position: fixed; inset: 0;
  background: rgba(252, 252, 253, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  z-index: 50;
  padding: 40rpx;
}
.cognize {
  background: linear-gradient(150deg, var(--warm) 0%, var(--warm-2) 100%);
  border-radius: 64rpx;
  padding: 72rpx 56rpx;
  width: 100%;
  max-width: 760rpx;
  animation: rise 0.4s ease;
}
@keyframes rise {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.ci-tag {
  font-size: 22rpx; letter-spacing: 0.32em; color: var(--gold);
  margin-bottom: 28rpx; display: block;
}
.ci-h {
  font-size: 44rpx; font-weight: 300; letter-spacing: 0.04em;
  margin-bottom: 36rpx; display: block; color: var(--ink);
}
.ci-t {
  font-size: 28rpx; color: var(--ink); line-height: 1.95;
  margin-bottom: 36rpx; display: block; letter-spacing: 0.03em;
}
.ci-em {
  font-size: 28rpx; color: var(--gold);
  letter-spacing: 0.04em; line-height: 1.85;
  padding: 28rpx 0;
  border-top: 1rpx solid var(--warm-2);
  margin-bottom: 36rpx; display: block;
}
.ci-foot {
  font-size: 22rpx; letter-spacing: 0.18em; color: var(--ink-dim);
  margin-bottom: 36rpx; display: block; text-align: center;
}
