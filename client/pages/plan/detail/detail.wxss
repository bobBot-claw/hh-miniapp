.plan-detail {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 180rpx;
}

/* 头部封面 */
.detail-hero {
  padding: 48rpx 32rpx 40rpx;
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hero-top {
  margin-bottom: 32rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.hero-stat {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.hero-stat-divider {
  width: 2rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 头部进度条 */
.hero-progress-bar {
  height: 6rpx;
  border-radius: 3rpx;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
  margin-top: 8rpx;
}
.hero-progress-fill {
  height: 100%;
  border-radius: 3rpx;
  background: #fff;
  transition: width 0.4s ease;
}

/* 描述 */
.detail-desc {
  padding: 32rpx;
}

.detail-desc text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* 能力值收益 */
.detail-gains {
  padding: 0 32rpx 32rpx;
}

.section-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.gains-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gain-item {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.gain-posture { color: #e17055; background: rgba(225, 112, 85, 0.1); }
.gain-core { color: #00b894; background: rgba(0, 184, 148, 0.1); }
.gain-flex { color: #6c5ce7; background: rgba(108, 92, 231, 0.1); }
.gain-vitality { color: #f39c12; background: rgba(243, 156, 18, 0.1); }
.gain-mind { color: #a29bfe; background: rgba(162, 155, 254, 0.1); }

/* 阶段切换 */
.phase-tabs {
  display: flex;
  padding: 0 32rpx;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.phase-tab {
  flex: 1;
  padding: 20rpx 16rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.phase-tab.active {
  border-color: var(--color-primary);
  background: rgba(124, 111, 247, 0.06);
}

.phase-tab-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.phase-tab-sub {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* 每日列表 */
.daily-list {
  padding: 0 32rpx;
}

.day-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.03);
}

.day-card.day-completed {
  opacity: 0.65;
}

.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.day-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.day-number {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.day-number-done {
  background: #00b894 !important;
  color: #fff !important;
}

.day-check {
  font-size: 28rpx;
  font-weight: 900;
}

.day-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.day-title-done {
  text-decoration: line-through;
  color: var(--text-tertiary);
}

.day-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.day-duration {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.day-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--text-tertiary);
  border-bottom: 3rpx solid var(--text-tertiary);
  transform: rotate(45deg);
  transition: transform 0.2s;
}

.day-arrow.up {
  transform: rotate(-135deg);
}

/* 展开内容 */
.day-content {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.day-section-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding: 20rpx 0 12rpx;
  font-weight: 600;
}

.meditation-label {
  margin-top: 8rpx;
}

/* 训练动作行 */
.exercise-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
}

.exercise-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.exercise-icon-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.meditation-icon {
  background: linear-gradient(135deg, #a29bfe, #6c5ce7) !important;
}

.exercise-info {
  flex: 1;
  min-width: 0;
}

.exercise-name {
  display: block;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exercise-meta {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.exercise-go {
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid var(--text-quaternary);
  border-top: 2rpx solid var(--text-quaternary);
  transform: rotate(45deg);
  flex-shrink: 0;
}

.meditation-row {
  padding-bottom: 8rpx;
}

/* 开始按钮 */
.start-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  z-index: 100;
}

.start-btn {
  background: var(--color-primary);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(124, 111, 247, 0.35);
}

.start-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
