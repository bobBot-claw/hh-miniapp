/* pages/plan/detail/detail.wxss - 计划详情 v4.0 */
.page { min-height: 100vh; padding-bottom: 140rpx; }

.hero {
  position: relative; padding: 48rpx 36rpx 36rpx; overflow: hidden;
}
.hero-fade {
  position: absolute; bottom: 0; left: 0; right: 0; height: 100rpx;
  background: linear-gradient(to top, var(--bg), transparent);
}
.hero-title { font-size: 40rpx; font-weight: 800; color: #fff; display: block; margin-bottom: 8rpx; position: relative; z-index: 1; }
.hero-stats { display: flex; align-items: center; gap: 8rpx; position: relative; z-index: 1; font-size: 24rpx; color: rgba(255,255,255,0.7); }
.hero-stats .dot { opacity: 0.3; }
.hero-bar { height: 4rpx; background: rgba(255,255,255,0.15); border-radius: 2rpx; overflow: hidden; margin-top: 16rpx; position: relative; z-index: 1; }
.hero-bar-fill { height: 100%; background: #fff; border-radius: 2rpx; transition: width 0.4s ease; }

.cta-wrap { padding: 28rpx 36rpx; display: flex; justify-content: center; }

.phases { display: flex; gap: 12rpx; padding: 0 36rpx; margin-bottom: 16rpx; }
.phase-tab { padding: 10rpx 20rpx; font-size: 24rpx; color: var(--text-dim); border-radius: 8rpx; }
.phase-on { color: #fff; font-weight: 700; background: var(--primary-soft); }

.days { padding: 0 36rpx; }
.day { padding: 16rpx 0; border-bottom: 1rpx solid var(--line); }
.day-done { opacity: 0.4; }
.day-head { display: flex; align-items: center; gap: 12rpx; }
.day-num { font-size: 22rpx; font-weight: 800; color: var(--primary); width: 48rpx; }
.day-title { flex: 1; font-size: 26rpx; font-weight: 500; color: var(--text); }
.day-dur { font-size: 22rpx; color: var(--text-dim); }

.day-body { padding: 12rpx 0 4rpx 60rpx; }
.ex-row { display: flex; align-items: center; justify-content: space-between; padding: 10rpx 0; }
.ex-name { font-size: 24rpx; color: var(--text-dim); }
.ex-go { font-size: 22rpx; color: var(--text-dim); }
