<!--pages/plan/detail/detail.wxml - 计划详情 v4.0 — 极简·行动-->
<view class="page deep-bg" wx:if="{{plan}}">
  <view class="hero" style="background: {{plan.cover_gradient}}">
    <view class="hero-fade"></view>
    <text class="hero-title">{{plan.title}}</text>
    <view class="hero-stats">
      <text>{{plan.duration_days}}天</text>
      <text class="dot">·</text>
      <text>{{plan.difficulty}}</text>
      <text class="dot">·</text>
      <text>{{totalProgress}}%</text>
    </view>
    <view wx:if="{{started}}" class="hero-bar">
      <view class="hero-bar-fill" style="width: {{totalProgress}}%"></view>
    </view>
  </view>

  <view class="cta-wrap">
    <view class="cta" bindtap="onStartPlan"><text>{{started ? '继续训练' : '开始计划'}}</text></view>
  </view>

  <!-- 阶段 -->
  <view class="phases">
    <view wx:for="{{enrichedPhases}}" wx:key="title" class="phase-tab {{currentPhaseIndex === index ? 'phase-on' : ''}}" data-index="{{index}}" bindtap="onPhaseTap">
      <text>{{item.title}}</text>
    </view>
  </view>

  <!-- 日列表 -->
  <view class="days">
    <view wx:for="{{enrichedPhases[currentPhaseIndex].daily}}" wx:key="day"
      class="day {{completedDays.indexOf(item.day) >= 0 ? 'day-done' : ''}}"
      data-index="{{index}}" bindtap="onDayTap">
      <view class="day-head">
        <text class="day-num">{{completedDays.indexOf(item.day) >= 0 ? '✓' : 'D' + item.day}}</text>
        <text class="day-title">{{item.title}}</text>
        <text class="day-dur">{{item.duration_text}}</text>
      </view>
      <view wx:if="{{currentDayIndex === index}}" class="day-body">
        <view wx:for="{{item.exerciseList}}" wx:for-item="ex" wx:key="id" class="ex-row" data-id="{{ex.id}}" bindtap="onExerciseTap">
          <text class="ex-name">{{ex.title}}</text>
          <text class="ex-go">›</text>
        </view>
        <view wx:if="{{item.meditationItem}}" class="ex-row" data-id="{{item.meditationItem.id}}" bindtap="onMeditationTap">
          <text class="ex-name">🧘 {{item.meditationItem.title}}</text>
          <text class="ex-go">›</text>
        </view>
      </view>
    </view>
  </view>

  <view style="height:140rpx;"></view>
</view>
