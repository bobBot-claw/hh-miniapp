<view class="plan-detail" wx:if="{{plan}}">
  <!-- 头部封面 -->
  <view class="detail-hero" style="background: {{plan.cover_gradient}}">
    <view class="hero-top">
      <text class="hero-title">{{plan.title}}</text>
    </view>
    <view class="hero-stats">
      <view class="hero-stat">
        <text class="stat-value">{{plan.duration_days}}</text>
        <text class="stat-label">天</text>
      </view>
      <view class="hero-stat-divider"></view>
      <view class="hero-stat">
        <text class="stat-value">{{plan.difficulty}}</text>
        <text class="stat-label">难度</text>
      </view>
      <view class="hero-stat-divider"></view>
      <view class="hero-stat">
        <text class="stat-value">{{totalProgress}}%</text>
        <text class="stat-label">进度</text>
      </view>
    </view>
    <!-- 进度条 -->
    <view class="hero-progress-bar" wx:if="{{started}}">
      <view class="hero-progress-fill" style="width: {{totalProgress}}%"></view>
    </view>
  </view>

  <!-- 描述 -->
  <view class="detail-desc">
    <text>{{plan.description}}</text>
  </view>

  <!-- 能力值收益 -->
  <view class="detail-gains">
    <text class="section-label">完成后你将获得</text>
    <view class="gains-row">
      <text wx:if="{{plan.abilities_gain.posture}}" class="gain-item gain-posture">体态 +{{plan.abilities_gain.posture}}</text>
      <text wx:if="{{plan.abilities_gain.core}}" class="gain-item gain-core">核心 +{{plan.abilities_gain.core}}</text>
      <text wx:if="{{plan.abilities_gain.flexibility}}" class="gain-item gain-flex">柔韧 +{{plan.abilities_gain.flexibility}}</text>
      <text wx:if="{{plan.abilities_gain.vitality}}" class="gain-item gain-vitality">活力 +{{plan.abilities_gain.vitality}}</text>
      <text wx:if="{{plan.abilities_gain.mind_body}}" class="gain-item gain-mind">身心 +{{plan.abilities_gain.mind_body}}</text>
    </view>
  </view>

  <!-- 阶段切换 -->
  <view class="phase-tabs">
    <view 
      wx:for="{{enrichedPhases}}" 
      wx:key="title"
      class="phase-tab {{currentPhaseIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onPhaseTap"
    >
      <text class="phase-tab-title">{{item.title}}</text>
    </view>
  </view>

  <!-- 当天训练内容 -->
  <view class="daily-list">
    <view 
      wx:for="{{enrichedPhases[currentPhaseIndex].daily}}" 
      wx:key="day"
      class="day-card {{currentDayIndex === index ? 'expanded' : ''}} {{completedDays.indexOf(item.day) >= 0 ? 'day-completed' : ''}}"
      data-index="{{index}}"
      bindtap="onDayTap"
    >
      <view class="day-header">
        <view class="day-left">
          <view class="day-number {{completedDays.indexOf(item.day) >= 0 ? 'day-number-done' : ''}}">
            <text wx:if="{{completedDays.indexOf(item.day) >= 0}}" class="day-check">✓</text>
            <text wx:else>Day {{item.day}}</text>
          </view>
          <text class="day-title {{completedDays.indexOf(item.day) >= 0 ? 'day-title-done' : ''}}">{{item.title}}</text>
        </view>
        <view class="day-right">
          <text class="day-duration">{{item.duration_text}}</text>
          <view class="day-arrow {{currentDayIndex === index ? 'up' : ''}}"></view>
        </view>
      </view>

      <!-- 展开内容 -->
      <view class="day-content" wx:if="{{currentDayIndex === index}}">
        <view class="day-section-label">训练动作</view>
        <view 
          wx:for="{{item.exerciseList}}" 
          wx:for-item="ex" 
          wx:key="id"
          class="exercise-row"
          data-id="{{ex.id}}"
          bindtap="onExerciseTap"
        >
          <view class="exercise-icon-wrap" style="background: {{plan.cover_gradient}}">
            <text class="exercise-icon-text">{{ex.category === 'core' ? '核' : ex.category === 'posture' ? '态' : ex.category === 'flexibility' ? '柔' : ex.category === 'energy' ? '能' : ex.category === 'stress' ? '压' : ex.category === 'sleep' ? '眠' : '微'}}</text>
          </view>
          <view class="exercise-info">
            <text class="exercise-name">{{ex.title}}</text>
            <text class="exercise-meta">{{ex.duration || 0}}分钟 · {{ex.difficulty || '入门'}}</text>
          </view>
          <view class="exercise-go"></view>
        </view>

        <!-- 冥想 -->
        <view wx:if="{{item.meditationItem}}" class="day-section-label meditation-label">冥想放松</view>
        <view 
          wx:if="{{item.meditationItem}}"
          class="exercise-row meditation-row"
          data-id="{{item.meditationItem.id}}"
          bindtap="onMeditationTap"
        >
          <view class="exercise-icon-wrap meditation-icon">
            <text class="exercise-icon-text">冥</text>
          </view>
          <view class="exercise-info">
            <text class="exercise-name">{{item.meditationItem.title}}</text>
            <text class="exercise-meta">{{item.meditationItem.duration}}分钟</text>
          </view>
          <view class="exercise-go"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 开始按钮 -->
  <view class="start-bar">
    <view class="start-btn" bindtap="onStartPlan">
      <text>{{started ? '继续训练' : '开始计划'}}</text>
    </view>
  </view>
</view>
