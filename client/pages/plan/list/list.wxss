/* pages/plan/list/list.wxss - 训练计划 v4.0 */
.page { min-height: 100vh; padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }
.tags { white-space: nowrap; padding: 24rpx 36rpx 16rpx; }
.tag-row { display: inline-flex; gap: 16rpx; }
.tag { font-size: 24rpx; color: var(--text-dim); padding: 6rpx 0; }
.tag-on { color: #fff; font-weight: 700; }

.list { padding: 0 36rpx; }
.item {
  margin-bottom: 16rpx; overflow: hidden;
  background: var(--surface); border-radius: 16rpx;
}
.item-cover {
  padding: 32rpx 28rpx 24rpx;
  display: flex; flex-direction: column; justify-content: flex-end;
}
.item-title { font-size: 32rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 4rpx; }
.item-sub { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; }
.item-desc {
  padding: 16rpx 28rpx 20rpx;
  font-size: 24rpx; color: var(--text-dim); line-height: 1.5;
}
