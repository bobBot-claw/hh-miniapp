/* pages/plan/list/list.wxss - 训练计划列表 v3.0 — 深空沉浸 */
.plan-list { min-height: 100vh; padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }

/* 筛选栏 */
.filter-bar { white-space: nowrap; padding: 24rpx 32rpx 16rpx; }

/* 计划卡片列表 */
.plan-cards { padding: 16rpx 32rpx; }

.plan-card { overflow: hidden; margin-bottom: 32rpx; }

/* 封面 */
.plan-cover {
  padding: 40rpx 32rpx 32rpx;
  position: relative; min-height: 180rpx;
}
.plan-cover-glow {
  position: absolute; top: -20%; right: -10%;
  width: 200rpx; height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.plan-title { display: block; font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; position: relative; z-index: 1; }
.plan-subtitle { display: block; font-size: 26rpx; color: rgba(255,255,255,0.75); position: relative; z-index: 1; }

/* 信息区 */
.plan-info { padding: 28rpx 32rpx; }
.plan-desc { display: block; font-size: 26rpx; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 20rpx; }
.plan-gains { display: flex; flex-wrap: wrap; gap: 12rpx; }
