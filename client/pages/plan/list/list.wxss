.plan-list {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 筛选栏 */
.filter-bar {
  white-space: nowrap;
  padding: 24rpx 32rpx 16rpx;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-card);
  margin-right: 16rpx;
  transition: all 0.2s;
}

.filter-tag.active {
  color: #fff;
  background: var(--color-primary);
}

/* 计划卡片列表 */
.plan-cards {
  padding: 16rpx 32rpx;
}

.plan-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 封面 */
.plan-cover {
  padding: 40rpx 32rpx 32rpx;
  position: relative;
  min-height: 180rpx;
}

.plan-cover-content {
  /* 简化后只保留标题+天数难度 */
}

.plan-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.plan-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 信息区 */
.plan-info {
  padding: 28rpx 32rpx;
}

.plan-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

/* 能力值收益 */
.plan-gains {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gain-badge {
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.gain-posture {
  color: #e17055;
  background: rgba(225, 112, 85, 0.1);
}

.gain-core {
  color: #00b894;
  background: rgba(0, 184, 148, 0.1);
}

.gain-flex {
  color: #6c5ce7;
  background: rgba(108, 92, 231, 0.1);
}

.gain-vitality {
  color: #f39c12;
  background: rgba(243, 156, 18, 0.1);
}

.gain-mind {
  color: #a29bfe;
  background: rgba(162, 155, 254, 0.1);
}
