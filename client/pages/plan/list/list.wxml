<!--pages/plan/list/list.wxml - 训练计划 v4.0 — 极简-->
<view class="page deep-bg">
  <scroll-view scroll-x class="tags">
    <view class="tag-row">
      <text wx:for="{{filterTags}}" wx:key="index" class="tag {{activeFilter === index ? 'tag-on' : ''}}" data-index="{{index}}" bindtap="onFilterTap">{{item}}</text>
    </view>
  </scroll-view>

  <view class="list">
    <view wx:for="{{plans}}" wx:key="id" class="item" data-id="{{item.id}}" bindtap="onPlanTap">
      <view class="item-cover" style="background: {{item.cover_gradient}}">
        <text class="item-title">{{item.title}}</text>
        <text class="item-sub">{{item.duration_days}}天 · {{item.difficulty}}</text>
      </view>
      <text class="item-desc">{{item.description}}</text>
    </view>
  </view>
</view>
