<view class="plan-list">
  <!-- 顶部筛选 -->
  <scroll-view class="filter-bar" scroll-x enable-flex>
    <view 
      wx:for="{{filterTags}}" 
      wx:key="index"
      class="filter-tag {{activeFilter === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onFilterTap"
    >{{item}}</view>
  </scroll-view>

  <!-- 计划卡片 -->
  <view class="plan-cards">
    <view 
      wx:for="{{plans}}" 
      wx:key="id"
      class="plan-card"
      data-id="{{item.id}}"
      bindtap="onPlanTap"
    >
      <!-- 封面区 -->
      <view class="plan-cover" style="background: {{item.cover_gradient}}">
        <view class="plan-cover-content">
          <text class="plan-title">{{item.title}}</text>
          <text class="plan-subtitle">{{item.subtitle}}</text>
        </view>
        <view class="plan-meta-row">
          <text class="plan-meta">{{item.duration_days}}天</text>
          <text class="plan-meta-dot">·</text>
          <text class="plan-meta">{{item.difficulty}}</text>
        </view>
      </view>

      <!-- 信息区 -->
      <view class="plan-info">
        <text class="plan-desc">{{item.description}}</text>
        <view class="plan-tags">
          <text wx:for="{{item.problem_tags}}" wx:for-item="tag" wx:key="*this" class="plan-tag">{{tag}}</text>
        </view>
        <!-- 能力值收益 -->
        <view class="plan-gains">
          <text wx:if="{{item.abilities_gain.posture}}" class="gain-badge gain-posture">体态 +{{item.abilities_gain.posture}}</text>
          <text wx:if="{{item.abilities_gain.core}}" class="gain-badge gain-core">核心 +{{item.abilities_gain.core}}</text>
          <text wx:if="{{item.abilities_gain.flexibility}}" class="gain-badge gain-flex">柔韧 +{{item.abilities_gain.flexibility}}</text>
          <text wx:if="{{item.abilities_gain.vitality}}" class="gain-badge gain-vitality">活力 +{{item.abilities_gain.vitality}}</text>
          <text wx:if="{{item.abilities_gain.mind_body}}" class="gain-badge gain-mind">身心 +{{item.abilities_gain.mind_body}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
