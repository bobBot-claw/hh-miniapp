<!--pages/habit/list/list.wxml - 深空沉浸版-->
<view class="page-habit-list deep-bg">
  <view class="header flex-between">
    <text class="page-title">我的习惯</text>
    <view class="holo-tag holo-tag-active" bindtap="onCreateHabit">
      <text>+ 添加习惯</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-secondary">加载中...</text>
  </view>

  <block wx:else>
    <view wx:if="{{habits.length === 0}}" class="empty-state">
      <text class="empty-icon">✅</text>
      <text class="empty-text">还没有习惯，添加一个开始吧</text>
    </view>

    <view wx:else class="habit-cards">
      <view
        wx:for="{{habits}}" wx:key="id"
        class="habit-card glow-card {{item.todayChecked ? 'habit-checked' : ''}}"
        data-id="{{item.id}}" bindtap="onHabitDetail"
      >
        <view class="flex-between">
          <view class="flex-row" style="gap:16rpx;">
            <text style="font-size:40rpx;">{{item.icon}}</text>
            <view class="flex-col">
              <text style="font-weight:600; color:var(--color-text);">{{item.name}}</text>
              <text wx:if="{{item.streak > 0}}" class="text-sm text-accent">🔥 连续 {{item.streak}} 天</text>
            </view>
          </view>
          <view
            wx:if="{{!item.todayChecked}}"
            class="checkin-btn" data-id="{{item.id}}" data-index="{{index}}" catchtap="onCheckin"
          >
            <text>打卡</text>
          </view>
          <text wx:else style="font-size:32rpx;">✅</text>
        </view>
      </view>
    </view>
  </block>
</view>
