<!--pages/habit/list/list.wxml - 极简版-->
<view class="page deep-bg">
  <view class="header flex-between">
    <text class="title">习惯</text>
    <view class="tag tag-on" bindtap="onCreateHabit"><text>+ 添加</text></view>
  </view>

  <view wx:if="{{loading}}" class="empty"><text class="text-dim">加载中</text></view>
  <block wx:else>
    <view wx:if="{{habits.length === 0}}" class="empty"><text class="text-dim">还没有习惯</text></view>
    <view wx:else class="list">
      <view wx:for="{{habits}}" wx:key="id" class="item {{item.todayChecked ? 'item-done' : ''}}" data-id="{{item.id}}" bindtap="onHabitDetail">
        <text class="item-icon">{{item.icon}}</text>
        <text class="item-name">{{item.name}}</text>
        <text wx:if="{{item.streak > 0}}" class="item-streak">🔥{{item.streak}}</text>
        <view wx:if="{{!item.todayChecked}}" class="checkin" data-id="{{item.id}}" data-index="{{index}}" catchtap="onCheckin"><text>打卡</text></view>
        <text wx:else class="checked">✓</text>
      </view>
    </view>
  </block>
</view>
