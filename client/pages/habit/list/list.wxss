/* pages/habit/list/list.wxss - 极简版 */
.page { min-height: 100vh; padding: 32rpx 36rpx; }
.header { margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: 700; color: var(--text); }
.tag-on { color: #fff !important; font-weight: 600; }

.list { }
.item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 18rpx 0; border-bottom: 1rpx solid var(--line);
}
.item-done { opacity: 0.4; }
.item-icon { font-size: 32rpx; }
.item-name { flex: 1; font-size: 28rpx; color: var(--text); font-weight: 500; }
.item-streak { font-size: 22rpx; color: var(--primary); }
.checkin {
  padding: 6rpx 20rpx; border-radius: 20rpx;
  background: var(--primary); color: #fff; font-size: 22rpx; font-weight: 600;
}
.checked { font-size: 28rpx; color: var(--accent); }

.empty { display: flex; justify-content: center; padding: 120rpx 0; }
