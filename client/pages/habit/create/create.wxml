<!--pages/habit/create/create.wxml-->
<view class="page-create" style="padding:32rpx;min-height:100vh;background:var(--color-bg);">
  <text class="text-md" style="font-weight:700;display:block;margin-bottom:32rpx;">选择一个习惯</text>
  <view style="display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx;margin-bottom:40rpx;">
    <view
      wx:for="{{templates}}"
      wx:key="name"
      class="template-card {{selected === index ? 'template-selected' : ''}}"
      data-index="{{index}}"
      bindtap="onSelectTemplate"
    >
      <text style="font-size:40rpx;">{{item.icon}}</text>
      <text style="font-size:26rpx;margin-top:8rpx;">{{item.name}}</text>
    </view>
  </view>
  <text class="text-md" style="font-weight:700;display:block;margin-bottom:16rpx;">或自定义</text>
  <input
    class="custom-input"
    placeholder="输入习惯名称"
    value="{{customName}}"
    bindinput="onCustomInput"
  />
  <view class="btn-primary" style="margin-top:48rpx;text-align:center;" bindtap="onCreate">
    <text>创建习惯</text>
  </view>
</view>
