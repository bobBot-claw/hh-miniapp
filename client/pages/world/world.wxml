<!--pages/world/world.wxml — 渐进微调：与 demo 屏4 完全一致-->

<view class="page">

  <!-- 暖色光晕 -->
  <view class="halo halo-1"></view>
  <view class="halo halo-2"></view>

  <scroll-view scroll-y class="scroll">

    <!-- 顶部行 -->
    <view class="top-row">
      <view class="back-btn" bindtap="goBack">
        <view class="back-arrow"></view>
      </view>
      <text class="brand-l">慢 慢 变 好</text>
      <text class="day-l">我 的 · 微 动 作 进 阶</text>
    </view>

    <!-- 微调卡片 — demo: .delta-card -->
    <view class="delta-card">
      <text class="dc-t">周 三 · 快 走</text>
      <view class="delta-row">
        <text class="wk">第 1 周</text>
        <text class="val">12 分</text>
        <text class="arr">基 线</text>
      </view>
      <view class="delta-row">
        <text class="wk">第 2 周</text>
        <text class="val">14 分</text>
        <text class="arr">+ 2</text>
      </view>
      <view class="delta-row">
        <text class="wk">第 3 周</text>
        <text class="val">15 分</text>
        <text class="arr">+ 1</text>
        <text class="now-mark">今 日</text>
      </view>
    </view>

    <!-- 数据网格 — demo: .data-grid -->
    <view class="data-grid">
      <view class="data-card">
        <text class="dc-k">累 计 出 汗</text>
        <text class="dc-m">{{sweatCount}} <text class="unit">次</text></text>
        <text class="dc-d">每 周 平 均 {{avgPerWeek}} 次</text>
      </view>
      <view class="data-card">
        <text class="dc-k">认 知 卡 片</text>
        <text class="dc-m">{{knowCount}} <text class="unit">张</text></text>
        <text class="dc-d">{{weekNum}} 周 累 积</text>
      </view>
    </view>

    <!-- 隐私说明 — demo: .explain -->
    <view class="explain" style="margin-top: 48rpx;">
      <text class="privacy-tag">隐 私 · 不 暴 露</text>
      <text class="explain-text">只 有 你 自 己 看 得 到 · 没 有 排 名 · 没 有 比 较 · 你 今 天 的 15 分 = 你 上 周 的 14 分 + 1</text>
    </view>

    <view style="height: 80rpx;"></view>
  </scroll-view>

</view>
