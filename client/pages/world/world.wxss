/* pages/world/world.wxss — 渐进微调：与 demo 屏4 完全一致 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  background: var(--bg);
}

/* 暖色光晕 */
.halo {
  position: fixed; pointer-events: none; z-index: 0;
  border-radius: 50%; filter: blur(140px); opacity: 0.5;
}
.halo-1 { width: 680px; height: 680px; background: var(--halo-cream); top: -200px; right: -200px; }
.halo-2 { width: 480px; height: 480px; background: var(--halo-gold); bottom: -200px; left: -200px; opacity: 0.3; }

.scroll {
  position: relative; z-index: 1;
  height: 100vh;
  padding: 72rpx 44rpx 0;
}

/* 顶部行 */
.top-row {
  display: flex; align-items: center; gap: 24rpx;
  margin-bottom: 44rpx;
}
.back-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--surface);
  border: 1rpx solid var(--line);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.back-arrow {
  width: 16rpx; height: 16rpx;
  border-left: 3rpx solid var(--ink-mute);
  border-bottom: 3rpx solid var(--ink-mute);
  transform: rotate(45deg);
  margin-left: 6rpx;
}
.brand-l { font-size: 22rpx; letter-spacing: 0.3em; color: var(--ink-mute); }
.day-l { font-size: 22rpx; letter-spacing: 0.2em; color: var(--ink-dim); }

/* 微调卡片 — demo: .delta-card */
.delta-card {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 40rpx;
  padding: 40rpx;
  margin-bottom: 28rpx;
}
.dc-t {
  font-size: 28rpx; color: var(--ink); font-weight: 400;
  margin-bottom: 28rpx; letter-spacing: 0.04em;
  display: block;
}
.delta-row {
  display: flex; align-items: center;
  gap: 28rpx; padding: 20rpx 0;
  border-top: 1rpx dashed var(--line);
}
.delta-row:first-of-type { border-top: none; }
.wk {
  flex: 0 0 112rpx;
  font-size: 22rpx; letter-spacing: 0.2em; color: var(--ink-mute);
}
.val {
  flex: 1;
  font-size: 36rpx; font-weight: 300; letter-spacing: 0.04em;
  color: var(--ink);
}
.arr {
  font-size: 24rpx; color: var(--gold); margin: 0 8rpx;
}
.now-mark {
  font-size: 20rpx; color: var(--gold); margin-left: 12rpx;
}

/* 数据网格 — demo: .data-grid */
.data-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 28rpx;
  margin-bottom: 36rpx;
}
.data-card {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 36rpx;
}
.dc-k {
  font-size: 22rpx; letter-spacing: 0.24em; color: var(--ink-dim);
  margin-bottom: 20rpx; display: block;
}
.dc-m {
  font-size: 48rpx; font-weight: 300; letter-spacing: 0.04em; color: var(--ink);
  margin-bottom: 12rpx; display: block;
}
.unit {
  font-size: 24rpx; color: var(--ink-mute); margin-left: 6rpx;
}
.dc-d {
  font-size: 24rpx; color: var(--gold); letter-spacing: 0.04em;
  display: block;
}

/* 说明 */
.explain {
  font-size: 26rpx;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
  line-height: 1.85;
  padding: 28rpx 36rpx;
  background: var(--warm);
  border-radius: 36rpx;
}
.privacy-tag {
  font-size: 22rpx; color: var(--gold); letter-spacing: 0.24em;
  margin-bottom: 12rpx; display: block;
}
.explain-text {
  display: block;
}
