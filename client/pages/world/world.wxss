/* pages/world/world.wxss — 我的世界：12主题世界+插画收藏 v0.7 demo 风格 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
}

/* ═══ 顶 bar ═══ */
.top-bar {
  position: absolute; top: 0; left: 0; right: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 100rpx 48rpx 0;
  z-index: 10;
}
.back-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex; align-items: center; justify-content: center;
}
.back-arrow {
  width: 16rpx; height: 16rpx;
  border-left: 3rpx solid rgba(42, 40, 32, 0.6);
  border-bottom: 3rpx solid rgba(42, 40, 32, 0.6);
  transform: rotate(45deg);
  margin-left: 6rpx;
}

/* ═══ 世界列表视图 ═══ */
.world-view {
  position: relative; z-index: 5;
}

/* 标题行 */
.title-row {
  display: flex; align-items: baseline; justify-content: space-between;
  padding: 200rpx 48rpx 48rpx;
}
.page-title {
  font-size: 40rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 0.2em;
}
.page-meta {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.5);
  letter-spacing: 0.2em;
}

/* 网格 */
.grid-scroll {
  height: calc(100vh - 340rpx);
  padding: 0 48rpx;
}
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

/* ═══ 世界卡片 — demo 毛玻璃 ═══ */
.world-card {
  position: relative;
  aspect-ratio: 1;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  padding: 28rpx;
  display: flex; flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  transition: transform 0.3s ease;
}
.world-card:active { transform: scale(0.98); }

.card-active {
  background: linear-gradient(135deg, rgba(212, 183, 121, 0.25), rgba(201, 166, 107, 0.15));
  border: 1rpx solid rgba(212, 183, 121, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(201, 166, 107, 0.2);
}
.card-locked {
  opacity: 0.5;
}

/* 图标 — 单色线条 */
.world-icon-wrap {
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
}
.icon-line {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid var(--gold-500);
  position: relative;
}
.icon-forest::before {
  content: '';
  position: absolute; bottom: -16rpx; left: 50%;
  width: 3rpx; height: 20rpx;
  background: var(--gold-500);
  transform: translateX(-50%);
}
.icon-sea {
  border-color: var(--brand-600);
}
.icon-sea::before {
  content: '';
  position: absolute; bottom: 6rpx; left: 4rpx; right: 4rpx;
  height: 3rpx;
  background: var(--brand-600);
  border-radius: 50%;
}
.icon-window {
  position: relative;
}
.icon-window::before, .icon-window::after {
  content: '';
  position: absolute;
  background: var(--gold-500);
}
.icon-window::before {
  top: -4rpx; bottom: -4rpx; left: 50%;
  width: 3rpx; transform: translateX(-50%);
}
.icon-window::after {
  left: -4rpx; right: -4rpx; top: 50%;
  height: 3rpx; transform: translateY(-50%);
}
.icon-warm {
  border-color: #D4755A;
}
.icon-warm::before {
  content: '';
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx; height: 16rpx;
  background: #D4755A;
  border-radius: 4rpx;
}
.icon-tea::before {
  content: '';
  position: absolute; top: 50%; left: 4rpx; right: 4rpx;
  height: 3rpx;
  background: var(--gold-500);
}
.icon-night {
  border-color: #5B6AAF;
  background: transparent;
}
.icon-night::before {
  content: '';
  position: absolute; top: 8rpx; right: 8rpx;
  width: 6rpx; height: 6rpx;
  background: #5B6AAF;
  border-radius: 50%;
}
.icon-default {
  border-color: var(--neutral-200);
}

/* 世界信息 */
.world-info {
  display: flex; flex-direction: column;
}
.world-name {
  font-size: 24rpx; font-weight: 500;
  color: var(--neutral-900);
  letter-spacing: 0.15em;
  line-height: 1.4;
}
.world-progress {
  font-size: 20rpx;
  color: rgba(42, 40, 32, 0.5);
  letter-spacing: 0.15em;
  margin-top: 4rpx;
}
.card-active .world-progress {
  color: var(--gold-600);
  font-weight: 500;
}

/* 探索中标记 */
.badge {
  position: absolute; top: 16rpx; right: 16rpx;
  background: var(--brand-600);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  letter-spacing: 0.1em;
  font-weight: 500;
}

/* ═══ 插画收藏视图 ═══ */
.gallery-view {
  position: relative; z-index: 5;
}

.gallery-header {
  display: flex; align-items: center; gap: 24rpx;
  padding: 100rpx 48rpx 32rpx;
}
.gallery-title {
  font-size: 36rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 0.2em;
  flex: 1;
}
.gallery-meta {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.5);
  letter-spacing: 0.15em;
}

.gallery-scroll {
  height: calc(100vh - 200rpx);
  padding: 0 48rpx;
}

/* 插画网格 */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

/* 已揭示的插画卡片 */
.egg-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  aspect-ratio: 3/4;
  background: rgba(255, 255, 255, 0.4);
}
.egg-img {
  width: 100%; height: 100%;
}
.egg-num {
  position: absolute; bottom: 12rpx; left: 0; right: 0;
  text-align: center;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 0.15em;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
}

/* 未揭示的插画 */
.egg-locked {
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1rpx dashed rgba(42, 40, 32, 0.15);
}
.egg-blur {
  width: 100%; height: 100%;
  background: rgba(201, 166, 107, 0.08);
}
.egg-num-dim {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 36rpx; font-weight: 300;
  color: rgba(42, 40, 32, 0.15);
  letter-spacing: 0.2em;
}

/* 空态 */
.empty {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 160rpx 0;
}
.empty-flame {
  width: 96rpx; height: 96rpx;
  background: radial-gradient(circle, rgba(232, 232, 232, 0.5) 0%, transparent 65%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 32rpx;
}
.empty-icon {
  font-size: 48rpx;
  color: var(--text-tertiary);
}
.empty-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.2em;
}
