/* pages/world/world.wxss — 治愈世界：12主题世界网格 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
}

/* 顶部 */
.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 100rpx 48rpx 0;
}
.back-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex; align-items: center; justify-content: center;
}
.back-arrow {
  width: 16rpx; height: 16rpx;
  border-left: 3rpx solid rgba(42, 40, 32, 0.6);
  border-bottom: 3rpx solid rgba(42, 40, 32, 0.6);
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.title-row {
  display: flex; align-items: baseline; justify-content: space-between;
  padding: 40rpx 48rpx 48rpx;
}
.page-title {
  font-size: 44rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 6rpx;
}
.page-meta {
  font-size: 24rpx;
  color: rgba(42, 40, 32, 0.5);
  letter-spacing: 4rpx;
}

/* 网格 */
.grid-scroll {
  height: calc(100vh - 280rpx);
  padding: 0 48rpx;
}
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

/* 世界卡片 */
.world-card {
  position: relative;
  aspect-ratio: 1;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  padding: 28rpx;
  display: flex; flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  transition: transform 0.3s ease;
}
.world-card:active { transform: scale(0.98); }

.card-active {
  background: linear-gradient(135deg, rgba(212, 183, 121, 0.2), rgba(201, 166, 107, 0.1));
  border: 1rpx solid rgba(212, 183, 121, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(201, 166, 107, 0.15);
}
.card-locked {
  opacity: 0.45;
}

/* 图标 — 单色线条 */
.world-icon-wrap {
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
}
/* 各世界线条图标 — 用 CSS 画 */
.icon-line {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid var(--gold-500);
}
/* 森林：圆+竖线 */
.icon-forest {
  border-radius: 50%;
  position: relative;
}
.icon-forest::before {
  content: '';
  position: absolute; bottom: -16rpx; left: 50%;
  width: 3rpx; height: 20rpx;
  background: var(--gold-500);
  transform: translateX(-50%);
}
/* 海边：圆+波浪 */
.icon-sea {
  border-radius: 50%;
  border: 3rpx solid var(--brand-600);
  position: relative;
}
.icon-sea::before {
  content: '';
  position: absolute; bottom: 6rpx; left: 4rpx; right: 4rpx;
  height: 3rpx;
  background: var(--brand-600);
  border-radius: 50%;
}
/* 窗边：圆+十字 */
.icon-window {
  position: relative;
}
.icon-window::before, .icon-window::after {
  content: '';
  position: absolute;
  background: var(--gold-500);
}
.icon-window::before {
  top: -4rpx; bottom: -4rpx; left: 50%;
  width: 3rpx; transform: translateX(-50%);
}
.icon-window::after {
  left: -4rpx; right: -4rpx; top: 50%;
  height: 3rpx; transform: translateY(-50%);
}
/* 暖屋：圆+内部小方块 */
.icon-warm {
  border: 3rpx solid #D4755A;
  position: relative;
}
.icon-warm::before {
  content: '';
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx; height: 16rpx;
  background: #D4755A;
  border-radius: 4rpx;
}
/* 茶书：圆+横线 */
.icon-tea {
  position: relative;
}
.icon-tea::before {
  content: '';
  position: absolute; top: 50%; left: 4rpx; right: 4rpx;
  height: 3rpx;
  background: var(--gold-500);
}
/* 夜星：圆+点 */
.icon-night {
  position: relative;
  background: transparent;
  border: 3rpx solid #5B6AAF;
}
.icon-night::before {
  content: '';
  position: absolute; top: 8rpx; right: 8rpx;
  width: 6rpx; height: 6rpx;
  background: #5B6AAF;
  border-radius: 50%;
}
/* 默认：纯圆 */
.icon-default {
  border: 3rpx solid var(--neutral-200);
}

/* 世界信息 */
.world-info {
  display: flex; flex-direction: column;
}
.world-name {
  font-size: 26rpx; font-weight: 500;
  color: var(--neutral-900);
  letter-spacing: 3rpx;
  line-height: 1.4;
}
.world-progress {
  font-size: 22rpx;
  color: rgba(42, 40, 32, 0.5);
  letter-spacing: 3rpx;
  margin-top: 4rpx;
}
.card-active .world-progress {
  color: var(--gold-600);
  font-weight: 500;
}

/* 探索中标记 */
.badge {
  position: absolute; top: 16rpx; right: 16rpx;
  background: var(--brand-600);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  letter-spacing: 2rpx;
  font-weight: 500;
}
