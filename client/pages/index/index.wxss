/* pages/index/index.wxss - 首页 v4.2 - 练习卡片精简 */

.page-index { min-height: 100vh; background: var(--color-bg); }
.home-scroll { height: 100vh; }

/* ===== 顶部状态条 ===== */
.top-bar {
  display: flex; justify-content: flex-start; align-items: center;
  padding: 16rpx 36rpx 4rpx;
}
.top-bar-left { display: flex; align-items: center; gap: 12rpx; }
.top-stat {
  font-size: 22rpx; color: var(--color-text-secondary); font-weight: 500;
  padding: 6rpx 14rpx; background: var(--color-bg-card); border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
}

/* ===== 通用分区标题行 ===== */
.section-title-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 36rpx; margin-bottom: 20rpx;
}
.section-title-lg {
  font-size: 40rpx; font-weight: 800; color: var(--color-text);
  letter-spacing: -0.5rpx;
}
.section-title-md {
  font-size: 30rpx; font-weight: 700; color: var(--color-text);
}
.section-more {
  display: flex; align-items: center; gap: 4rpx;
  padding: 8rpx 16rpx; border-radius: 20rpx;
  background: var(--color-bg-card); border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.section-more-text { font-size: 22rpx; color: var(--color-text-secondary); font-weight: 500; }
.section-more-icon { font-size: 24rpx; color: var(--color-text-secondary); }

/* ===== 今日训练（无计划时） ===== */
.today-section { margin-top: 4rpx; }

.hero-card { padding: 0 36rpx; }
.hero-cover {
  position: relative; border-radius: 28rpx; min-height: 440rpx;
  display: flex; flex-direction: column; justify-content: flex-end;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  border: 1rpx solid var(--color-border);
}
.hero-overlay {
  position: relative; z-index: 1; padding: 32rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  border-radius: 0 0 28rpx 28rpx;
  margin-top: auto;
  display: flex; align-items: flex-end; justify-content: space-between; gap: 24rpx;
}
.hero-info-left { flex: 1; min-width: 0; }
.hero-duration {
  font-size: 22rpx; color: rgba(255,255,255,0.6); display: block; margin-bottom: 8rpx; font-weight: 500;
}
.hero-title {
  font-size: 42rpx; font-weight: 800; color: #fff; display: block;
  line-height: 1.2; letter-spacing: -0.5rpx;
}
.hero-start-btn {
  display: inline-flex; align-items: center; justify-content: center;
  background: #fff; color: var(--color-primary-dark); padding: 20rpx 44rpx; border-radius: 44rpx;
  font-size: 26rpx; font-weight: 700; flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

/* ═══════════════════════════════════════════════
   计划进度大卡片 — 第一屏核心
   ═══════════════════════════════════════════════ */

.plan-hero-card {
  margin: 0 24rpx;
  background: var(--color-bg-card);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.1);
  border: 1rpx solid var(--color-border);
}

.plan-hero-cover {
  padding: 40rpx 36rpx 32rpx;
  position: relative;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.plan-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.plan-hero-name {
  font-size: 34rpx; font-weight: 800; color: #fff; letter-spacing: -0.5rpx;
}
.plan-hero-phase {
  font-size: 22rpx; color: rgba(255,255,255,0.75);
  background: rgba(255,255,255,0.18);
  padding: 6rpx 16rpx; border-radius: 14rpx;
  font-weight: 500;
}

.plan-hero-day {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.plan-hero-daynum {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center;
  width: 120rpx; height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 28rpx;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255,255,255,0.25);
  flex-shrink: 0;
}
.plan-hero-daynum-label {
  font-size: 18rpx; color: rgba(255,255,255,0.7); font-weight: 600;
  letter-spacing: 3rpx;
}
.plan-hero-daynum-value {
  font-size: 56rpx; color: #fff; font-weight: 900; line-height: 1;
  margin-top: 4rpx;
}
.plan-hero-day-info {
  flex: 1; min-width: 0;
}
.plan-hero-day-title {
  font-size: 36rpx; font-weight: 800; color: #fff; display: block;
  line-height: 1.2; margin-bottom: 6rpx;
}
.plan-hero-day-duration {
  font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; font-weight: 500;
}
.plan-hero-start-btn {
  display: inline-flex; align-items: center; justify-content: center;
  background: #fff; color: #1a1a2e; padding: 22rpx 40rpx; border-radius: 44rpx;
  font-size: 28rpx; font-weight: 700; flex-shrink: 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.18);
}

.plan-hero-chips {
  display: flex; flex-wrap: wrap; gap: 10rpx;
}
.plan-chip {
  padding: 6rpx 18rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 12rpx;
  font-size: 22rpx; color: rgba(255,255,255,0.9);
  font-weight: 500;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  border: 1rpx solid rgba(255,255,255,0.1);
}
.plan-chip-meditation {
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.18);
}

.plan-hero-footer {
  padding: 24rpx 36rpx 28rpx;
}
.plan-progress-visual {
  margin-bottom: 12rpx;
}
.plan-dots {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.plan-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}
.plan-dot-done {
  background: var(--color-primary);
  box-shadow: 0 2rpx 6rpx rgba(124, 111, 247, 0.3);
}
.plan-dot-current {
  background: var(--color-primary);
  opacity: 0.5;
  animation: pulse-dot 1.5s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}
.plan-progress-info {
  display: flex; justify-content: space-between; align-items: center;
}
.plan-progress-text {
  font-size: 22rpx; color: var(--color-text-secondary); font-weight: 500;
}
.plan-progress-pct {
  font-size: 22rpx; color: var(--color-primary); font-weight: 700;
}

/* ═══════════════════════════════════════════════
   计划完成庆祝卡片
   ═══════════════════════════════════════════════ */

.plan-complete-card {
  display: flex; align-items: center; gap: 20rpx;
  margin: 0 36rpx; padding: 28rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  border: 2rpx solid #00b894;
  box-shadow: 0 4rpx 20rpx rgba(0, 184, 148, 0.15);
}
.plan-complete-icon {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: linear-gradient(135deg, #00b894, #55efc4);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.plan-complete-icon-text { font-size: 36rpx; color: #fff; font-weight: 900; }
.plan-complete-info { flex: 1; min-width: 0; }
.plan-complete-title {
  font-size: 28rpx; font-weight: 700; color: var(--color-text); display: block; margin-bottom: 4rpx;
}
.plan-complete-sub {
  font-size: 22rpx; color: var(--color-text-secondary); display: block;
}

/* ═══════════════════════════════════════════════
   能力值模块
   ═══════════════════════════════════════════════ */

.abilities-section { margin-top: 28rpx; }

.abilities-scroll { white-space: nowrap; padding-left: 36rpx; }
.abilities-row { display: inline-flex; gap: 12rpx; padding-right: 36rpx; }

.ability-card {
  display: inline-flex; flex-direction: column;
  width: 180rpx;
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 20rpx;
  flex-shrink: 0;
  border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.ability-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.ability-name {
  font-size: 22rpx; font-weight: 600; color: var(--color-text);
}
.ability-level {
  font-size: 18rpx; font-weight: 700; color: var(--color-primary);
  background: rgba(124, 111, 247, 0.08);
  padding: 2rpx 8rpx; border-radius: 6rpx;
}
.ability-bar-bg {
  height: 8rpx; border-radius: 4rpx;
  background: rgba(0, 0, 0, 0.05);
  overflow: hidden;
  margin-bottom: 8rpx;
}
.ability-bar-fill {
  height: 100%; border-radius: 4rpx;
  transition: width 0.6s ease;
}
.ability-value {
  font-size: 32rpx; font-weight: 800; color: var(--color-text);
  letter-spacing: -1rpx; line-height: 1;
}

/* ===== 训练计划 ===== */
.plan-section { margin-top: 28rpx; }

.plan-scroll { white-space: nowrap; padding-left: 36rpx; }
.plan-cards-row { display: inline-flex; gap: 16rpx; padding-right: 36rpx; }

.plan-card-mini {
  display: inline-flex; flex-direction: column; width: 280rpx;
  background: var(--color-bg-card); border-radius: 20rpx; overflow: hidden;
  flex-shrink: 0; border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  position: relative;
}
.plan-card-mini.plan-active {
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 20rpx rgba(124, 111, 247, 0.2);
}
.plan-mini-cover {
  padding: 28rpx 20rpx 20rpx; min-height: 140rpx;
  display: flex; flex-direction: column; justify-content: flex-end;
  position: relative;
}
.plan-mini-title {
  font-size: 28rpx; font-weight: 700; color: #fff; display: block;
  line-height: 1.3; margin-bottom: 6rpx;
}
.plan-mini-sub {
  font-size: 22rpx; color: rgba(255,255,255,0.75); display: block;
}
.plan-mini-badge {
  position: absolute; top: 12rpx; right: 12rpx;
  background: #fff; color: var(--color-primary);
  padding: 4rpx 12rpx; border-radius: 10rpx;
  font-size: 18rpx; font-weight: 700;
}

/* ===== 分页间隔 ===== */
.page-break { height: 40rpx; }

/* ===== 分类分区 ===== */
.category-sections { padding-top: 4rpx; }
.category-section { margin-bottom: 28rpx; }
.cat-header { padding: 0 36rpx; margin-bottom: 14rpx; display: flex; align-items: center; justify-content: space-between; }
.cat-title { font-size: 30rpx; font-weight: 700; color: var(--color-text); }

.cat-scroll { white-space: nowrap; padding-left: 36rpx; }
.cat-card-list { display: inline-flex; gap: 14rpx; padding-right: 36rpx; }

/* 精简卡片 — 只保留封面+时长+标题 */
.cat-card {
  display: inline-flex; flex-direction: column; width: 220rpx;
  background: var(--color-bg-card); border-radius: 20rpx; overflow: hidden;
  flex-shrink: 0; border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.cat-card-cover {
  height: 120rpx; position: relative;
  display: flex; align-items: flex-end; justify-content: flex-end;
  padding: 10rpx 14rpx;
}
.cat-card-duration-badge {
  font-size: 20rpx; color: rgba(255,255,255,0.85);
  background: rgba(0,0,0,0.3);
  padding: 3rpx 10rpx; border-radius: 8rpx;
  font-weight: 500;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}
.cat-card-body { padding: 12rpx 14rpx 14rpx; }
.cat-card-title {
  font-size: 24rpx; font-weight: 700; color: var(--color-text);
  display: block; line-height: 1.4;
  white-space: normal; overflow: hidden;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
}

/* ===== 更多抽屉 ===== */
.drawer-section { padding: 0 36rpx; margin-bottom: 24rpx; }
.drawer-toggle {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 20rpx; background: var(--color-bg-card); border-radius: 20rpx;
  border: 1rpx dashed rgba(124, 111, 247, 0.2);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.drawer-toggle-text { font-size: 26rpx; font-weight: 600; color: var(--color-primary); }
.drawer-toggle-icon { font-size: 16rpx; color: var(--color-primary); }
.drawer-content { overflow: hidden; transition: max-height 0.35s ease; }
.drawer-open { max-height: 5000rpx; }
.drawer-closed { max-height: 0; }

/* ===== Onboarding ===== */
.onboarding-prompt { display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 48rpx; }
.onboarding-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 48rpx; background: var(--color-bg-card);
  border-radius: var(--radius-xl); text-align: center;
  border: 1rpx solid var(--color-border);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.onboarding-title { font-size: var(--font-size-xl); font-weight: 700; margin-bottom: 16rpx; color: var(--color-text); }
.onboarding-desc { font-size: var(--font-size-base); color: var(--color-text-secondary); margin-bottom: 48rpx; }

/* ===== 静养入口 ===== */
.section { margin-bottom: 16rpx; }
.meditation-card {
  display: flex; align-items: center; background: var(--color-bg-card);
  border-radius: 20rpx; padding: 20rpx; margin: 0 36rpx; gap: 16rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.meditation-cover {
  width: 72rpx; height: 72rpx; border-radius: 16rpx;
  display: flex; justify-content: center; align-items: center; flex-shrink: 0;
}
.meditation-info { display: flex; flex-direction: column; gap: 4rpx; }
.meditation-title { font-size: 26rpx; font-weight: 600; color: var(--color-text); }

/* ===== 通用 ===== */
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: var(--font-size-sm); }
.loading-container { display: flex; justify-content: center; align-items: center; height: 60vh; }
