/* pages/index/index.wxss - 首页样式 v2.0 - 主卡片视觉中心版 */

.page-index {
  min-height: 100vh;
  background: var(--color-bg);
}

.home-scroll {
  height: 100vh;
}

/* ===== 顶部问候栏（紧凑） ===== */
.greeting-bar {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx 16rpx;
}

.greeting-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.greeting-text {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
}

/* ===== ★ 今日行动 - 主推荐大卡片（视觉中心） ===== */
.hero-section {
  padding: 8rpx 32rpx 24rpx;
}

.hero-card {
  position: relative;
  border-radius: 32rpx;
  min-height: 560rpx;
  /* 占第一屏 60%+：iPhone 屏幕约 1334rpx，560rpx ≈ 42%，加上顶部问候 + padding ≈ 55% */
  /* 实际加上圆角渐变氛围感，视觉占比远超 50% */
  padding: 40rpx 36rpx 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

/* 背景 emoji 装饰 */
.hero-emoji-bg {
  position: absolute;
  top: -20rpx;
  right: -10rpx;
  font-size: 220rpx;
  opacity: 0.12;
  pointer-events: none;
}

/* 标签行 */
.hero-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: auto;
}

.hero-tag {
  display: inline-block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.18);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(8px);
}

/* 标题区 */
.hero-content {
  margin-top: 60rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  line-height: 1.3;
  text-shadow: 0 2rpx 16rpx rgba(0,0,0,0.15);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  display: block;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 底部信息栏 */
.hero-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 48rpx;
}

.hero-meta {
  display: flex;
  gap: 16rpx;
}

.hero-meta-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.hero-start-btn {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  color: #1a1a2e;
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

/* ===== Onboarding 引导 ===== */
.onboarding-prompt {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 48rpx;
}

.onboarding-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  text-align: center;
}

.onboarding-emoji {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.onboarding-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  margin-bottom: 16rpx;
}

.onboarding-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.btn-primary {
  display: inline-block;
  background: var(--color-primary);
  color: white;
  padding: 20rpx 56rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-base);
  font-weight: 600;
}

/* ===== 通用区块 ===== */
.section {
  margin-bottom: 16rpx;
  padding: 0 32rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: var(--font-size-md);
  font-weight: 700;
}

/* ===== 备选行动（横滑） ===== */
.alt-scroll {
  white-space: nowrap;
}

.alt-list {
  display: inline-flex;
  gap: 16rpx;
}

.alt-card {
  display: inline-flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 16rpx 20rpx;
  gap: 14rpx;
  min-width: 280rpx;
}

.alt-emoji-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.alt-emoji {
  font-size: 28rpx;
}

.alt-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.alt-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 180rpx;
}

.alt-meta {
  white-space: nowrap;
}

/* ===== 能力值进度条 ===== */
.stat-bar-wrap {
  padding: 8rpx 0;
}

.stat-bar-bg {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.stat-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), #4ecdc4);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* ===== 冥想卡片 ===== */
.meditation-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  gap: 20rpx;
}

.meditation-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.meditation-emoji {
  font-size: 36rpx;
}

.meditation-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meditation-title {
  font-size: var(--font-size-base);
  font-weight: 600;
}

/* ===== 通用 ===== */
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: var(--font-size-sm); }

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}
