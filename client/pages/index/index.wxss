/* pages/index/index.wxss - 首页 v3.2 - 精简+悬浮TabBar */

.page-index { min-height: 100vh; background: var(--color-bg); }
.home-scroll { height: 100vh; }

/* ===== 顶部状态条 ===== */
.top-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 48rpx 36rpx 8rpx;
}
.top-bar-left { display: flex; align-items: center; gap: 12rpx; }
.top-stat {
  font-size: 22rpx; color: var(--color-text-secondary); font-weight: 500;
  padding: 6rpx 14rpx; background: var(--color-bg-card); border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
}

.top-bar-right { display: flex; align-items: center; }
.top-avatar {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  display: flex; justify-content: center; align-items: center;
}
.top-avatar-text { font-size: 20rpx; color: #fff; font-weight: 600; }

/* ===== 通用分区标题行 ===== */
.section-title-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 36rpx; margin-bottom: 20rpx;
}
.section-title-lg {
  font-size: 40rpx; font-weight: 800; color: var(--color-text);
  letter-spacing: -0.5rpx;
}
.section-title-md {
  font-size: 30rpx; font-weight: 700; color: var(--color-text);
}
.section-more {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: var(--color-bg-card); display: flex; justify-content: center; align-items: center;
  border: 1rpx solid var(--color-border);
}
.section-more-icon { font-size: 26rpx; color: var(--color-text-secondary); }

/* ===== 今日训练 ===== */
.today-section { margin-top: 12rpx; }

.hero-card { padding: 0 36rpx; }
.hero-cover {
  position: relative; border-radius: 28rpx; min-height: 480rpx;
  display: flex; flex-direction: column; justify-content: flex-end;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.35);
  border: 1rpx solid rgba(255,255,255,0.06);
}

.hero-overlay {
  position: relative; z-index: 1; padding: 32rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.15) 70%, transparent 100%);
  border-radius: 0 0 28rpx 28rpx;
  margin-top: auto;
  display: flex; align-items: flex-end; justify-content: space-between; gap: 24rpx;
}
.hero-info-left { flex: 1; min-width: 0; }
.hero-duration {
  font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 8rpx;
  font-weight: 500;
}
.hero-title {
  font-size: 42rpx; font-weight: 800; color: #fff; display: block;
  line-height: 1.2; letter-spacing: -0.5rpx;
}

.hero-start-btn {
  display: inline-flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff; padding: 20rpx 44rpx; border-radius: 44rpx;
  font-size: 26rpx; font-weight: 700; flex-shrink: 0;
  box-shadow: 0 6rpx 24rpx rgba(124, 111, 247, 0.4);
  border: 1rpx solid rgba(255,255,255,0.15);
}

/* ===== 本周看见 ===== */
.week-section { margin-top: 28rpx; }

.week-scroll { white-space: nowrap; padding-left: 36rpx; }
.week-cards { display: inline-flex; gap: 12rpx; padding-right: 36rpx; }

.week-card {
  display: inline-flex; flex-direction: column;
  background: var(--color-bg-card); border-radius: 20rpx;
  padding: 20rpx 24rpx; min-width: 168rpx; flex-shrink: 0;
  border: 1rpx solid var(--color-border);
}
.week-card-label { font-size: 20rpx; color: var(--color-text-muted); margin-bottom: 8rpx; }
.week-card-value-row { display: flex; align-items: baseline; gap: 4rpx; margin-bottom: 6rpx; }
.week-card-value { font-size: 40rpx; font-weight: 800; color: var(--color-text); line-height: 1.1; letter-spacing: -1rpx; }
.week-card-unit { font-size: 20rpx; color: var(--color-text-secondary); font-weight: 500; }
.week-card-compare { font-size: 18rpx; color: var(--color-text-muted); }

/* ===== 分页间隔 ===== */
.page-break { height: 40rpx; }

/* ===== 分类分区 ===== */
.category-sections { padding-top: 4rpx; }
.category-section { margin-bottom: 28rpx; }

.cat-header { padding: 0 36rpx; margin-bottom: 14rpx; display: flex; align-items: center; justify-content: space-between; }
.cat-title-wrap { display: flex; align-items: center; gap: 0; }
.cat-title { font-size: 30rpx; font-weight: 700; color: var(--color-text); }

.cat-reason {
  display: inline-flex; align-items: center; gap: 0;
  padding: 4rpx 14rpx; background: rgba(124, 111, 247, 0.1);
  border-radius: 10rpx; border: 1rpx solid rgba(124, 111, 247, 0.12);
}
.cat-reason-text { font-size: 20rpx; color: var(--color-primary-light); font-weight: 500; }

/* 横滑区域 */
.cat-scroll { white-space: nowrap; padding-left: 36rpx; }
.cat-card-list { display: inline-flex; gap: 14rpx; padding-right: 36rpx; }

.cat-card {
  display: inline-flex; flex-direction: column; width: 240rpx;
  background: var(--color-bg-card); border-radius: 20rpx; overflow: hidden;
  flex-shrink: 0; border: 1rpx solid var(--color-border);
}
.cat-card-cover {
  height: 120rpx;
}
.cat-card-body { padding: 14rpx 16rpx 16rpx; }
.cat-card-title {
  font-size: 24rpx; font-weight: 700; color: var(--color-text);
  display: block; line-height: 1.4; margin-bottom: 4rpx;
  white-space: normal; overflow: hidden;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.cat-card-sub {
  font-size: 20rpx; color: var(--color-text-secondary);
  display: block; line-height: 1.4; margin-bottom: 8rpx;
  white-space: normal; overflow: hidden;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
}

.cat-card-reason {
  padding: 4rpx 10rpx; background: rgba(124, 111, 247, 0.06);
  border-radius: 8rpx; margin-bottom: 8rpx;
}
.cat-card-reason-text { font-size: 18rpx; color: var(--color-primary-light); line-height: 1.3; }

.cat-card-footer { display: flex; align-items: center; justify-content: space-between; }
.cat-card-duration { font-size: 18rpx; color: var(--color-text-muted); }
.cat-card-tag {
  font-size: 16rpx; color: var(--color-primary-light);
  background: rgba(124, 111, 247, 0.1); padding: 2rpx 10rpx;
  border-radius: 6rpx; font-weight: 600;
}

/* ===== 更多抽屉 ===== */
.drawer-section { padding: 0 36rpx; margin-bottom: 24rpx; }

.drawer-toggle {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 20rpx; background: var(--color-bg-card); border-radius: 20rpx;
  border: 1rpx dashed rgba(124, 111, 247, 0.2);
}
.drawer-toggle-text { font-size: 26rpx; font-weight: 600; color: var(--color-primary-light); }
.drawer-toggle-icon { font-size: 16rpx; color: var(--color-primary); }

.drawer-content { overflow: hidden; transition: max-height 0.35s ease; }
.drawer-open { max-height: 5000rpx; }
.drawer-closed { max-height: 0; }

/* ===== 悬浮毛玻璃 TabBar ===== */
.float-tabbar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 40rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 999;
}
.float-tabbar-inner {
  display: flex; justify-content: space-around; align-items: center;
  background: rgba(30, 30, 50, 0.72);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-radius: 48rpx;
  padding: 16rpx 8rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4);
}
.float-tabbar-item {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  padding: 8rpx 24rpx; border-radius: 32rpx;
  transition: all 0.2s ease;
}
.float-tab-active {
  background: rgba(124, 111, 247, 0.15);
}
.float-tab-icon {
  font-size: 32rpx; color: var(--color-text-muted);
  transition: color 0.2s ease;
}
.float-tab-active .float-tab-icon {
  color: var(--color-primary-light);
}
.float-tab-label {
  font-size: 18rpx; color: var(--color-text-muted); font-weight: 500;
  transition: color 0.2s ease;
}
.float-tab-active .float-tab-label {
  color: var(--color-primary-light); font-weight: 600;
}

/* ===== Onboarding ===== */
.onboarding-prompt { display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 48rpx; }
.onboarding-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 48rpx; background: var(--color-bg-card);
  border-radius: var(--radius-xl); text-align: center;
  border: 1rpx solid var(--color-border);
}
.onboarding-title { font-size: var(--font-size-xl); font-weight: 700; margin-bottom: 16rpx; color: var(--color-text); }
.onboarding-desc { font-size: var(--font-size-base); color: var(--color-text-secondary); margin-bottom: 48rpx; }

/* ===== 静养入口 ===== */
.section { margin-bottom: 16rpx; }

.meditation-card {
  display: flex; align-items: center; background: var(--color-bg-card);
  border-radius: 20rpx; padding: 20rpx; margin: 0 36rpx; gap: 16rpx;
  border: 1rpx solid var(--color-border);
}
.meditation-cover {
  width: 72rpx; height: 72rpx; border-radius: 16rpx;
  display: flex; justify-content: center; align-items: center; flex-shrink: 0;
}
.meditation-info { display: flex; flex-direction: column; gap: 4rpx; }
.meditation-title { font-size: 26rpx; font-weight: 600; color: var(--color-text); }

/* ===== 通用 ===== */
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: var(--font-size-sm); }
.loading-container { display: flex; justify-content: center; align-items: center; height: 60vh; }
