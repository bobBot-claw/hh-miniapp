/* pages/index/index.wxss - 首页 v2.0 - 分区横滑版 */

.page-index { min-height: 100vh; background: var(--color-bg); }
.home-scroll { height: 100vh; }

/* ===== 问候 ===== */
.greeting-bar { display: flex; align-items: center; padding: 48rpx 32rpx 12rpx; }
.greeting-icon { font-size: 40rpx; margin-right: 12rpx; }
.greeting-text { font-size: var(--font-size-lg); font-weight: 700; color: var(--color-text); }

/* ===== 主推荐大卡片 ===== */
.hero-section { padding: 8rpx 32rpx 20rpx; }

.hero-card {
  position: relative; border-radius: 32rpx; min-height: 480rpx;
  padding: 36rpx 36rpx 32rpx; display: flex; flex-direction: column;
  justify-content: space-between; overflow: hidden;
}
.hero-emoji-bg { position: absolute; top: -20rpx; right: -10rpx; font-size: 200rpx; opacity: 0.12; pointer-events: none; }
.hero-tags { display: flex; gap: 12rpx; margin-bottom: auto; }
.hero-tag { display: inline-block; font-size: 22rpx; color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.18); padding: 6rpx 20rpx; border-radius: 20rpx; }
.hero-content { margin-top: 48rpx; }
.hero-title { font-size: 44rpx; font-weight: 800; color: #fff; display: block; line-height: 1.3; text-shadow: 0 2rpx 16rpx rgba(0,0,0,0.15); }
.hero-subtitle { font-size: 28rpx; color: rgba(255,255,255,0.75); display: block; margin-top: 12rpx; line-height: 1.5; }
.hero-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 36rpx; }
.hero-meta { display: flex; gap: 16rpx; }
.hero-meta-item { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.hero-start-btn { display: inline-flex; align-items: center; background: rgba(255,255,255,0.95); color: #1a1a2e; padding: 16rpx 44rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 700; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15); }

/* ===== 进度展示 ===== */
.progress-section { padding: 12rpx 32rpx 24rpx; }

.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.progress-title { font-size: 26rpx; font-weight: 600; color: var(--color-text); }
.progress-link { font-size: 24rpx; color: var(--color-primary); padding: 4rpx 8rpx; }

.progress-bars { display: flex; flex-direction: column; gap: 12rpx; }
.progress-item { display: flex; align-items: center; gap: 10rpx; }
.progress-emoji { font-size: 24rpx; width: 32rpx; text-align: center; }
.progress-bar-bg { flex: 1; height: 12rpx; background: rgba(255,255,255,0.08); border-radius: 6rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; border-radius: 6rpx; transition: width 0.5s ease; }
.progress-value { font-size: 22rpx; color: var(--color-text-secondary); width: 40rpx; text-align: right; }

/* ===== 分类分区 ===== */
.category-sections { padding-top: 8rpx; }

.category-section { margin-bottom: 28rpx; }

.cat-header { padding: 0 32rpx; margin-bottom: 16rpx; }
.cat-title-wrap { display: flex; align-items: center; gap: 8rpx; margin-bottom: 6rpx; }
.cat-emoji { font-size: 32rpx; }
.cat-title { font-size: 32rpx; font-weight: 700; color: var(--color-text); }

.cat-reason { display: inline-flex; align-items: center; gap: 6rpx; padding: 4rpx 14rpx; background: rgba(124, 111, 247, 0.1); border-radius: 10rpx; }
.cat-reason-icon { font-size: 20rpx; }
.cat-reason-text { font-size: 22rpx; color: var(--color-primary); }

/* 横滑区域 */
.cat-scroll { white-space: nowrap; padding-left: 32rpx; }

.cat-card-list { display: inline-flex; gap: 16rpx; padding-right: 32rpx; }

.cat-card {
  display: inline-flex; flex-direction: column; width: 260rpx;
  background: var(--color-bg-card); border-radius: 20rpx; overflow: hidden;
  flex-shrink: 0;
}
.cat-card-cover {
  height: 140rpx; display: flex; justify-content: center; align-items: center;
}
.cat-card-emoji { font-size: 48rpx; }

.cat-card-body { padding: 14rpx 16rpx 16rpx; }
.cat-card-title { font-size: 26rpx; font-weight: 700; color: var(--color-text); display: block; line-height: 1.4; margin-bottom: 4rpx; white-space: normal; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.cat-card-sub { font-size: 22rpx; color: var(--color-text-secondary); display: block; line-height: 1.4; margin-bottom: 8rpx; white-space: normal; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }

.cat-card-reason { padding: 4rpx 10rpx; background: rgba(124, 111, 247, 0.08); border-radius: 8rpx; margin-bottom: 8rpx; }
.cat-card-reason-text { font-size: 20rpx; color: var(--color-primary); line-height: 1.4; }

.cat-card-footer { display: flex; align-items: center; justify-content: space-between; }
.cat-card-duration { font-size: 20rpx; color: var(--color-text-secondary); }
.cat-card-tag { font-size: 18rpx; color: var(--color-primary); background: rgba(124, 111, 247, 0.12); padding: 2rpx 10rpx; border-radius: 6rpx; font-weight: 500; }

/* ===== 更多抽屉 ===== */
.drawer-section { padding: 0 32rpx; margin-bottom: 24rpx; }

.drawer-toggle {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 20rpx; background: var(--color-bg-card); border-radius: 20rpx;
}
.drawer-toggle-text { font-size: 28rpx; font-weight: 600; color: var(--color-primary); }
.drawer-toggle-icon { font-size: 20rpx; color: var(--color-primary); }

.drawer-content { overflow: hidden; transition: max-height 0.3s ease; }
.drawer-open { max-height: 5000rpx; }
.drawer-closed { max-height: 0; }

/* ===== Onboarding ===== */
.onboarding-prompt { display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 48rpx; }
.onboarding-card { display: flex; flex-direction: column; align-items: center; padding: 80rpx 48rpx; background: var(--color-bg-card); border-radius: var(--radius-xl); text-align: center; }
.onboarding-emoji { font-size: 96rpx; margin-bottom: 32rpx; }
.onboarding-title { font-size: var(--font-size-xl); font-weight: 700; margin-bottom: 16rpx; }
.onboarding-desc { font-size: var(--font-size-base); color: var(--color-text-secondary); margin-bottom: 48rpx; }
.btn-primary { display: inline-block; background: var(--color-primary); color: white; padding: 20rpx 56rpx; border-radius: var(--radius-lg); font-size: var(--font-size-base); font-weight: 600; }

/* ===== 通用 ===== */
.section { margin-bottom: 16rpx; padding: 0 32rpx; }
.section-header { margin-bottom: 16rpx; }
.section-title { font-size: var(--font-size-md); font-weight: 700; }

.meditation-card { display: flex; align-items: center; background: var(--color-bg-card); border-radius: var(--radius-lg); padding: 20rpx; gap: 20rpx; }
.meditation-cover { width: 80rpx; height: 80rpx; border-radius: var(--radius-md); display: flex; justify-content: center; align-items: center; flex-shrink: 0; }
.meditation-emoji { font-size: 36rpx; }
.meditation-info { display: flex; flex-direction: column; gap: 6rpx; }
.meditation-title { font-size: var(--font-size-base); font-weight: 600; }

.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: var(--font-size-sm); }
.loading-container { display: flex; justify-content: center; align-items: center; height: 60vh; }
