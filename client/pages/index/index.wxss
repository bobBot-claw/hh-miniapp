/* pages/index/index.wxss - 首页样式 v2.0 - 小红书瀑布流版 */

.page-index {
  min-height: 100vh;
  background: var(--color-bg);
}

.home-scroll {
  height: 100vh;
}

/* ===== 顶部问候栏 ===== */
.greeting-bar {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx 16rpx;
}

.greeting-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.greeting-text {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
}

/* ===== ★ 主推荐大卡片 ===== */
.hero-section {
  padding: 8rpx 32rpx 24rpx;
}

.hero-card {
  position: relative;
  border-radius: 32rpx;
  min-height: 520rpx;
  padding: 40rpx 36rpx 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.hero-emoji-bg {
  position: absolute;
  top: -20rpx;
  right: -10rpx;
  font-size: 220rpx;
  opacity: 0.12;
  pointer-events: none;
}

.hero-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: auto;
}

.hero-tag {
  display: inline-block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.18);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.hero-content {
  margin-top: 60rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  line-height: 1.3;
  text-shadow: 0 2rpx 16rpx rgba(0,0,0,0.15);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  display: block;
  margin-top: 12rpx;
  line-height: 1.5;
}

.hero-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40rpx;
}

.hero-meta {
  display: flex;
  gap: 16rpx;
}

.hero-meta-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.hero-start-btn {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  color: #1a1a2e;
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

/* ===== ★ 瀑布流推荐 ===== */
.recommend-section {
  padding: 8rpx 32rpx 0;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: var(--font-size-md);
  font-weight: 700;
}

.section-sub {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-left: 12rpx;
}

/* 瀑布流容器 */
.waterfall {
  display: flex;
  gap: 16rpx;
}

.waterfall-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 推荐卡片 */
.rec-card {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  overflow: hidden;
}

.rec-card-tall .rec-cover {
  height: 220rpx;
}

.rec-card-short .rec-cover {
  height: 160rpx;
}

.rec-cover {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.rec-cover-emoji {
  font-size: 56rpx;
}

.rec-body {
  padding: 16rpx 20rpx 18rpx;
}

.rec-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
  line-height: 1.4;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* AI 推荐理由 */
.rec-reason {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 12rpx;
  background: rgba(124, 111, 247, 0.08);
  border-radius: 10rpx;
}

.rec-reason-icon {
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.rec-reason-text {
  font-size: 22rpx;
  color: var(--color-primary);
  line-height: 1.5;
  flex: 1;
}

.rec-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rec-duration {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.rec-tag {
  font-size: 18rpx;
  color: var(--color-primary);
  background: rgba(124, 111, 247, 0.12);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* ===== Onboarding 引导 ===== */
.onboarding-prompt {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 48rpx;
}

.onboarding-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  text-align: center;
}

.onboarding-emoji {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.onboarding-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  margin-bottom: 16rpx;
}

.onboarding-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.btn-primary {
  display: inline-block;
  background: var(--color-primary);
  color: white;
  padding: 20rpx 56rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-base);
  font-weight: 600;
}

/* ===== 通用区块 ===== */
.section {
  margin-bottom: 16rpx;
  padding: 0 32rpx;
}

/* ===== 冥想卡片 ===== */
.meditation-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  gap: 20rpx;
}

.meditation-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.meditation-emoji {
  font-size: 36rpx;
}

.meditation-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meditation-title {
  font-size: var(--font-size-base);
  font-weight: 600;
}

/* ===== 通用 ===== */
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: var(--font-size-sm); }

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}
