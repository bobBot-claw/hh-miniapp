/* pages/index/index.wxss - 首页 v6.0 — 五力能量球+超级沉浸背景 */

.page-index { min-height: 100vh; background: #050510; position: relative; }
.home-scroll { height: 100vh; position: relative; z-index: 2; }

/* ═══════════════════════════════════════════════
   全屏沉浸层
   ═══════════════════════════════════════════════ */

.immersive-hero {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 100vh;
  z-index: 10;
  overflow: hidden;
  pointer-events: none;
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.immersive-hero.hero-collapsed {
  opacity: 0;
  transform: scale(1.05);
}

/* ══ L1: 深空渐变 ══ */
.space-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: 
    radial-gradient(ellipse at 30% 20%, #1a0a3e 0%, transparent 50%),
    radial-gradient(ellipse at 70% 60%, #0a1a2e 0%, transparent 50%),
    radial-gradient(ellipse at 50% 100%, #0d0d1a 0%, transparent 60%),
    linear-gradient(180deg, #070714 0%, #0c0c20 40%, #050510 100%);
}

/* ══ L2: 透视网格地面 ══ */
.grid-floor {
  position: absolute;
  bottom: 0; left: -50%; right: -50%;
  height: 55vh;
  background: 
    repeating-linear-gradient(
      90deg,
      rgba(124,111,247,0.06) 0px,
      rgba(124,111,247,0.06) 1px,
      transparent 1px,
      transparent 60px
    ),
    repeating-linear-gradient(
      0deg,
      rgba(78,205,196,0.04) 0px,
      rgba(78,205,196,0.04) 1px,
      transparent 1px,
      transparent 60px
    );
  transform: perspective(500rpx) rotateX(60deg);
  transform-origin: center top;
  mask-image: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 70%);
  -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 70%);
}

/* ══ L3: 星尘粒子 ══ */
.stardust {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
}
.star {
  position: absolute;
  border-radius: 50%;
  background: #fff;
}
.star-1  { width: 4rpx; height: 4rpx; top: 8%;  left: 15%; animation: twinkle 3s ease-in-out infinite 0s; }
.star-2  { width: 3rpx; height: 3rpx; top: 15%; left: 75%; animation: twinkle 4s ease-in-out infinite 0.5s; }
.star-3  { width: 5rpx; height: 5rpx; top: 25%; left: 40%; animation: twinkle 3.5s ease-in-out infinite 1s; }
.star-4  { width: 3rpx; height: 3rpx; top: 35%; left: 88%; animation: twinkle 5s ease-in-out infinite 1.5s; }
.star-5  { width: 4rpx; height: 4rpx; top: 50%; left: 10%; animation: twinkle 4.5s ease-in-out infinite 2s; }
.star-6  { width: 3rpx; height: 3rpx; top: 60%; left: 65%; animation: twinkle 3s ease-in-out infinite 0.8s; }
.star-7  { width: 4rpx; height: 4rpx; top: 72%; left: 30%; animation: twinkle 4s ease-in-out infinite 1.2s; }
.star-8  { width: 5rpx; height: 5rpx; top: 80%; left: 82%; animation: twinkle 3.5s ease-in-out infinite 2.5s; }

@keyframes twinkle {
  0%, 100% { opacity: 0.2; transform: scale(1); }
  50%      { opacity: 1; transform: scale(1.5); }
}

/* ══ L4: 大范围呼吸光晕 ══ */
.ambient-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  animation: ambient-breathe 8s ease-in-out infinite;
}
.ambient-1 {
  width: 600rpx; height: 600rpx;
  background: radial-gradient(circle, rgba(124,111,247,0.15) 0%, transparent 70%);
  top: 5%; left: -10%;
  animation-delay: 0s;
}
.ambient-2 {
  width: 500rpx; height: 500rpx;
  background: radial-gradient(circle, rgba(78,205,196,0.12) 0%, transparent 70%);
  top: 40%; right: -10%;
  animation-delay: 4s;
}
@keyframes ambient-breathe {
  0%, 100% { opacity: 0.4; transform: scale(0.9); }
  50%      { opacity: 1; transform: scale(1.15); }
}

/* ═══════════════════════════════════════════════
   L5: 五力能量球
   ═══════════════════════════════════════════════ */

.orbs-field {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
}

.orb {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 五球定位 — 左二右三围绕中心 */
.orb-pos-posture    { top: 14vh; left: 8%;  animation: orb-float 6s ease-in-out infinite 0s; }
.orb-pos-core       { top: 32vh; left: 5%;  animation: orb-float 7s ease-in-out infinite 1s; }
.orb-pos-flexibility { top: 12vh; right: 8%; animation: orb-float 5.5s ease-in-out infinite 0.5s; }
.orb-pos-vitality   { top: 30vh; right: 3%; animation: orb-float 6.5s ease-in-out infinite 1.5s; }
.orb-pos-mind_body  { top: 48vh; left: 50%; transform: translateX(-50%); animation: orb-float 7.5s ease-in-out infinite 2s; }

@keyframes orb-float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-15rpx); }
}
.orb-pos-mind_body {
  animation-name: orb-float-center;
}
@keyframes orb-float-center {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50%      { transform: translateX(-50%) translateY(-15rpx); }
}

/* 球体外光晕 */
.orb-halo {
  position: absolute;
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  top: 50%; left: 50%;
  transform: translate(-50%, -60%);
  filter: blur(20rpx);
}

/* 球体本身 */
.orb-sphere {
  border-radius: 50%;
  position: relative;
  z-index: 2;
}

/* 脉冲环 */
.orb-ring {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -60%);
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  border: 2rpx solid;
  animation: orb-pulse 3s ease-out infinite;
}
@keyframes orb-pulse {
  0%   { transform: translate(-50%, -60%) scale(0.8); opacity: 0.8; }
  100% { transform: translate(-50%, -60%) scale(2.2); opacity: 0; }
}

/* 数值 */
.orb-value {
  position: relative;
  z-index: 3;
  font-size: 28rpx;
  font-weight: 900;
  margin-top: 8rpx;
  text-shadow: 0 0 10rpx currentColor;
}

/* 名称 */
.orb-name {
  position: relative;
  z-index: 3;
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 500;
  margin-top: 2rpx;
  white-space: nowrap;
}

/* ═══════════════════════════════════════════════
   L6: 教练全息投影
   ═══════════════════════════════════════════════ */

.coach-layer {
  position: absolute;
  top: 8vh;
  left: 0; right: 0; bottom: 30vh;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1;
}

.coach-img {
  width: 480rpx;
  height: 100%;
  transition: opacity 1.2s ease-in-out;
  filter: drop-shadow(0 0 30rpx rgba(78,205,196,0.3)) drop-shadow(0 0 60rpx rgba(124,111,247,0.15));
}
.coach-visible { opacity: 1; }
.coach-hidden { opacity: 0; position: absolute; }

.holo-ground {
  position: absolute;
  bottom: 28vh;
  left: 0; right: 0;
  height: 60rpx;
  display: flex; justify-content: center;
  z-index: 1;
}
.holo-ground::after {
  content: '';
  width: 400rpx; height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(78,205,196,0.2) 0%, rgba(124,111,247,0.08) 40%, transparent 70%);
  animation: ground-pulse 3s ease-in-out infinite;
}
@keyframes ground-pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50%      { opacity: 1; transform: scale(1.12); }
}

/* ═══ 顶部状态条 ═══ */
.hero-top-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  padding: 16rpx 36rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  z-index: 5;
}
.hero-top-left { display: flex; align-items: center; gap: 12rpx; }
.hero-stat-chip {
  font-size: 22rpx; color: rgba(255,255,255,0.75); font-weight: 600;
  padding: 8rpx 18rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

/* ═══ 底部面板 ═══ */
.hero-bottom-panel {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 0 48rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: auto;
}

.hero-info { text-align: center; margin-bottom: 32rpx; }
.hero-today-label {
  font-size: 22rpx; color: rgba(78,205,196,0.85); font-weight: 600;
  letter-spacing: 4rpx; display: block; margin-bottom: 8rpx;
}
.hero-today-title {
  font-size: 52rpx; font-weight: 900; color: #fff;
  display: block; line-height: 1.2;
  text-shadow: 0 4rpx 20rpx rgba(124,111,247,0.4);
}
.hero-today-sub {
  font-size: 26rpx; color: rgba(255,255,255,0.5); font-weight: 500;
  display: block; margin-top: 8rpx;
}

/* CTA 按钮 */
.hero-cta-wrap { position: relative; margin-bottom: 28rpx; }
.hero-cta-btn {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  padding: 28rpx 96rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #7c6ff7, #4ecdc4);
  overflow: hidden;
  z-index: 1;
}
.cta-glow {
  position: absolute;
  top: -50%; left: -50%; right: -50%; bottom: -50%;
  background: linear-gradient(135deg, rgba(124,111,247,0.5), rgba(78,205,196,0.5));
  filter: blur(30rpx);
  border-radius: 56rpx;
  animation: cta-pulse 2.5s ease-in-out infinite;
  z-index: -1;
}
@keyframes cta-pulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%      { opacity: 0.8; transform: scale(1.08); }
}
.cta-text {
  font-size: 32rpx; font-weight: 800; color: #fff;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 下滑提示 */
.hero-scroll-hint {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  opacity: 0.5; transition: opacity 0.3s;
}
.hero-scroll-hint.hint-hidden { opacity: 0; }
.scroll-arrow {
  width: 24rpx; height: 24rpx;
  border-right: 3rpx solid rgba(255,255,255,0.4);
  border-bottom: 3rpx solid rgba(255,255,255,0.4);
  transform: rotate(45deg);
  animation: arrow-bounce 2s ease-in-out infinite;
}
@keyframes arrow-bounce {
  0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.4; }
  50%      { transform: rotate(45deg) translateY(8rpx); opacity: 1; }
}
.scroll-hint-text { font-size: 20rpx; color: rgba(255,255,255,0.35); font-weight: 500; }

/* 占位 */
.scroll-spacer { height: 100vh; pointer-events: none; }

/* ═══════════════════════════════════════════════
   下方滚动内容区
   ═══════════════════════════════════════════════ */

.section-title-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 36rpx; margin-bottom: 20rpx;
}
.section-title-lg { font-size: 40rpx; font-weight: 800; color: var(--color-text); letter-spacing: -0.5rpx; }
.section-title-md { font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.section-more {
  display: flex; align-items: center; gap: 4rpx;
  padding: 8rpx 16rpx; border-radius: 20rpx;
  background: var(--color-bg-card); border: 1rpx solid var(--color-border);
}
.section-more-text { font-size: 22rpx; color: var(--color-text-secondary); font-weight: 500; }
.section-more-icon { font-size: 24rpx; color: var(--color-text-secondary); }

.today-section { margin-top: 4rpx; }
.hero-card { padding: 0 36rpx; }
.hero-cover {
  position: relative; border-radius: 28rpx; min-height: 440rpx;
  display: flex; flex-direction: column; justify-content: flex-end;
  overflow: hidden; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1); border: 1rpx solid var(--color-border);
}
.hero-overlay {
  position: relative; z-index: 1; padding: 32rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 100%);
  border-radius: 0 0 28rpx 28rpx; margin-top: auto;
  display: flex; align-items: flex-end; justify-content: space-between; gap: 24rpx;
}
.hero-info-left { flex: 1; min-width: 0; }
.hero-duration { font-size: 22rpx; color: rgba(255,255,255,0.6); display: block; margin-bottom: 8rpx; }
.hero-title { font-size: 42rpx; font-weight: 800; color: #fff; display: block; line-height: 1.2; }
.hero-start-btn {
  display: inline-flex; align-items: center; justify-content: center;
  background: #fff; color: var(--color-primary-dark); padding: 20rpx 44rpx; border-radius: 44rpx;
  font-size: 26rpx; font-weight: 700; flex-shrink: 0;
}

.plan-hero-card { margin: 0 24rpx; background: var(--color-bg-card); border-radius: 32rpx; overflow: hidden; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.1); border: 1rpx solid var(--color-border); }
.plan-hero-cover { padding: 40rpx 36rpx 32rpx; position: relative; min-height: 300rpx; display: flex; flex-direction: column; justify-content: space-between; }
.plan-hero-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28rpx; }
.plan-hero-name { font-size: 34rpx; font-weight: 800; color: #fff; }
.plan-hero-phase { font-size: 22rpx; color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.18); padding: 6rpx 16rpx; border-radius: 14rpx; font-weight: 500; }
.plan-hero-day { display: flex; align-items: center; gap: 24rpx; margin-bottom: 24rpx; }
.plan-hero-daynum { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 120rpx; height: 120rpx; background: rgba(255,255,255,0.2); border-radius: 28rpx; backdrop-filter: blur(8px); border: 1rpx solid rgba(255,255,255,0.25); flex-shrink: 0; }
.plan-hero-daynum-label { font-size: 18rpx; color: rgba(255,255,255,0.7); font-weight: 600; letter-spacing: 3rpx; }
.plan-hero-daynum-value { font-size: 56rpx; color: #fff; font-weight: 900; line-height: 1; margin-top: 4rpx; }
.plan-hero-day-info { flex: 1; }
.plan-hero-day-title { font-size: 36rpx; font-weight: 800; color: #fff; display: block; margin-bottom: 6rpx; }
.plan-hero-day-duration { font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; }
.plan-hero-start-btn { display: inline-flex; align-items: center; justify-content: center; background: #fff; color: #1a1a2e; padding: 22rpx 40rpx; border-radius: 44rpx; font-size: 28rpx; font-weight: 700; flex-shrink: 0; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.18); }
.plan-hero-chips { display: flex; flex-wrap: wrap; gap: 10rpx; }
.plan-chip { padding: 6rpx 18rpx; background: rgba(255,255,255,0.18); border-radius: 12rpx; font-size: 22rpx; color: rgba(255,255,255,0.9); font-weight: 500; }
.plan-chip-meditation { background: rgba(255,255,255,0.12); }
.plan-hero-footer { padding: 24rpx 36rpx 28rpx; }
.plan-progress-visual { margin-bottom: 12rpx; }
.plan-dots { display: flex; flex-wrap: wrap; gap: 8rpx; }
.plan-dot { width: 20rpx; height: 20rpx; border-radius: 50%; background: rgba(0,0,0,0.06); }
.plan-dot-done { background: var(--color-primary); box-shadow: 0 2rpx 6rpx rgba(124,111,247,0.3); }
.plan-dot-current { background: var(--color-primary); opacity: 0.5; animation: pulse-dot 1.5s ease-in-out infinite; }
@keyframes pulse-dot { 0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.3)} }
.plan-progress-info { display: flex; justify-content: space-between; align-items: center; }
.plan-progress-text { font-size: 22rpx; color: var(--color-text-secondary); }
.plan-progress-pct { font-size: 22rpx; color: var(--color-primary); font-weight: 700; }

.plan-complete-card { display: flex; align-items: center; gap: 20rpx; margin: 0 36rpx; padding: 28rpx 24rpx; background: var(--color-bg-card); border-radius: 24rpx; border: 2rpx solid #00b894; }
.plan-complete-icon { width: 72rpx; height: 72rpx; border-radius: 50%; background: linear-gradient(135deg, #00b894, #55efc4); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.plan-complete-icon-text { font-size: 36rpx; color: #fff; font-weight: 900; }
.plan-complete-info { flex: 1; }
.plan-complete-title { font-size: 28rpx; font-weight: 700; color: var(--color-text); display: block; margin-bottom: 4rpx; }
.plan-complete-sub { font-size: 22rpx; color: var(--color-text-secondary); display: block; }

.plan-section { margin-top: 28rpx; }
.plan-scroll { white-space: nowrap; padding-left: 36rpx; }
.plan-cards-row { display: inline-flex; gap: 16rpx; padding-right: 36rpx; }
.plan-card-mini { display: inline-flex; flex-direction: column; width: 280rpx; background: var(--color-bg-card); border-radius: 20rpx; overflow: hidden; flex-shrink: 0; border: 1rpx solid var(--color-border); }
.plan-card-mini.plan-active { border-color: var(--color-primary); box-shadow: 0 4rpx 20rpx rgba(124,111,247,0.2); }
.plan-mini-cover { padding: 28rpx 20rpx 20rpx; min-height: 140rpx; display: flex; flex-direction: column; justify-content: flex-end; position: relative; }
.plan-mini-title { font-size: 28rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 6rpx; }
.plan-mini-sub { font-size: 22rpx; color: rgba(255,255,255,0.75); display: block; }
.plan-mini-badge { position: absolute; top: 12rpx; right: 12rpx; background: #fff; color: var(--color-primary); padding: 4rpx 12rpx; border-radius: 10rpx; font-size: 18rpx; font-weight: 700; }

.page-break { height: 40rpx; }
.category-sections { padding-top: 4rpx; }
.category-section { margin-bottom: 28rpx; }
.cat-header { padding: 0 36rpx; margin-bottom: 14rpx; }
.cat-title { font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.cat-scroll { white-space: nowrap; padding-left: 36rpx; }
.cat-card-list { display: inline-flex; gap: 14rpx; padding-right: 36rpx; }
.cat-card { display: inline-flex; flex-direction: column; width: 220rpx; background: var(--color-bg-card); border-radius: 20rpx; overflow: hidden; flex-shrink: 0; border: 1rpx solid var(--color-border); }
.cat-card-cover { height: 120rpx; position: relative; display: flex; align-items: flex-end; justify-content: flex-end; padding: 10rpx 14rpx; }
.cat-card-duration-badge { font-size: 20rpx; color: rgba(255,255,255,0.85); background: rgba(0,0,0,0.3); padding: 3rpx 10rpx; border-radius: 8rpx; }
.cat-card-body { padding: 12rpx 14rpx 14rpx; }
.cat-card-title { font-size: 24rpx; font-weight: 700; color: var(--color-text); display: block; line-height: 1.4; white-space: normal; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; }

.drawer-section { padding: 0 36rpx; margin-bottom: 24rpx; }
.drawer-toggle { display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 20rpx; background: var(--color-bg-card); border-radius: 20rpx; border: 1rpx dashed rgba(124,111,247,0.2); }
.drawer-toggle-text { font-size: 26rpx; font-weight: 600; color: var(--color-primary); }
.drawer-toggle-icon { font-size: 16rpx; color: var(--color-primary); }
.drawer-content { overflow: hidden; transition: max-height 0.35s ease; }
.drawer-open { max-height: 5000rpx; }
.drawer-closed { max-height: 0; }

.onboarding-prompt { display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 48rpx; }
.onboarding-card { display: flex; flex-direction: column; align-items: center; padding: 80rpx 48rpx; background: var(--color-bg-card); border-radius: var(--radius-xl); text-align: center; border: 1rpx solid var(--color-border); }
.onboarding-title { font-size: var(--font-size-xl); font-weight: 700; margin-bottom: 16rpx; color: var(--color-text); }
.onboarding-desc { font-size: var(--font-size-base); color: var(--color-text-secondary); margin-bottom: 48rpx; }

.section { margin-bottom: 16rpx; }
.meditation-card { display: flex; align-items: center; background: var(--color-bg-card); border-radius: 20rpx; padding: 20rpx; margin: 0 36rpx; gap: 16rpx; border: 1rpx solid var(--color-border); }
.meditation-cover { width: 72rpx; height: 72rpx; border-radius: 16rpx; display: flex; justify-content: center; align-items: center; flex-shrink: 0; }
.meditation-info { display: flex; flex-direction: column; gap: 4rpx; }
.meditation-title { font-size: 26rpx; font-weight: 600; color: var(--color-text); }

.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: var(--font-size-sm); }
.loading-container { display: flex; justify-content: center; align-items: center; height: 60vh; }
