/* pages/index/index.wxss - 首页 v7.0 — 极简·沉浸·行动 */

.page { min-height: 100vh; background: var(--bg); }

/* 新用户 */
.full-center {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 48rpx;
}
.emoji-xl { font-size: 96rpx; margin-bottom: 32rpx; }
.title-lg { font-size: 48rpx; font-weight: 800; color: var(--text); display: block; margin-bottom: 12rpx; }
.sub { font-size: 28rpx; color: var(--text-dim); display: block; margin-bottom: 48rpx; }

/* ═══ 全屏沉浸层 ═══ */
.hero {
  position: fixed; top: 0; left: 0; right: 0; height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  pointer-events: none;
  transition: opacity 0.5s ease;
  z-index: 10;
}
.hero-hide { opacity: 0; }

/* 唯一呼吸光 */
.breath-light {
  position: absolute;
  width: 500rpx; height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(124,111,247,0.12) 0%, transparent 70%);
  animation: breathe 6s ease-in-out infinite;
  pointer-events: none;
}

/* 能力值 — 五个小点 */
.ability-row {
  display: flex; gap: 24rpx; margin-bottom: 60rpx;
  position: relative; z-index: 2;
}
.ab { display: flex; align-items: center; justify-content: center; }
.ab-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  transition: opacity 0.3s;
}

/* 行动文字 */
.action-zone {
  text-align: center; margin-bottom: 48rpx;
  position: relative; z-index: 2;
  pointer-events: auto;
}
.action-label {
  font-size: 22rpx; color: var(--accent); font-weight: 600;
  letter-spacing: 4rpx; display: block; margin-bottom: 12rpx;
}
.action-title {
  font-size: 52rpx; font-weight: 900; color: #fff; display: block;
  line-height: 1.2; margin-bottom: 8rpx;
}
.action-sub {
  font-size: 26rpx; color: var(--text-dim); display: block;
}

/* CTA */
.hero-cta {
  position: relative; z-index: 2;
  pointer-events: auto;
  margin-bottom: 60rpx;
}

/* 滑动提示 */
.scroll-hint {
  position: relative; z-index: 2;
  opacity: 0.3; transition: opacity 0.3s;
}
.scroll-hint.hint-hide { opacity: 0; }
.scroll-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: #fff; opacity: 0.4;
  animation: float 2s ease-in-out infinite;
}

/* ═══ 下方滚动 ═══ */
.scroll { height: 100vh; position: relative; z-index: 2; }
.scroll-gap { height: 100vh; pointer-events: none; }

/* 计划行 */
.plan-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 36rpx; margin: 0 36rpx 2rpx;
  background: var(--surface);
  border-radius: 16rpx;
}
.plan-left { display: flex; align-items: center; gap: 16rpx; }
.plan-day { font-size: 24rpx; font-weight: 800; color: var(--primary); }
.plan-title { font-size: 28rpx; font-weight: 600; color: var(--text); }
.plan-go { font-size: 32rpx; color: var(--text-dim); }

/* 推荐行 */
.rec-row {
  display: flex; align-items: center; gap: 16rpx;
  padding: 28rpx 36rpx; margin: 0 36rpx 2rpx;
  background: var(--surface);
  border-radius: 16rpx;
}
.rec-title { flex: 1; font-size: 28rpx; font-weight: 600; color: var(--text); }
.rec-dur { font-size: 24rpx; color: var(--text-dim); }
.rec-go { font-size: 32rpx; color: var(--text-dim); }

/* 链接行 */
.link-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 36rpx; margin: 2rpx 36rpx;
  font-size: 28rpx; color: var(--text-dim);
}
.link-go { font-size: 28rpx; }
