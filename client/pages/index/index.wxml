<!--pages/index/index.wxml - 首页 v2.0 - 小红书瀑布流版-->
<view class="page-index">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-secondary">加载中...</text>
  </view>

  <block wx:else>
    <!-- 未完成 onboarding -->
    <view wx:if="{{!hasProfile}}" class="onboarding-prompt">
      <view class="onboarding-card">
        <text class="onboarding-emoji">💪</text>
        <text class="onboarding-title">欢迎来到 HH</text>
        <text class="onboarding-desc">回答几个问题，为你定制专属运动计划</text>
        <view class="btn-primary" bindtap="startOnboarding">
          <text>开始设置</text>
        </view>
      </view>
    </view>

    <!-- 已完成 onboarding -->
    <block wx:if="{{hasProfile}}">
      <scroll-view scroll-y class="home-scroll" enhanced="{{true}}">

        <!-- 顶部简短问候 -->
        <view class="greeting-bar">
          <text class="greeting-icon">{{timeIcon}}</text>
          <text class="greeting-text">{{greeting}}</text>
        </view>

        <!-- ★ 今日行动 - 主推荐大卡片 -->
        <view class="hero-section" wx:if="{{primaryRecommend}}" bindtap="onPrimaryTap">
          <view class="hero-card" style="background: {{primaryRecommend.cover_gradient || 'linear-gradient(160deg, #7c6ff7, #4ecdc4)'}}">
            <text class="hero-emoji-bg">{{primaryRecommend.emoji || '💪'}}</text>
            <view class="hero-tags">
              <text class="hero-tag">{{primaryRecommend.category_label}}</text>
              <text class="hero-tag" wx:if="{{primaryRecommend.difficulty}}">{{primaryRecommend.difficulty}}</text>
            </view>
            <view class="hero-content">
              <text class="hero-title">{{primaryRecommend.title}}</text>
              <text class="hero-subtitle">{{primaryRecommend.subtitle}}</text>
            </view>
            <view class="hero-footer">
              <view class="hero-meta">
                <text class="hero-meta-item">⏱ {{primaryRecommend.duration_text}}</text>
              </view>
              <view class="hero-start-btn">
                <text>开始跟练</text>
              </view>
            </view>
          </view>
        </view>

        <!-- ★ AI 智能推荐 - 小红书瀑布流 -->
        <view class="recommend-section" wx:if="{{recommendCards.length > 0}}">
          <view class="section-header">
            <text class="section-title">为你推荐</text>
            <text class="section-sub">AI 根据你的状态智能推荐</text>
          </view>

          <!-- 双列瀑布流 -->
          <view class="waterfall">
            <!-- 左列 -->
            <view class="waterfall-col">
              <view
                wx:for="{{recommendCards}}"
                wx:key="id"
                wx:if="{{index % 2 === 0}}"
                class="rec-card {{item.card_height === 'tall' ? 'rec-card-tall' : 'rec-card-short'}}"
                data-id="{{item.id}}"
                bindtap="onCardTap"
              >
                <!-- 封面区 -->
                <view class="rec-cover" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
                  <text class="rec-cover-emoji">{{item.emoji}}</text>
                </view>
                <!-- 信息区 -->
                <view class="rec-body">
                  <text class="rec-title">{{item.title}}</text>
                  <!-- AI 推荐理由 -->
                  <view class="rec-reason" wx:if="{{item.reason}}">
                    <text class="rec-reason-icon">{{item.reason.icon}}</text>
                    <text class="rec-reason-text">{{item.reason.reason}}</text>
                  </view>
                  <view class="rec-footer">
                    <text class="rec-duration">⏱ {{item.duration_text}}</text>
                    <text class="rec-tag" wx:if="{{item.reason}}">{{item.reason.tag}}</text>
                  </view>
                </view>
              </view>
            </view>
            <!-- 右列 -->
            <view class="waterfall-col">
              <view
                wx:for="{{recommendCards}}"
                wx:key="id"
                wx:if="{{index % 2 === 1}}"
                class="rec-card {{item.card_height === 'tall' ? 'rec-card-tall' : 'rec-card-short'}}"
                data-id="{{item.id}}"
                bindtap="onCardTap"
              >
                <view class="rec-cover" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
                  <text class="rec-cover-emoji">{{item.emoji}}</text>
                </view>
                <view class="rec-body">
                  <text class="rec-title">{{item.title}}</text>
                  <view class="rec-reason" wx:if="{{item.reason}}">
                    <text class="rec-reason-icon">{{item.reason.icon}}</text>
                    <text class="rec-reason-text">{{item.reason.reason}}</text>
                  </view>
                  <view class="rec-footer">
                    <text class="rec-duration">⏱ {{item.duration_text}}</text>
                    <text class="rec-tag" wx:if="{{item.reason}}">{{item.reason.tag}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 静养入口 -->
        <view class="section" wx:if="{{meditationRecommend}}">
          <view class="section-header">
            <text class="section-title">🧘 静养</text>
          </view>
          <view class="meditation-card" bindtap="onMeditationTap">
            <view class="meditation-cover" style="background: {{meditationRecommend.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #9d93fa)'}}">
              <text class="meditation-emoji">{{meditationRecommend.emoji || '🧘'}}</text>
            </view>
            <view class="meditation-info">
              <text class="meditation-title">{{meditationRecommend.title}}</text>
              <text class="text-sm text-secondary">{{meditationRecommend.subtitle}}</text>
              <text class="text-sm text-muted">⏱ {{meditationRecommend.duration_text}}</text>
            </view>
          </view>
        </view>

        <view style="height: 40rpx;"></view>
      </scroll-view>
    </block>
  </block>
</view>
