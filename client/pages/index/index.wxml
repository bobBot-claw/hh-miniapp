<!--pages/index/index.wxml - 首页 v3.2 - 精简+悬浮TabBar-->
<view class="page-index">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-secondary">加载中...</text>
  </view>

  <block wx:else>
    <!-- 未完成 onboarding -->
    <view wx:if="{{!hasProfile}}" class="onboarding-prompt">
      <view class="onboarding-card">
        <text class="onboarding-title">欢迎来到 HH</text>
        <text class="onboarding-desc">回答几个问题，定制专属运动计划</text>
        <view class="btn-primary" bindtap="startOnboarding">
          <text>开始设置</text>
        </view>
      </view>
    </view>

    <!-- 已完成 onboarding -->
    <block wx:if="{{hasProfile}}">
      <scroll-view scroll-y class="home-scroll" enhanced="{{true}}">

        <!-- ═══ 第一屏 ═══ -->

        <!-- 顶部状态条 -->
        <view class="top-bar">
          <view class="top-bar-left">
            <text class="top-stat">连续{{userStats.streak || 0}}天</text>
            <text class="top-stat">今日{{userStats.total_minutes || 0}}min</text>
          </view>
          <view class="top-bar-right" bindtap="onProfileTap">
            <view class="top-avatar">
              <text class="top-avatar-text">我</text>
            </view>
          </view>
        </view>

        <!-- 今日训练 -->
        <view class="today-section">
          <view class="section-title-row">
            <text class="section-title-lg">今日训练</text>
            <view class="section-more" bindtap="onViewStats">
              <text class="section-more-icon">›</text>
            </view>
          </view>

          <!-- 大卡片 -->
          <view class="hero-card" wx:if="{{primaryRecommend}}" bindtap="onPrimaryTap">
            <view class="hero-cover" style="background: {{primaryRecommend.cover_gradient || 'linear-gradient(160deg, #2d2d52, #7c6ff7, #4ecdc4)'}}">
              <!-- 底部信息叠加 - 左标题右按钮 -->
              <view class="hero-overlay">
                <view class="hero-info-left">
                  <text class="hero-duration">{{primaryRecommend.duration_text}} · {{primaryRecommend.difficulty || '入门'}}</text>
                  <text class="hero-title">{{primaryRecommend.title}}</text>
                </view>
                <view class="hero-start-btn">
                  <text>立即开始</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 本周看见 -->
        <view class="week-section" wx:if="{{weekStats}}">
          <view class="section-title-row">
            <text class="section-title-md">本周看见</text>
            <view class="section-more" bindtap="onViewStats">
              <text class="section-more-icon">›</text>
            </view>
          </view>
          <scroll-view scroll-x class="week-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
            <view class="week-cards">
              <view class="week-card" wx:for="{{weekStats}}" wx:key="key">
                <text class="week-card-label">{{item.label}}</text>
                <view class="week-card-value-row">
                  <text class="week-card-value">{{item.value}}</text>
                  <text class="week-card-unit">{{item.unit}}</text>
                </view>
                <text class="week-card-compare">{{item.compare}}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- ═══ 训练计划 ═══ -->

        <view class="plan-section">
          <view class="section-title-row">
            <text class="section-title-md">训练计划</text>
            <view class="section-more" bindtap="onViewAllPlans">
              <text class="section-more-text">全部</text>
              <text class="section-more-icon">›</text>
            </view>
          </view>
          <scroll-view scroll-x class="plan-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
            <view class="plan-cards-row">
              <view 
                wx:for="{{planList}}" 
                wx:key="id"
                class="plan-card-mini"
                data-id="{{item.id}}"
                bindtap="onPlanTap"
              >
                <view class="plan-mini-cover" style="background: {{item.cover_gradient}}">
                  <text class="plan-mini-title">{{item.title}}</text>
                  <text class="plan-mini-sub">{{item.duration_days}}天 · {{item.difficulty}}</text>
                </view>
                <view class="plan-mini-tags">
                  <text wx:for="{{item.problem_tags}}" wx:for-item="tag" wx:key="*this" class="plan-mini-tag">{{tag}}</text>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- ═══ 第二屏起：分类分区推荐 ═══ -->

        <view class="page-break"></view>

        <view class="category-sections">
          <!-- 每个分类分区 -->
          <view wx:for="{{categorySections}}" wx:key="key" class="category-section">
            <!-- 分区头部 -->
            <view class="cat-header">
              <view class="cat-title-wrap">
                <text class="cat-title">{{item.label}}</text>
              </view>
              <view class="cat-reason" wx:if="{{item.section_reason}}">
                <text class="cat-reason-text">{{item.section_reason.text}}</text>
              </view>
            </view>

            <!-- 横滑卡片 -->
            <scroll-view scroll-x class="cat-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
              <view class="cat-card-list">
                <view
                  wx:for="{{item.exercises}}"
                  wx:for-item="ex"
                  wx:key="id"
                  class="cat-card"
                  data-id="{{ex.id}}"
                  bindtap="onCardTap"
                >
                  <view class="cat-card-cover" style="background: {{ex.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
                  </view>
                  <view class="cat-card-body">
                    <text class="cat-card-title">{{ex.title}}</text>
                    <text class="cat-card-sub">{{ex.subtitle}}</text>
                    <view class="cat-card-reason" wx:if="{{ex.reason}}">
                      <text class="cat-card-reason-text">{{ex.reason.reason}}</text>
                    </view>
                    <view class="cat-card-footer">
                      <text class="cat-card-duration">{{ex.duration_text}}</text>
                      <text class="cat-card-tag" wx:if="{{ex.reason}}">{{ex.reason.tag}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </scroll-view>
          </view>

          <!-- 更多抽屉 -->
          <view class="drawer-section">
            <view class="drawer-toggle" bindtap="onToggleDrawer">
              <text class="drawer-toggle-text">{{showMore ? '收起' : '更多推荐'}}</text>
              <text class="drawer-toggle-icon">{{showMore ? '▲' : '▼'}}</text>
            </view>
            <view class="drawer-content {{showMore ? 'drawer-open' : 'drawer-closed'}}">
              <view
                wx:for="{{moreCategories}}"
                wx:key="key"
                class="category-section"
              >
                <view class="cat-header">
                  <view class="cat-title-wrap">
                    <text class="cat-title">{{item.label}}</text>
                  </view>
                  <view class="cat-reason" wx:if="{{item.section_reason}}">
                    <text class="cat-reason-text">{{item.section_reason.text}}</text>
                  </view>
                </view>
                <scroll-view scroll-x class="cat-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
                  <view class="cat-card-list">
                    <view
                      wx:for="{{item.exercises}}"
                      wx:for-item="ex"
                      wx:key="id"
                      class="cat-card"
                      data-id="{{ex.id}}"
                      bindtap="onCardTap"
                    >
                      <view class="cat-card-cover" style="background: {{ex.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
                      </view>
                      <view class="cat-card-body">
                        <text class="cat-card-title">{{ex.title}}</text>
                        <text class="cat-card-sub">{{ex.subtitle}}</text>
                        <view class="cat-card-reason" wx:if="{{ex.reason}}">
                          <text class="cat-card-reason-text">{{ex.reason.reason}}</text>
                        </view>
                        <view class="cat-card-footer">
                          <text class="cat-card-duration">{{ex.duration_text}}</text>
                          <text class="cat-card-tag" wx:if="{{ex.reason}}">{{ex.reason.tag}}</text>
                        </view>
                      </view>
                    </view>
                  </view>
                </scroll-view>
              </view>
            </view>
          </view>
        </view>

        <!-- 静养入口 -->
        <view class="section" wx:if="{{meditationRecommend}}">
          <view class="section-title-row">
            <text class="section-title-md">静养</text>
          </view>
          <view class="meditation-card" bindtap="onMeditationTap">
            <view class="meditation-cover" style="background: {{meditationRecommend.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #9d93fa)'}}">
            </view>
            <view class="meditation-info">
              <text class="meditation-title">{{meditationRecommend.title}}</text>
              <text class="text-sm text-secondary">{{meditationRecommend.subtitle}}</text>
              <text class="text-sm text-muted">{{meditationRecommend.duration_text}}</text>
            </view>
          </view>
        </view>

        <!-- 底部留白给悬浮TabBar -->
        <view style="height: 160rpx;"></view>
      </scroll-view>
    </block>
  </block>

</view>
