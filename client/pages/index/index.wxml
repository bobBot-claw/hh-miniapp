<!--pages/index/index.wxml - 首页 v2.0 - 分区横滑版-->
<view class="page-index">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-secondary">加载中...</text>
  </view>

  <block wx:else>
    <!-- 未完成 onboarding -->
    <view wx:if="{{!hasProfile}}" class="onboarding-prompt">
      <view class="onboarding-card">
        <text class="onboarding-emoji">💪</text>
        <text class="onboarding-title">欢迎来到 HH</text>
        <text class="onboarding-desc">回答几个问题，为你定制专属运动计划</text>
        <view class="btn-primary" bindtap="startOnboarding">
          <text>开始设置</text>
        </view>
      </view>
    </view>

    <!-- 已完成 onboarding -->
    <block wx:if="{{hasProfile}}">
      <scroll-view scroll-y class="home-scroll" enhanced="{{true}}">

        <!-- ═══ 第一屏：今日行动 + 进度 ═══ -->

        <!-- 问候 -->
        <view class="greeting-bar">
          <text class="greeting-icon">{{timeIcon}}</text>
          <text class="greeting-text">{{greeting}}</text>
        </view>

        <!-- 今日行动主卡片 -->
        <view class="hero-section" wx:if="{{primaryRecommend}}" bindtap="onPrimaryTap">
          <view class="hero-card" style="background: {{primaryRecommend.cover_gradient || 'linear-gradient(160deg, #7c6ff7, #4ecdc4)'}}">
            <text class="hero-emoji-bg">{{primaryRecommend.emoji || '💪'}}</text>
            <view class="hero-tags">
              <text class="hero-tag">{{primaryRecommend.category_label}}</text>
              <text class="hero-tag" wx:if="{{primaryRecommend.difficulty}}">{{primaryRecommend.difficulty}}</text>
            </view>
            <view class="hero-content">
              <text class="hero-title">{{primaryRecommend.title}}</text>
              <text class="hero-subtitle">{{primaryRecommend.subtitle}}</text>
            </view>
            <view class="hero-footer">
              <view class="hero-meta">
                <text class="hero-meta-item">⏱ {{primaryRecommend.duration_text}}</text>
              </view>
              <view class="hero-start-btn">
                <text>开始跟练</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 进度展示 -->
        <view class="progress-section" wx:if="{{userStats}}">
          <view class="progress-header">
            <text class="progress-title">🔥 连续{{userStats.streak || 0}}天 · 已运动{{userStats.total_exercises || 0}}次</text>
            <text class="progress-link" bindtap="onViewStats">详情 ›</text>
          </view>
          <view class="progress-bars">
            <view class="progress-item" wx:for="{{userStats.abilities}}" wx:key="key">
              <text class="progress-emoji">{{item.emoji}}</text>
              <view class="progress-bar-bg">
                <view class="progress-bar-fill" style="width: {{item.value}}%; background: {{item.color}};"></view>
              </view>
              <text class="progress-value">{{item.value}}</text>
            </view>
          </view>
        </view>

        <!-- ═══ 第二屏起：分类分区推荐 ═══ -->

        <view class="category-sections">
          <!-- 每个分类分区 -->
          <view wx:for="{{categorySections}}" wx:key="key" class="category-section">
            <!-- 分区头部 -->
            <view class="cat-header">
              <view class="cat-title-wrap">
                <text class="cat-emoji">{{item.emoji}}</text>
                <text class="cat-title">{{item.label}}</text>
              </view>
              <view class="cat-reason" wx:if="{{item.section_reason}}">
                <text class="cat-reason-icon">{{item.section_reason.icon}}</text>
                <text class="cat-reason-text">{{item.section_reason.text}}</text>
              </view>
            </view>

            <!-- 横滑卡片 -->
            <scroll-view scroll-x class="cat-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
              <view class="cat-card-list">
                <view
                  wx:for="{{item.exercises}}"
                  wx:for-item="ex"
                  wx:key="id"
                  class="cat-card"
                  data-id="{{ex.id}}"
                  bindtap="onCardTap"
                >
                  <view class="cat-card-cover" style="background: {{ex.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
                    <text class="cat-card-emoji">{{ex.emoji}}</text>
                  </view>
                  <view class="cat-card-body">
                    <text class="cat-card-title">{{ex.title}}</text>
                    <text class="cat-card-sub">{{ex.subtitle}}</text>
                    <view class="cat-card-reason" wx:if="{{ex.reason}}">
                      <text class="cat-card-reason-text">{{ex.reason.icon}} {{ex.reason.reason}}</text>
                    </view>
                    <view class="cat-card-footer">
                      <text class="cat-card-duration">⏱ {{ex.duration_text}}</text>
                      <text class="cat-card-tag" wx:if="{{ex.reason}}">{{ex.reason.tag}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </scroll-view>
          </view>

          <!-- 更多抽屉 -->
          <view class="drawer-section">
            <view class="drawer-toggle" bindtap="onToggleDrawer">
              <text class="drawer-toggle-text">{{showMore ? '收起' : '更多推荐'}}</text>
              <text class="drawer-toggle-icon">{{showMore ? '▲' : '▼'}}</text>
            </view>
            <view class="drawer-content {{showMore ? 'drawer-open' : 'drawer-closed'}}">
              <view
                wx:for="{{moreCategories}}"
                wx:key="key"
                class="category-section"
              >
                <view class="cat-header">
                  <view class="cat-title-wrap">
                    <text class="cat-emoji">{{item.emoji}}</text>
                    <text class="cat-title">{{item.label}}</text>
                  </view>
                  <view class="cat-reason" wx:if="{{item.section_reason}}">
                    <text class="cat-reason-icon">{{item.section_reason.icon}}</text>
                    <text class="cat-reason-text">{{item.section_reason.text}}</text>
                  </view>
                </view>
                <scroll-view scroll-x class="cat-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
                  <view class="cat-card-list">
                    <view
                      wx:for="{{item.exercises}}"
                      wx:for-item="ex"
                      wx:key="id"
                      class="cat-card"
                      data-id="{{ex.id}}"
                      bindtap="onCardTap"
                    >
                      <view class="cat-card-cover" style="background: {{ex.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
                        <text class="cat-card-emoji">{{ex.emoji}}</text>
                      </view>
                      <view class="cat-card-body">
                        <text class="cat-card-title">{{ex.title}}</text>
                        <text class="cat-card-sub">{{ex.subtitle}}</text>
                        <view class="cat-card-reason" wx:if="{{ex.reason}}">
                          <text class="cat-card-reason-text">{{ex.reason.icon}} {{ex.reason.reason}}</text>
                        </view>
                        <view class="cat-card-footer">
                          <text class="cat-card-duration">⏱ {{ex.duration_text}}</text>
                          <text class="cat-card-tag" wx:if="{{ex.reason}}">{{ex.reason.tag}}</text>
                        </view>
                      </view>
                    </view>
                  </view>
                </scroll-view>
              </view>
            </view>
          </view>
        </view>

        <!-- 静养入口 -->
        <view class="section" wx:if="{{meditationRecommend}}">
          <view class="section-header">
            <text class="section-title">🧘 静养</text>
          </view>
          <view class="meditation-card" bindtap="onMeditationTap">
            <view class="meditation-cover" style="background: {{meditationRecommend.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #9d93fa)'}}">
              <text class="meditation-emoji">{{meditationRecommend.emoji || '🧘'}}</text>
            </view>
            <view class="meditation-info">
              <text class="meditation-title">{{meditationRecommend.title}}</text>
              <text class="text-sm text-secondary">{{meditationRecommend.subtitle}}</text>
              <text class="text-sm text-muted">⏱ {{meditationRecommend.duration_text}}</text>
            </view>
          </view>
        </view>

        <view style="height: 60rpx;"></view>
      </scroll-view>
    </block>
  </block>
</view>
