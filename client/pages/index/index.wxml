<!--pages/index/index.wxml - 首页 v7.0 — 极简·沉浸·行动-->

<view class="page">
  <!-- 新用户 -->
  <view wx:if="{{!hasProfile}}" class="full-center">
    <text class="emoji-xl">🏃</text>
    <text class="title-lg">开始你的行动</text>
    <text class="sub">回答几个问题，定制专属计划</text>
    <view class="cta" bindtap="startOnboarding"><text>开始</text></view>
  </view>

  <!-- 老用户 -->
  <block wx:if="{{hasProfile}}">
    <!-- 全屏沉浸 — 呼吸光 + 行动 -->
    <view class="hero {{heroCollapsed ? 'hero-hide' : ''}}">
      <view class="breath-light"></view>

      <!-- 能力值 — 极简横条 -->
      <view class="ability-row">
        <view wx:for="{{abilities}}" wx:key="key" class="ab">
          <view class="ab-dot" style="background: {{item.color}}; opacity: {{0.3 + item.value / 150}};"></view>
        </view>
      </view>

      <!-- 核心行动 -->
      <view class="action-zone" bindtap="onHeroStart">
        <text class="action-label">今日训练</text>
        <text class="action-title">{{heroTitle}}</text>
        <text class="action-sub">{{heroSub}}</text>
      </view>

      <!-- CTA -->
      <view class="cta hero-cta" bindtap="onHeroStart">
        <text>开始</text>
      </view>

      <!-- 滑动提示 -->
      <view class="scroll-hint {{heroCollapsed ? 'hint-hide' : ''}}">
        <view class="scroll-dot"></view>
      </view>
    </view>

    <!-- 下方 — 最少信息 -->
    <scroll-view scroll-y class="scroll" bindscroll="onHomeScroll">
      <view class="scroll-gap"></view>

      <!-- 活跃计划摘要 -->
      <view wx:if="{{activePlan && !activePlan.isCompleted && todayInfo}}" class="plan-row" bindtap="onPlanContinue">
        <view class="plan-left">
          <text class="plan-day">DAY {{todayInfo.dayNum}}</text>
          <text class="plan-title">{{activePlan.planTitle}}</text>
        </view>
        <text class="plan-go">›</text>
      </view>

      <view wx:elif="{{activePlan && activePlan.isCompleted}}" class="plan-row" bindtap="onPlanCompleteTap">
        <text class="plan-title">✓ {{activePlan.planTitle}} 已完成</text>
      </view>

      <!-- 推荐运动 — 单条 -->
      <view wx:if="{{primaryRecommend && !activePlan}}" class="rec-row" bindtap="onPrimaryTap">
        <text class="rec-title">{{primaryRecommend.title}}</text>
        <text class="rec-dur">{{primaryRecommend.duration_text}}</text>
        <text class="rec-go">›</text>
      </view>

      <!-- 训练计划入口 -->
      <view class="link-row" bindtap="onViewAllPlans">
        <text>训练计划</text>
        <text class="link-go">›</text>
      </view>

      <!-- 静养入口 -->
      <view wx:if="{{meditationRecommend}}" class="link-row" bindtap="onMeditationTap">
        <text>静养 · {{meditationRecommend.title}}</text>
        <text class="link-go">›</text>
      </view>

      <view style="height: 160rpx;"></view>
    </scroll-view>
  </block>
</view>
