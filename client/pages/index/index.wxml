<!--pages/index/index.wxml - 首页（今日行动）v2.0-->
<view class="page-index">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-secondary">加载中...</text>
  </view>

  <block wx:else>
    <!-- 未完成 onboarding -->
    <view wx:if="{{!hasProfile}}" class="onboarding-prompt">
      <view class="onboarding-card">
        <text class="onboarding-emoji">💪</text>
        <text class="onboarding-title">欢迎来到 HH</text>
        <text class="onboarding-desc">回答几个问题，为你定制专属运动计划</text>
        <view class="btn-primary" bindtap="startOnboarding">
          <text>开始设置</text>
        </view>
      </view>
    </view>

    <!-- 已完成 onboarding - 今日行动首页 -->
    <block wx:if="{{hasProfile}}">
      <scroll-view scroll-y class="home-scroll">

        <!-- 每日问候区 -->
        <view class="greeting-section">
          <view class="greeting-row">
            <text class="greeting-icon">{{timeIcon}}</text>
            <text class="greeting-text">{{greeting}}</text>
          </view>
          <text wx:if="{{dailyText}}" class="daily-text">{{dailyText}}</text>
        </view>

        <!-- 今日行动 - 主推荐 -->
        <view class="section" wx:if="{{primaryRecommend}}">
          <view class="section-header">
            <text class="section-title">🎯 今日行动</text>
          </view>

          <view class="primary-card" bindtap="onPrimaryTap">
            <view class="primary-cover" style="background: {{primaryRecommend.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
              <text class="primary-emoji">{{primaryRecommend.emoji || '💪'}}</text>
            </view>
            <view class="primary-info">
              <text class="primary-title">{{primaryRecommend.title}}</text>
              <text class="primary-subtitle text-secondary">{{primaryRecommend.subtitle}}</text>
              <view class="primary-meta flex-row">
                <text class="text-sm text-muted">⏱ {{primaryRecommend.duration_text}}</text>
                <text class="text-sm text-muted">{{primaryRecommend.category_label}}</text>
                <text wx:if="{{primaryRecommend.difficulty}}" class="tag">{{primaryRecommend.difficulty}}</text>
              </view>
            </view>
            <view class="primary-action">
              <text class="action-btn-text">开始跟练 →</text>
            </view>
          </view>
        </view>

        <!-- 备选行动 -->
        <view class="section" wx:if="{{alternatives.length > 0}}">
          <view class="section-header">
            <text class="section-title">💡 或者试试</text>
          </view>
          <view class="alt-list">
            <view
              wx:for="{{alternatives}}"
              wx:key="id"
              class="alt-card"
              data-id="{{item.id}}"
              bindtap="onAltTap"
            >
              <view class="alt-emoji-wrap" style="background: {{item.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #4ecdc4)'}}">
                <text class="alt-emoji">{{item.emoji || '⚡'}}</text>
              </view>
              <view class="alt-info">
                <text class="alt-title">{{item.title}}</text>
                <text class="alt-meta text-sm text-muted">⏱ {{item.duration_text}} · {{item.category_label}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 能力值快速展示 -->
        <view class="section" wx:if="{{userStats}}">
          <view class="section-header">
            <text class="section-title">🔥 连续{{userStats.streak || 0}}天 · 活力值 {{userStats.vitality || 0}}</text>
          </view>
          <view class="stat-bar-wrap">
            <view class="stat-bar-bg">
              <view class="stat-bar-fill" style="width: {{userStats.vitality || 0}}%;"></view>
            </view>
          </view>
          <view class="stat-weekly-row">
            <text class="text-sm text-secondary">本周变化</text>
            <text class="text-sm text-accent">体态健康 +12</text>
          </view>
        </view>

        <!-- 静养入口（辅助） -->
        <view class="section" wx:if="{{meditationRecommend}}">
          <view class="section-header">
            <text class="section-title">🧘 静养</text>
          </view>
          <view class="meditation-card" bindtap="onMeditationTap">
            <view class="meditation-cover" style="background: {{meditationRecommend.cover_gradient || 'linear-gradient(135deg, #7c6ff7, #9d93fa)'}}">
              <text class="meditation-emoji">{{meditationRecommend.emoji || '🧘'}}</text>
            </view>
            <view class="meditation-info">
              <text class="meditation-title">{{meditationRecommend.title}}</text>
              <text class="text-sm text-secondary">{{meditationRecommend.subtitle}}</text>
              <text class="text-sm text-muted">⏱ {{meditationRecommend.duration_text}}</text>
            </view>
          </view>
        </view>

        <!-- 底部留白 -->
        <view style="height: 40rpx;"></view>
      </scroll-view>
    </block>
  </block>
</view>
