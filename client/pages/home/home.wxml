<!--pages/home/home.wxml — 主页：与 demo 完全一致-->

<view class="page">
  <!-- 背景：模糊插画 -->
  <image class="bg-egg {{revealed?'bg-egg-lit':'bg-egg-dim'}}" src="{{eggUrl}}" mode="aspectFill" />

  <!-- 6 光点 -->
  <view class="particles">
    <view class="particle" style="left:18%;animation-delay:0s;"></view>
    <view class="particle" style="left:48%;animation-delay:2s;"></view>
    <view class="particle" style="left:78%;animation-delay:4s;"></view>
    <view class="particle" style="left:33%;animation-delay:6s;"></view>
    <view class="particle" style="left:63%;animation-delay:1s;"></view>
    <view class="particle" style="left:88%;animation-delay:3s;"></view>
  </view>

  <!-- 右上角世界入口 — demo 只有一个 ◉ -->
  <view class="top-icon" style="top:{{topBarTop}}px;right:{{topBarRight}}px;" bindtap="goWorld">
    <view class="icon-globe"></view>
  </view>

  <!-- 中央内容 — demo: flame → title → sub → btn-glow → btn-text -->
  <view class="home-content">
    <view class="flame {{revealed?'flame-lit':''}}">
      <text class="flame-icon">✦</text>
    </view>

    <text class="home-title">{{actionTitle}}</text>
    <text class="home-sub">{{actionSub}}</text>

    <view class="btn-glow" bindtap="startAction"><text>{{ctaText}}</text></view>
    <view class="btn-text" bindtap="resetDay"><text>重 置 状 态</text></view>
  </view>
</view>
