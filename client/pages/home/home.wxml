<!--pages/home/home.wxml — 主页 v0.7 demo 风格-->

<view class="page warm-bg">
  <image class="illust-bg {{revealed?'illust-lit':'illust-dim'}}" src="{{currentEgg.blurUrl}}" mode="aspectFill" />

  <view class="particles">
    <view class="particle p1"></view>
    <view class="particle p2"></view>
    <view class="particle p3"></view>
    <view class="particle p4"></view>
    <view class="particle p5"></view>
    <view class="particle p6"></view>
  </view>

  <view wx:if="{{!hasEgg}}" class="bg-fallback"></view>

  <view class="top-bar" style="top:{{topBarTop}}px;right:{{topBarRight}}px;">
    <view class="top-icon" bindtap="goTogether"><view class="icon-together"></view></view>
    <view class="top-icon" bindtap="goWorld"><view class="icon-world"></view></view>
    <view class="top-icon" bindtap="goMood"><view class="icon-mood"></view></view>
  </view>

  <view class="content">
    <view class="center">
      <view class="flame {{revealed?'flame-lit':''}}">
        <text class="flame-icon">✦</text>
      </view>

      <text class="home-title">{{actionTitle}}</text>
      <text class="home-sub">{{actionSub}}</text>
      <view class="duration-tag"><text>{{durationText}}</text></view>

      <view class="cta" bindtap="startAction"><text>{{ctaText}}</text></view>

      <view wx:if="{{!revealed}}" class="together-entry" bindtap="goTogether">
        <view class="together-entry-icon"></view>
        <text class="together-entry-text">邀请好友</text>
      </view>

      <text wx:if="{{revealed&&tomorrowHint}}" class="tomorrow-hint">{{tomorrowHint}}</text>

      <view class="btn-text-inverse" bindtap="resetDay" style="margin-top:24rpx;"><text>重置状态</text></view>
    </view>
  </view>
</view>
