/* pages/home/home.wxss — 主页：日间七日微光 + 夜间安眠模式 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  background: var(--bg);
}

/* ========== 夜间模式 ========== */
.page.night {
  background: #0A0A0F;
}

.night-view {
  width: 100%; min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
}

.night-sky {
  display: flex; flex-direction: column; align-items: center;
  width: 100%; padding-top: 40vh;
}

/* 月牙 */
.moon {
  position: relative;
  width: 120rpx; height: 120rpx;
  margin-bottom: 64rpx;
}
.moon-body {
  position: absolute;
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 240, 0.08);
  box-shadow: 0 0 60rpx 20rpx rgba(255, 255, 240, 0.04);
}
.moon-shadow {
  position: absolute;
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  background: #0A0A0F;
  top: -16rpx; left: 20rpx;
}

/* 夜间文字 */
.night-word {
  font-size: 28rpx; font-weight: 300;
  color: rgba(255, 255, 240, 0.25);
  letter-spacing: 0.16em;
  line-height: 1.8;
  text-align: center;
  padding: 0 80rpx;
  margin-bottom: 120rpx;
  white-space: pre-line;
}

.night-time {
  font-size: 22rpx; font-weight: 300;
  color: rgba(255, 255, 240, 0.12);
  letter-spacing: 0.3em;
}

/* ========== 日间模式 ========== */

/* 暖色光晕 */
.halo {
  position: fixed; pointer-events: none; z-index: 0;
  border-radius: 50%; filter: blur(140px); opacity: 0.5;
}
.halo-1 {
  width: 680px; height: 680px;
  background: var(--halo-cream);
  top: -200px; right: -200px;
}
.halo-2 {
  width: 480px; height: 480px;
  background: var(--halo-gold);
  bottom: -200px; left: -200px;
  opacity: 0.3;
}

.scroll {
  position: relative; z-index: 1;
  height: 100vh;
  padding: 72rpx 44rpx 0;
}

/* 顶部行 — slogan */
.top-row {
  margin-bottom: 44rpx;
}
.slogan-l {
  font-size: 24rpx; letter-spacing: 0.2em; color: var(--ink-mute);
  font-weight: 300;
}

/* 推荐卡 */
.recommend {
  background: linear-gradient(150deg, var(--warm) 0%, var(--warm-2) 100%);
  border-radius: 48rpx;
  padding: 56rpx 48rpx;
  margin-bottom: 36rpx;
  position: relative;
}
.recommend .tag {
  font-size: 22rpx; letter-spacing: 0.3em; color: var(--gold);
  margin-bottom: 16rpx; display: block;
}
.rec-scene {
  font-size: 24rpx; color: var(--ink-mute);
  letter-spacing: 0.18em; margin-bottom: 16rpx; display: block;
}
.act-name {
  font-size: 64rpx; font-weight: 300; letter-spacing: 0.04em;
  margin-bottom: 12rpx; display: block; color: var(--ink);
}
.act-sub {
  font-size: 26rpx; color: var(--ink-mute);
  letter-spacing: 0.06em; margin-bottom: 44rpx; display: block;
}

/* 周历条 */
.week-bar {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 48rpx;
  padding: 36rpx 44rpx;
  margin-bottom: 36rpx;
}
.wb-head {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 28rpx;
}
.wb-t { font-size: 26rpx; color: var(--ink); }
.wb-num { font-size: 48rpx; font-weight: 300; letter-spacing: 0.04em; margin-right: 12rpx; }
.wb-s { font-size: 22rpx; letter-spacing: 0.18em; color: var(--ink-dim); }

/* 周历光点 */
.week-row {
  display: flex; justify-content: space-between; gap: 16rpx;
  padding: 8rpx 0;
}
.day-cell { flex: 1; text-align: center; position: relative; }
.d-pip {
  width: 28rpx; height: 28rpx; border-radius: 50%;
  margin: 0 auto 16rpx;
  background: var(--surface);
  border: 3rpx solid var(--dot);
  transition: 0.4s;
}
.day-cell.done .d-pip {
  background: var(--gold); border-color: var(--gold);
  box-shadow: 0 0 24rpx rgba(20, 125, 69, 0.4);
}
.day-cell.now .d-pip {
  background: var(--warm-2); border-color: var(--gold);
  box-shadow: 0 0 0 8rpx rgba(20, 125, 69, 0.18);
  animation: pulse 2.6s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.18); }
}
.d-lbl { font-size: 22rpx; letter-spacing: 0.16em; color: var(--ink-dim); }
.day-cell.done .d-lbl { color: var(--ink); }
.day-cell.now .d-lbl { color: var(--gold); font-weight: 400; }

/* 已收认知小卡 */
.know-section { margin-bottom: 24rpx; }
.know-title {
  font-size: 22rpx; letter-spacing: 0.24em; color: var(--ink-dim);
  margin-bottom: 20rpx; display: block;
}
.know-row { display: flex; gap: 20rpx; white-space: nowrap; padding-bottom: 8rpx; }
.know-card {
  flex: 0 0 auto;
  background: var(--surface); border: 1rpx solid var(--line);
  border-radius: 36rpx; padding: 28rpx 32rpx; width: 400rpx;
}
.kc-tag { font-size: 20rpx; letter-spacing: 0.24em; color: var(--gold); margin-bottom: 16rpx; display: block; }
.kc-t { font-size: 24rpx; color: var(--ink); line-height: 1.7; letter-spacing: 0.03em; white-space: normal; }

/* 工具入口 */
.tool-row { display: flex; justify-content: center; gap: 20rpx; flex-wrap: wrap; margin-top: 24rpx; margin-bottom: 24rpx; }
.tool-pill {
  padding: 16rpx 32rpx;
  border: 1rpx solid var(--line); border-radius: 60rpx;
  font-size: 24rpx; color: var(--ink-mute); letter-spacing: 0.18em;
  background: var(--surface);
}
.tool-pill text { color: var(--ink-mute); letter-spacing: 0.18em; }

/* 浮动按钮 */
.float-pill {
  position: fixed; left: 50%; transform: translateX(-50%);
  bottom: 80rpx;
  background: var(--ink); color: #fff;
  padding: 28rpx 48rpx; border-radius: 80rpx;
  font-size: 26rpx; letter-spacing: 0.18em;
  z-index: 10; display: flex; align-items: center;
  box-shadow: 0 24rpx 56rpx rgba(0, 0, 0, 0.16);
}
.float-pill text { color: #fff; letter-spacing: 0.18em; }
.dot {
  display: inline-block;
  width: 12rpx; height: 12rpx;
  background: var(--warm); border-radius: 50%;
  margin-right: 20rpx;
  animation: blink 1.4s infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
