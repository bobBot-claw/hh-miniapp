/* pages/home/home.wxss — 主页：暗+模糊插画+光点+行动 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
}

/* 背景插画 — 全屏 */
.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

/* 无插画时的渐变背景 */
.bg-fallback {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 70% 60% at 30% 30%, rgba(212, 183, 121, 0.3) 0%, transparent 60%),
    radial-gradient(ellipse 55% 50% at 70% 70%, rgba(201, 166, 107, 0.2) 0%, transparent 60%),
    linear-gradient(170deg, #2A2820 0%, #1a1810 100%);
  z-index: 0;
}

/* 光点漂浮 */
.particles {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.particle {
  position: absolute; bottom: 0;
  width: 10rpx; height: 10rpx;
  background: radial-gradient(circle, var(--gold-400) 0%, transparent 70%);
  border-radius: 50%;
  animation: float-particle 9s ease-in-out infinite;
  opacity: 0;
}
.p1 { left: 18%; animation-delay: 0s; }
.p2 { left: 48%; animation-delay: 2s; }
.p3 { left: 78%; animation-delay: 4s; }
.p4 { left: 33%; animation-delay: 6s; }
.p5 { left: 63%; animation-delay: 1s; }

/* 内容层 */
.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 0 64rpx;
}

/* 右上角世界入口 */
.top-right {
  position: fixed; top: 100rpx; right: 48rpx;
  z-index: 10;
}
/* 情绪天气入口 */
.top-right-2 {
  position: fixed; top: 100rpx; right: 148rpx;
  z-index: 10;
}
.top-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex; align-items: center; justify-content: center;
}
/* 单色线条世界图标 — 简约圆+内部线 */
.icon-world {
  width: 32rpx; height: 32rpx;
  border: 3rpx solid rgba(42, 40, 32, 0.5);
  border-radius: 50%;
  position: relative;
}
.icon-world::before {
  content: '';
  position: absolute;
  top: 50%; left: -2rpx; right: -2rpx;
  height: 2rpx;
  background: rgba(42, 40, 32, 0.5);
}
.icon-world::after {
  content: '';
  position: absolute;
  left: 50%; top: -2rpx; bottom: -2rpx;
  width: 2rpx;
  background: rgba(42, 40, 32, 0.5);
}
/* 情绪图标 — 弧线+点 */
.icon-mood {
  width: 32rpx; height: 32rpx;
  border: 3rpx solid rgba(42, 40, 32, 0.5);
  border-radius: 50%;
  position: relative;
  border-bottom-color: transparent;
}
.icon-mood::before {
  content: '';
  position: absolute;
  top: 8rpx; left: 8rpx;
  width: 5rpx; height: 5rpx;
  background: rgba(42, 40, 32, 0.5);
  border-radius: 50%;
}
.icon-mood::after {
  content: '';
  position: absolute;
  top: 8rpx; right: 8rpx;
  width: 5rpx; height: 5rpx;
  background: rgba(42, 40, 32, 0.5);
  border-radius: 50%;
}

/* 中央 */
.center {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
}

/* ✦ 光点 */
.flame {
  width: 128rpx; height: 128rpx;
  margin-bottom: 96rpx;
  background: radial-gradient(circle, rgba(232, 232, 232, 0.5) 0%, transparent 65%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  animation: breathe 3s ease-in-out infinite;
}
.flame-lit {
  background: radial-gradient(circle, var(--gold-400) 0%, var(--gold-600) 60%, transparent 80%);
  box-shadow: 0 0 64rpx var(--gold-400);
}
.flame-icon {
  font-size: 64rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 24rpx rgba(255, 255, 255, 0.5);
}

/* 标题 */
.home-title {
  font-size: 48rpx; font-weight: 300;
  color: var(--text-inverse);
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  display: block;
}
.home-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
  margin-bottom: 120rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  display: block;
}

/* 明天预告 */
.tomorrow-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
  margin-top: 32rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}
