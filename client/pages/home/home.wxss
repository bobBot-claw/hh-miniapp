/* pages/home/home.wxss — 主页：与 demo 完全一致 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
  background: #2A2820;
}

/* ═══ 背景彩蛋 ═══ */
.bg-egg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
  transition: filter 1.5s ease, opacity 1.5s ease;
}
/* 暗态 — demo: blur(12px) saturate(85%) brightness(0.65) */
.bg-egg-dim {
  filter: blur(12px) saturate(85%) brightness(0.65);
  opacity: 1;
}
/* 亮态 — demo: blur(0) saturate(105%) brightness(1) */
.bg-egg-lit {
  filter: blur(0) saturate(105%) brightness(1);
  opacity: 1;
}

/* ═══ 光点漂浮 — 6 个，demo 完全一致 ═══ */
.particles {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.particle {
  position: absolute; bottom: 0;
  width: 10rpx; height: 10rpx;
  background: radial-gradient(circle, var(--gold-400) 0%, transparent 70%);
  border-radius: 50%;
  animation: float 9s ease-in-out infinite;
  opacity: 0;
}
@keyframes float {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  10% { opacity: 0.9; }
  50% { transform: translateY(-50%) translateX(30rpx); opacity: 0.7; }
  90% { opacity: 0.4; }
  100% { transform: translateY(-110%) translateX(50rpx); opacity: 0; }
}

/* ═══ 右上角世界入口 — demo: 40px 圆形毛玻璃 ═══ */
.top-icon {
  position: fixed;
  z-index: 10;
  width: 80rpx; height: 80rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
/* ◉ 图标 — 圆+中心点 */
.icon-globe {
  width: 36rpx; height: 36rpx;
  border: 2.5rpx solid rgba(42, 40, 32, 0.6);
  border-radius: 50%;
  position: relative;
}
.icon-globe::before {
  content: '';
  position: absolute; top: 50%; left: 50%;
  width: 8rpx; height: 8rpx;
  background: rgba(42, 40, 32, 0.6);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* ═══ 中央内容 — demo 布局 ═══ */
.home-content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  padding: 120rpx 64rpx 80rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
}

/* ═══ ✦ 光点 — demo: 64px, rgba(232,232,232,0.5) ═══ */
.flame {
  width: 128rpx; height: 128rpx;
  margin-bottom: 96rpx;
  background: radial-gradient(circle, rgba(232, 232, 232, 0.5) 0%, transparent 65%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  animation: breathe 3s ease-in-out infinite;
}
/* 揭示后 — demo: radial-gradient(gold-400→gold-600) + box-shadow */
.flame-lit {
  background: radial-gradient(circle, var(--gold-400) 0%, var(--gold-600) 60%, transparent 80%);
  box-shadow: 0 0 64rpx var(--gold-400);
}
.flame-icon {
  font-size: 64rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 24rpx rgba(255, 255, 255, 0.5);
}
@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.1); opacity: 0.9; }
}

/* ═══ 标题 — demo: 22px, weight:300, 白色, letter-spacing:0.2em ═══ */
.home-title {
  font-size: 44rpx; font-weight: 300;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 0.2em;
  margin-bottom: 16rpx;
  display: block;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}
.home-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.2em;
  margin-bottom: 160rpx;
  display: block;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
}

/* ═══ 主按钮 — demo: btn-glow ═══ */
.btn-glow {
  background: var(--gold-500);
  color: #fff;
  font-size: 26rpx; font-weight: 500;
  letter-spacing: 0.3em;
  padding: 32rpx 112rpx;
  border: none; border-radius: 100rpx;
  box-shadow:
    0 4rpx 24rpx rgba(201, 166, 107, 0.5),
    0 1px 0 rgba(255, 255, 255, 0.4) inset;
}
.btn-glow text {
  color: #fff;
  letter-spacing: 0.3em;
}

/* ═══ 文字按钮 — demo: btn-text ═══ */
.btn-text {
  background: transparent;
  margin-top: 24rpx;
  padding: 24rpx 32rpx;
  border: none;
}
.btn-text text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx; font-weight: 400;
  letter-spacing: 0.3em;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
}
