/* pages/home/home.wxss — 主页：按 v0.7 demo 风格 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
  background: #FCFCFD;
}

/* 背景插画 — 全屏缩放 */
.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

/* 无插画时的暖白渐变 */
.bg-fallback {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 70% 60% at 30% 30%, var(--halo-cream) 0%, transparent 65%),
    radial-gradient(ellipse 55% 50% at 70% 70%, var(--halo-gold) 0%, transparent 65%);
  filter: blur(60px);
  z-index: 0;
}

/* 光点漂浮 — 6 个 */
.particles {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.particle {
  position: absolute; bottom: 0;
  width: 10rpx; height: 10rpx;
  background: radial-gradient(circle, var(--gold-400) 0%, transparent 70%);
  border-radius: 50%;
  animation: float-particle 9s ease-in-out infinite;
  opacity: 0;
}
.p1 { left: 18%; animation-delay: 0s; }
.p2 { left: 48%; animation-delay: 2s; }
.p3 { left: 78%; animation-delay: 4s; }
.p4 { left: 33%; animation-delay: 6s; }
.p5 { left: 63%; animation-delay: 1s; }
.p6 { left: 88%; animation-delay: 3s; }

/* 内容层 — 居中 */
.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 60rpx 64rpx 80rpx;
  text-align: center;
}

/* ═══ 右上角按钮组 ═══ */
.top-bar {
  position: fixed;
  z-index: 10;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.top-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex; align-items: center; justify-content: center;
}
/* 共练图标 — 双圆 */
.icon-together {
  width: 28rpx; height: 28rpx;
  position: relative;
}
.icon-together::before {
  content: '';
  position: absolute; top: 0; left: 0;
  width: 20rpx; height: 20rpx;
  border: 2rpx solid rgba(42, 40, 32, 0.6);
  border-radius: 50%;
}
.icon-together::after {
  content: '';
  position: absolute; bottom: 0; right: 0;
  width: 20rpx; height: 20rpx;
  border: 2rpx solid rgba(42, 40, 32, 0.6);
  border-radius: 50%;
}
/* 世界图标 — 圆+十字 */
.icon-world {
  width: 30rpx; height: 30rpx;
  border: 2.5rpx solid rgba(42, 40, 32, 0.6);
  border-radius: 50%;
  position: relative;
}
.icon-world::before {
  content: '';
  position: absolute;
  top: 50%; left: -2rpx; right: -2rpx;
  height: 2rpx;
  background: rgba(42, 40, 32, 0.6);
}
.icon-world::after {
  content: '';
  position: absolute;
  left: 50%; top: -2rpx; bottom: -2rpx;
  width: 2rpx;
  background: rgba(42, 40, 32, 0.6);
}
/* 情绪图标 — 弧线+两点 */
.icon-mood {
  width: 30rpx; height: 30rpx;
  border: 2.5rpx solid rgba(42, 40, 32, 0.6);
  border-radius: 50%;
  position: relative;
  border-bottom-color: transparent;
}
.icon-mood::before {
  content: '';
  position: absolute;
  top: 7rpx; left: 7rpx;
  width: 5rpx; height: 5rpx;
  background: rgba(42, 40, 32, 0.6);
  border-radius: 50%;
}
.icon-mood::after {
  content: '';
  position: absolute;
  top: 7rpx; right: 7rpx;
  width: 5rpx; height: 5rpx;
  background: rgba(42, 40, 32, 0.6);
  border-radius: 50%;
}

/* ═══ 中央内容 ═══ */
.center {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
}

/* ✦ 光点 — demo 风格 */
.flame {
  width: 128rpx; height: 128rpx;
  margin-bottom: 96rpx;
  background: radial-gradient(circle, rgba(232, 232, 232, 0.5) 0%, transparent 65%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  animation: breathe 3s ease-in-out infinite;
}
/* 揭示后光点变金 */
.flame-lit {
  background: radial-gradient(circle, var(--gold-400) 0%, var(--gold-600) 60%, transparent 80%);
  box-shadow: 0 0 64rpx var(--gold-400);
}
.flame-icon {
  font-size: 64rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 24rpx rgba(255, 255, 255, 0.5);
}

/* 标题 — demo: font-weight:300 + 宽字间距 + 白色(暗底) 或 深色(亮底) */
.home-title {
  font-size: 44rpx; font-weight: 300;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 0.2em;
  margin-bottom: 16rpx;
  display: block;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}
/* 亮色标题(无插画时) */
.home-title-lit {
  color: var(--neutral-900);
  text-shadow: none;
}
.home-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.2em;
  margin-bottom: 48rpx;
  display: block;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
}
.home-sub-lit {
  color: var(--text-secondary);
  text-shadow: none;
}

/* 时长标签 */
.duration-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 96rpx;
}
.duration-tag text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 0.15em;
}

/* ═══ CTA — 暖金发光按钮 (demo 风格) ═══ */
.cta {
  display: flex; align-items: center; justify-content: center;
  padding: 32rpx 112rpx;
  border-radius: 100rpx;
  background: var(--gold-500);
  color: #fff;
  font-size: 26rpx; font-weight: 500;
  letter-spacing: 0.3em;
  box-shadow: 0 4rpx 24rpx rgba(201, 166, 107, 0.5),
              0 1px 0 rgba(255, 255, 255, 0.4) inset;
  border: none;
}

/* ═══ 共练入口 ═══ */
.together-entry {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 48rpx;
  padding: 16rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}
.together-entry-icon {
  width: 24rpx; height: 24rpx;
  position: relative;
}
.together-entry-icon::before {
  content: '';
  position: absolute; top: 0; left: 0;
  width: 16rpx; height: 16rpx;
  border: 1.5rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
}
.together-entry-icon::after {
  content: '';
  position: absolute; bottom: 0; right: 0;
  width: 16rpx; height: 16rpx;
  border: 1.5rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
}
.together-entry-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.2em;
}

/* 明天预告 */
.tomorrow-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 0.2em;
  margin-top: 36rpx;
}

/* 重置按钮 */
.btn-text-inverse {
  background: transparent;
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx; font-weight: 400;
  letter-spacing: 0.3em;
  padding: 20rpx 32rpx;
  border: none;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
}
