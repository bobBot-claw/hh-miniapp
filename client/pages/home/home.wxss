/* pages/home/home.wxss — 主页：暖白浅色 + 光点 + 行动 v0.8 */

.page {
  position: relative;
  width: 100%; min-height: 100vh;
  overflow: hidden;
  background: #FCFCFD;
}

/* 背景插画 — 全屏 */
.illust-bg {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  transform: scale(1.15);
}

/* 无插画时的暖白渐变背景 */
.bg-fallback {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 70% 60% at 25% 25%, rgba(212, 183, 121, 0.18) 0%, transparent 60%),
    radial-gradient(ellipse 55% 50% at 75% 70%, rgba(201, 166, 107, 0.12) 0%, transparent 60%),
    linear-gradient(170deg, #FCFCFD 0%, #F8F4EE 100%);
  z-index: 0;
}

/* 光点漂浮 */
.particles {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.particle {
  position: absolute; bottom: 0;
  width: 10rpx; height: 10rpx;
  background: radial-gradient(circle, var(--gold-500) 0%, transparent 70%);
  border-radius: 50%;
  animation: float-particle 9s ease-in-out infinite;
  opacity: 0;
}
.p1 { left: 18%; animation-delay: 0s; }
.p2 { left: 48%; animation-delay: 2s; }
.p3 { left: 78%; animation-delay: 4s; }
.p4 { left: 33%; animation-delay: 6s; }
.p5 { left: 63%; animation-delay: 1s; }

/* 内容层 */
.content {
  position: relative; z-index: 2;
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 0 64rpx;
}

/* ═══ 右上角按钮组（胶囊下方）═══ */
.top-bar {
  position: fixed;
  z-index: 10;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.top-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex; align-items: center; justify-content: center;
}
/* 共练图标 — 双圆 */
.icon-together {
  width: 28rpx; height: 28rpx;
  position: relative;
}
.icon-together::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 20rpx; height: 20rpx;
  border: 2rpx solid rgba(42, 40, 32, 0.35);
  border-radius: 50%;
}
.icon-together::after {
  content: '';
  position: absolute;
  bottom: 0; right: 0;
  width: 20rpx; height: 20rpx;
  border: 2rpx solid rgba(42, 40, 32, 0.35);
  border-radius: 50%;
}
/* 世界图标 — 圆+十字 */
.icon-world {
  width: 30rpx; height: 30rpx;
  border: 2.5rpx solid rgba(42, 40, 32, 0.35);
  border-radius: 50%;
  position: relative;
}
.icon-world::before {
  content: '';
  position: absolute;
  top: 50%; left: -2rpx; right: -2rpx;
  height: 2rpx;
  background: rgba(42, 40, 32, 0.35);
}
.icon-world::after {
  content: '';
  position: absolute;
  left: 50%; top: -2rpx; bottom: -2rpx;
  width: 2rpx;
  background: rgba(42, 40, 32, 0.35);
}
/* 情绪图标 — 弧线+两点 */
.icon-mood {
  width: 30rpx; height: 30rpx;
  border: 2.5rpx solid rgba(42, 40, 32, 0.35);
  border-radius: 50%;
  position: relative;
  border-bottom-color: transparent;
}
.icon-mood::before {
  content: '';
  position: absolute;
  top: 7rpx; left: 7rpx;
  width: 5rpx; height: 5rpx;
  background: rgba(42, 40, 32, 0.35);
  border-radius: 50%;
}
.icon-mood::after {
  content: '';
  position: absolute;
  top: 7rpx; right: 7rpx;
  width: 5rpx; height: 5rpx;
  background: rgba(42, 40, 32, 0.35);
  border-radius: 50%;
}

/* 中央 */
.center {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
}

/* ✦ 光点 */
.flame {
  width: 128rpx; height: 128rpx;
  margin-bottom: 80rpx;
  background: radial-gradient(circle, rgba(201, 166, 107, 0.15) 0%, transparent 65%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  animation: breathe 3s ease-in-out infinite;
}
.flame-lit {
  background: radial-gradient(circle, var(--gold-500) 0%, var(--gold-600) 60%, transparent 80%);
  box-shadow: 0 0 64rpx rgba(201, 166, 107, 0.4);
}
.flame-icon {
  font-size: 64rpx;
  color: var(--gold-500);
}

/* 标题 */
.home-title {
  font-size: 48rpx; font-weight: 300;
  color: var(--neutral-900);
  letter-spacing: 6rpx;
  margin-bottom: 12rpx;
  display: block;
}
.home-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
  display: block;
}

/* 时长标签 */
.duration-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(20, 125, 69, 0.06);
  border: 1rpx solid rgba(20, 125, 69, 0.12);
  margin-bottom: 80rpx;
}
.duration-tag text {
  font-size: 24rpx;
  color: var(--brand-600, #147D45);
  letter-spacing: 2rpx;
}

/* ═══ 共练入口 ═══ */
.together-entry {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 36rpx;
  padding: 16rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(20, 125, 69, 0.04);
  border: 1rpx solid rgba(20, 125, 69, 0.08);
}
.together-entry-icon {
  width: 24rpx; height: 24rpx;
  position: relative;
}
.together-entry-icon::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 16rpx; height: 16rpx;
  border: 1.5rpx solid rgba(20, 125, 69, 0.4);
  border-radius: 50%;
}
.together-entry-icon::after {
  content: '';
  position: absolute;
  bottom: 0; right: 0;
  width: 16rpx; height: 16rpx;
  border: 1.5rpx solid rgba(20, 125, 69, 0.4);
  border-radius: 50%;
}
.together-entry-text {
  font-size: 24rpx;
  color: var(--brand-600, #147D45);
  opacity: 0.7;
  letter-spacing: 2rpx;
}

/* 明天预告 */
.tomorrow-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
  margin-top: 32rpx;
}

/* 重置按钮 */
.btn-text-inverse {
  background: transparent;
  color: var(--text-tertiary);
  font-size: 24rpx; font-weight: 400;
  letter-spacing: 6rpx;
  padding: 20rpx 32rpx;
  border: none;
}
